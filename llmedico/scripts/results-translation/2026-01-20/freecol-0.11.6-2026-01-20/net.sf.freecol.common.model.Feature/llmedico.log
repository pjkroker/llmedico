        "tags": [],
        "code": "/**\n * {@inheritDoc}\n */\n@Override\nprotected void writeChildren(FreeColXMLWriter xw) throws XMLStreamException {\n    super.writeChildren(xw);\n    for (Scope scope : getScopes()) scope.toXML(xw);\n}"
