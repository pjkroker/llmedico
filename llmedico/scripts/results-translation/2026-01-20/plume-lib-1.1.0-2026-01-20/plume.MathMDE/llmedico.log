lus);\n    if (nonstrict_ends) {\n        if ((r != mod_positive(first_nonstrict, modulus)) || (r != mod_positive(last_nonstrict, modulus))) {\n            return null;\n        }\n    }\n    return new long[] { r, modulus };\n}"
