        ],
        "code": "///\n/// Modulus\n///\n/**\n * Return z such that (z == x mod y) and (0 &le; z &lt; abs(y)).\n * @param x value to be modded\n * @param y modulus\n * @return x % y, where the result is constrained to be positive\n */\npublic static int mod_positive(int x, int y) {\n    int result = x % y;\n    if (result < 0) {\n        result += Math.abs(y);\n    }\n    return result;\n}"
