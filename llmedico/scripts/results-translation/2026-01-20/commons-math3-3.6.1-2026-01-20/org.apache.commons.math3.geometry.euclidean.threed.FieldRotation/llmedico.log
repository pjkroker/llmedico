            "tag": "param",
            "name": "convention",
            "content": "convention to use for the semantics of the angle",
            "assertion": "assert convention != null && RotationConvention.isValid(convention);",
            "description": "convention must be a valid rotation convention"
          },
          {
            "tag": "return",
            "name": null,
            "content": "array of three angles, in the order specified by the set",
            "assertion": "assert (order == RotationOrder.CARDAN && Math.abs(Math.PI/2 - ((Number) getQ2()).doubleValue()) < Math.PI/2) || (order == RotationOrder.EULER && ((Number) getAngle()).doubleValue() > 0 && ((Number) getAngle()).doubleValue() < Math.PI);",
            "description": "array of three angles, in the order specified by the set"
          },
          {
            "tag": "throws",
            "name": "CardanEulerSingularityException",
            "content": "if the rotation is singular with respect to the angles set specified",
            "assertion": "assert receiverObjectID.isSingular(args[0], args[1]);",
            "description": "if the rotation is singular with respect to the angles set specified"
