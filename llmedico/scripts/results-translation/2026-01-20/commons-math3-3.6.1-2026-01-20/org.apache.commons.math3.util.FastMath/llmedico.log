        "javadoc": "/**\n * Power function.  Compute x^y.\n *\n * @param x   a double\n * @param y   a double\n * @return double\n */\n",
        "tags": [
          {
            "tag": "param",
            "name": "x",
            "content": "a double",
            "assertion": "assert true;",
            "description": "a double"
          },
