            "name": null,
            "content": "greatest common divisor, never negative.",
            "assertion": "assert methodResult >= 0 && (args[0] == Long.MIN_VALUE && args[1] == Long.MIN_VALUE ? false : args[0] == 0L && args[1] == 0L ? methodResult == 0L : methodResult == Math.abs(gcd(Math.abs(args[0]), Math.abs(args[1]))));",
