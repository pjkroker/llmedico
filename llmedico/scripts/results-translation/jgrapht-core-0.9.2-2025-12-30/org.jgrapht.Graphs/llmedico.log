, 'RETURN': [{'description': 'a list of the vertices that are the direct predecessors of the specified vertex', 'assertion': 'assert methodResultID != null;', 'name': None, 'content': 'a list of vertices that are the direct predecessors of a\nspecified vertex. If the graph is a multigraph, vertices may appear more\nthan once in the returned list.'}]}}, {'method': 'successorListOf', 'type': 'method', 'parameters': [{'type': {'qualified_name': 'org.jgrapht.DirectedGraph', 'simple_name': 'DirectedGraph', 'is_array': False}, 'name': 'g'}, {'type': {'qualified_name': 'java.lang.Object', 'simple_name': 'Object', 'is_array': False}, 'name': 'vertex'}], 'conditions': {'PARAM': [{'description': 'the graph to look for successors in.', 'assertion': 'assert args[0] != null;', 'name': 'g', 'content': 'the graph to look for successors in.'}, {'description': 'the vertex to get the successors of.', 'assertion': 'assert args[1] != null;', 'name': 'vertex', 'content': 'the vertex to get the successors of.'}], 'RETURN': [{'description': 'a list of the vertices that are the direct successors of the specified vertex. If the graph is a multigraph vertices may appear more than once in the returned list.', 'assertion': 'assert methodResultID != null && ((org.jgrapht.graph.DirectedGraph<? extends org.jgrapht.graph.DefaultEdge>) args[0]).getSuccessors(args[1]) == methodResultID;', 'name': None, 'content': 'a list of the vertices that are the direct successors of the specified vertex. If the graph is a multigraph vertices may appear more than once in the returned list.'}]}}, {'method': 'undirectedGraph', 'type': 'method', 'parameters': [{'type': {'qualified_name': 'org.jgrapht.Graph', 'simple_name': 'Graph', 'is_array': False}, 'name': 'g'}], 'conditions': {'PARAM': [{'description': 'the graph for which an undirected view is to be returned must be either DirectedGraph or UndirectedGraph', 'assertion': 'assert !(args[0] instanceof org.jgrapht.DirectedGraph) && (args[0] instanceof org.jgrapht.G