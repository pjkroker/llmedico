        "code": "/**\n * {@inheritDoc}\n * @since 3.1\n */\npublic DerivativeStructure value(final DerivativeStructure t) {\n    return t.negate().add(m).multiply(b).exp().multiply(q).add(1).pow(oneOverN).reciprocal().multiply(k - a).add(a);\n}"
