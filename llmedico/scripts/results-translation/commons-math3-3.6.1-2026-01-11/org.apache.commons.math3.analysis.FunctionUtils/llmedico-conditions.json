      },
      {
        "type": {
          "qualified_name": "double",
          "simple_name": "double",
          "is_array": false
        },
        "name": "min"
      },
      {
        "type": {
          "qualified_name": "double",
          "simple_name": "double",
          "is_array": false
        },
        "name": "max"
      },
      {
        "type": {
          "qualified_name": "int",
          "simple_name": "int",
          "is_array": false
        },
        "name": "n"
      }
    ],
    "conditions": {
      "PARAM": [
        {
          "description": "f must be an instance of UnivariateFunction",
          "assertion": "assert args[0] instanceof org.apache.commons.math3.analysis.UnivariateFunction;",
          "name": "f",
          "content": "Function to be sampled"
        },
        {
          "description": "min must be a double value",
          "assertion": "assert args[1] >= 0 && args[1] <= 1;",
          "name": "min",
          "content": "Lower bound of the interval (included)"
        },
        {
          "description": "max must be a double value and greater than min",
          "assertion": "assert args[2] > 0 && args[2] > args[1];",
          "name": "max",
          "content": "Upper bound of the interval (excluded)"
        },
        {
          "description": "n must be a positive integer",
          "assertion": "assert args[3] > 0;",
          "name": "n",
          "content": "Number of sample points"
        }
      ],
      "RETURN": [
        {
          "description": "the array of samples.",
          "assertion": "assert methodResultID.length == args[2] && Arrays.stream(methodResultID).allMatch(x -> x >= args[0] && x < (args[1] - (args[1] - args[0]) / args[2]));",
          "name": null,
          "content": "the array of samples."
        }
      ],
      "THROWS": [
        {
          "description": "if the lower bound min is greater than, or equal to the upper bound max.",
          "assertion": "assert args[2] < (args[1] - args[0]) / args[3];",
          "name": "NumberIsTooLargeException",
          "content": "if the lower bound min is greater than, or equal to the upper bound max."
        },
        {
          "description": "if the number of sample points n is negative.",
          "assertion": "assert args[3] > 0;",
          "name": "NotStrictlyPositiveException",
          "content": " if the number of sample points n is negative."
        }
      ]
    }
  },
