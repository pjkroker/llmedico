          "description": "maximalIterationCount must be greater than or equal to minimalIterationCount and less than or equal to SIMPSON_MAX_ITERATIONS_COUNT",
          "assertion": "assert args[3] >= args[2] && args[3] <= receiverObjectID.SIMPSON_MAX_ITERATIONS_COUNT;",
          "name": "maximalIterationCount",
          "content": "maximum number of iterations (must be less than or equal to {@link #SIMPSON_MAX_ITERATIONS_COUNT})"
        }
