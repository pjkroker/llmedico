            "tag": "return",
            "name": null,
            "content": "floating point value represented by {@code string}, or {@code null} if {@code string} has a length of zero or cannot be parsed as a {@code double} value",
            "assertion": "assert methodResultID == (args[0] != null && args[0].length() > 0) ? Double.parseDouble(args[0]) : null;",
            "description": "the floating point value represented by the input string, or null if the input string has a length of zero or cannot be parsed as a double value."
