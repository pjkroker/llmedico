          {
            "tag": "return",
            "name": null,
            "content": "predicate",
            "assertion": "assert !args[0].equals(null) && (Boolean.class.isAssignableFrom(args[1].getReturnType()) || args[1].getReturnType().equals(boolean.class));",
            "description": "the predicate invokes a method on the input object"
          },
          {
            "tag": "throws",
