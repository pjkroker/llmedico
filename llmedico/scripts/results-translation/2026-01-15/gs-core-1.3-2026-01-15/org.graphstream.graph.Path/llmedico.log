        ],
        "javadoc": "/**\n * Method that adds a node (and an edge) to the path. Parameters are the\n * start node : the one who already belong to the path or the first one if\n * the path is empty. The other parameter is the the new edge to add.\n *\n * @param from\n *            The start node.\n * @param edge\n *            The edge used.\n */\n",
        "tags": [
          {
            "tag": "param",
            "name": "from",
            "content": " The start node.",
            "assertion": "assert (args[0] == null) == false;",
            "description": "The start node."
          },
          {
            "tag": "param",
            "name": "edge",
            "content": " The edge used.",
            "assertion": "assert (args[1] == null) == false;",
            "description": "The edge used."
          }
        ],
        "code": "// -------------- MODIFIERS -------------\n/**\n * Method that adds a node (and an edge) to the path. Parameters are the\n * start node : the one who already belong to the path or the first one if\n * the path is empty. The other parameter is the the new edge to add.\n *\n * @param from\n *            The start node.\n * @param edge\n *            The edge used.\n */\npublic void add(Node from, Edge edge) {\n    if (root == null) {\n        if (from == null) {\n            throw new IllegalArgumentException(\"From node cannot be null.\");\n        } else {\n            setRoot(from);\n        }\n    }\n    if (from == null) {\n        from = nodePath.peek();\n    }\n    if (nodePath.size() == 1 || ((nodePath.peek() == from) && (from == edgePath.peek().getSourceNode() || from == edgePath.peek().getTargetNode()))) {\n        nodePath.push(edge.getOpposite(from));\n        edgePath.push(edge);\n    } else {\n        logger.warning(\"Cannot add the specified edge, it cannot be part of the path! %n\");\n    }\n}"
      },
