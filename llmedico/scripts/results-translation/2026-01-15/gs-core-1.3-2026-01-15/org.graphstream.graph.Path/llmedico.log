        ],
        "code": "/**\n * Method that adds an edge an a node to the path. The new edge to add is\n * given.\n *\n * @param edge\n *            The edge to add to the path.\n */\npublic void add(Edge edge) {\n    if (nodePath.isEmpty()) {\n        add(null, edge);\n    } else {\n        add(nodePath.peek(), edge);\n    }\n}"
