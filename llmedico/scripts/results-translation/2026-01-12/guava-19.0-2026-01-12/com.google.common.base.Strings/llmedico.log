import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

public class Main {

    public static void main(String[] args) {
        Map<String, Object> parameters = new HashMap<>();
        List<Map<String, Object>> paramList = new ArrayList<>();

        for (Map<String, Object> param : parameters.values()) {
            paramList.add(param);
        }

        List<Map<String, String>> assertions = generateAssertions("nullToEmpty", "Returns the given string if it is non-null; the empty string otherwise.", paramList);

        for (Map<String, String> assertion : assertions) {
            System.out.println(jsonToString(asignment));
        }
    }

    public static List<Map<String, String>> generateAssertions(String methodName, String description, List<Map<String, Object>> parameters) {
        List<Map<String, String>> assertions = new ArrayList<>();

        if (parameters != null && !parameters.isEmpty()) {
            for (Map<String, Object> param : parameters) {
                Map<String, String> assertion = new HashMap<>();
                assertion.put("description", getParamDescription(description, param));
                assertion.put("assertion", "assert args[" + getArgIndex(param) + "] != null;");
                assertion.put("name", (String) param.get("name"));
                assertion.put("content", (String) param.get("name") + ": must be non-null");

                assertions.add(assertion);
            }
        }

        return assertions;
    }

    private static String getParamDescription(String description, Map<String, Object> param) {
        if (description.contains(param.get("name").toString())) {
            int start = description.indexOf(param.get("name").toString());
            int end = start + param.get("name").toString().length();

            return description.substring(start, end);
        } else {
            return "";
        }
    }

    private static String jsonToString(Map<String, String> assertion) {
        StringBuilder sb = new StringBuilder("{");
        for (Map.Entry<String, String> entry : assertion.entrySet()) {
            sb.append("\"").append(entry.getKey()).append("\": \"").append(entry.getValue()).append("\",");
        }
        return sb.toString().substring(0, sb.length() - 1) + "}";
    }

    private static int getArgIndex(Map<String, Object> param) {
        if (param.get("name").equals("string")) {
            return 0;
        } else {
            throw new RuntimeException("Unsupported parameter");
        }
    }
}
