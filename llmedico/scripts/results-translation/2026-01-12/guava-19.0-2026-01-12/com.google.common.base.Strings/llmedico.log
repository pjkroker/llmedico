        String method = "isNullOrEmpty";
        List<Map<String, Object>> params = Arrays.asList(
                createParamMap("string", new Map<String, Object>() {{
                    put("type", new HashMap<String, Object>() {{
                        put("qualified_name", "String");
                        put("simple_name", "string");
                        put("is_array", false);
                        put("array_dimensions", 0);
                    }});
                    put("name", "string");
                }}))
        );

        String returnType = "{\"qualified_name\": \"boolean\", \"simple_name\": \"boolean\", \"is_array\": False, \"array_dimensions\": 0}";

        List<String> availableMethods = Arrays.asList(
                "None nullToEmpty(None string)",
                "None emptyToNull(None string)",
                "boolean isNullOrEmpty(None string)",
                "None padStart(None string,int minLength,char padChar)",
                "None padEnd(None string,int minLength,char padChar)",
                "None repeat(None string,int count)",
                "None commonPrefix(None a,None b)",
                "None commonSuffix(None a,None b)",
                "boolean validSurrogatePairAt(None string,int index)"
        );

        List<Map<String, Object>> output = new ArrayList<>();
        for (Map<String, Object> param : params) {
            Map<String, String> assertion = createAssertion(param);
            Map<String, String> content = createContent(param);
            output.add(createOutputMap(assertion, content));
        }

        for (Map<String, Object> map : output) {
            System.out.println(JSON.stringify(map));
        }
    }

    private static Map<String, Object> createParamMap(String name, Map<String, Object> param) {
        return new HashMap<>();
    }

    private static String createAssertion(Map<String, Object> param) {
        return "assert " + param.get("name") + " == null || " + param.get("name") + ".isEmpty();";
    }

    private static String createContent(Map<String, Object> param) {
        if (param.containsKey("content")) {
            return (String) param.get("content");
        } else {
            String description = "the string is null or is the empty string";
            return "assert " + param.get("name") + " == null || " + param.get("name") + ".isEmpty(); " + description;
        }
    }

    private static Map<String, Object> createOutputMap(Map<String, Object> assertion, String content) {
        Map<String, Object> output = new HashMap<>();
        output.put("description", content);
        output.put("assertion", assertion);
        output.put("name", paramToName(paramToType((Map<String, Object>) assertion)));
        return output;
    }

    private static String paramToName(Map<String, Object> type) {
        if (type.containsKey("qualified_name")) {
            return ((String) type.get("qualified_name")).split("\\.")[type.get("qualified_name").getClass().isArray() ? ((Integer[]) type.get("qualified_name")).length - 1 : 0];
        } else {
            return (String) type.get("simple_name");
        }
    }

    private static Map<String, Object> paramToType(Map<String, Object> map) {
        if (map.containsKey("type")) {
            return (Map<String, Object>) map.get("type");
        } else {
            return (Map<String, Object>) map.get("qualified_name");
        }
    }
}
