import json

def generate_assertions(javadoc, method_name, parameters, return_type):
    # Parse the Javadoc to extract pre-condition information
    doc = re.sub(r'@return.*', '', javadoc)
    doc = re.sub(r'@throws.*', '', doc)

    # Extract pre-conditions from the Javadoc
    pre_conditions = []
    for line in doc.split('\n'):
        match = re.search(r'@param\s+([a-zA-Z_][a-zA-Z0-9_]*)\s+must\s+(.*)', line)
        if match:
            parameter_name = match.group(1)
            content = match.group(2).strip()
            pre_conditions.append({
                'description': f"{parameter_name} must {content}",
                'assertion': f"assert {parameter_name} == {content};",
                'name': parameter_name,
                'content': content
            })

    # Check if the number of parameters matches the expected output
    if len(parameters) != len(pre_conditions):
        raise ValueError("Number of parameters does not match expected output")

    # Generate the corrected JSON output
    json_output = []
    for i, pre_condition in enumerate(pre_conditions):
        parameter = parameters[i]
        receiver_object_id = f"{method_name}_ID"
        assertion = f"(receiverObjectID.{parameter['name']} != null && !receiverObjectID.{parameter['name']}.isEmpty())" if 'is_array' not in parameter else f"(receiverObjectID.{parameter['name']} != null)"
        
        # Fix the listed problems
        corrected_assertion = re.sub(r'(!)', '', assertion)
        corrected_assertion = re.sub(r'=.*', '', corrected_assertion)

        json_output.append({
            'description': pre_condition['description'],
            'assertion': corrected_assertion,
            'name': pre_condition['name'],
            'content': pre_condition['content']
        })

    return json.dumps(json_output, indent=4)

