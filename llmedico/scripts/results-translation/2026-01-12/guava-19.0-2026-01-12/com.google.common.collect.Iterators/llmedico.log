public class Main {
    public static void main(String[] args) {
        String javadoc = "/**
 * Returns the next element in {@code iterator} or {@code defaultValue} if\n" +
                "* the iterator is empty.  The {@link Iterables} analog to this method is\n" +
                "* {@link Iterables#getFirst}.\n*\n" +
                *
                + "@param defaultValue the default value to return if the iterator is empty\n" +
                + "@return the next element of {@code iterator} or the default value\n" +
                + "@since 7.0";
        String method = "getNext";

        List<Map<String, Object>> params = new ArrayList<>();
        params.add(createParamMap("defaultValue", "java.lang.Object"));
        params.add(createParamMap("iterator", "Iterator"));

        List<String> returnTypes = new ArrayList<>();

        System.out.println(generateJson(javadoc, method, params, returnTypes));
    }

    private static Map<String, Object> createParamMap(String name, String type) {
        Map<String, Object> param = new HashMap<>();
        param.put("name", name);
        param.put("type", type);
        if (isNullable(type)) {
            param.put("content", "<The " + name + " must not be null.>");
        } else {
            param.put("content", name + " must not be null.");
        }
        return param;
    }

    private static boolean isNullable(String type) {
        // Check if the type ends with '[]' to represent an array
        if (type.endsWith("[]")) {
            return false; // Arrays are not nullable
        }
        // Check if the type starts with 'java.lang.Object'
        if (type.startsWith("java.lang.Object")) {
            return true;
        }
        // Check if the type is 'null' or has a single element in its type representation
        return type.equals("null") || type.equals("boolean");
    }

    private static String generateJson(String javadoc, String method, List<Map<String, Object>> params, List<String> returnTypes) {
        Map<String, Object> json = new HashMap<>();
        json.put("params", params);
        if (!returnTypes.isEmpty()) {
            json.put("returnTypes", returnTypes);
        }
        // If there are no parameters or return types, add a default message
        if (json.get("params").isEmpty() && json.get("returnTypes").isEmpty()) {
            json.put("message", "No parameters or return types provided.");
        }
        return json.toString();
    }
}
