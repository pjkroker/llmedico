    public static Map<String, Object> createParam(String name, String type) {
        Map<String, Object> param = new HashMap<>();
        param.put("type", createType(type));
        param.put("name", name);
        return param;
    }

    public static Map<String, Object> createType(String type) {
        Map<String, Object> typeMap = new HashMap<>();

        if (type.startsWith("java.lang.")) {
            String[] parts = type.split("\\.");
            typeMap.put("qualified_name", parts[1]);
            typeMap.put("simple_name", parts[2]);
            typeMap.put("is_array", false);
            typeMap.put("array_dimensions", 0);
        } else if (type.startsWith("%s")) {
            typeMap.put("qualified_name", "String");
            typeMap.put("simple_name", "");
            typeMap.put("is_array", true);
            typeMap.put("array_dimensions", 1);
        }

        return typeMap;
    }

    public static String generateAssertions(Map<String, Object> referenceParams, List<Map<String, Object>> methodParams) {
        StringBuilder output = new StringBuilder();

        // Add assertion for non-null reference
        if (referenceParams.containsKey("reference") && !((String) referenceParams.get("type").get("qualified_name")).equals("java.lang.Object")) {
