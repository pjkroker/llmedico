        // Add assertions for method parameters
        for (Map<String, Object> param : methodParams) {
            if (param.containsKey("type") && !((String) param.get("type").get("qualified_name")).equals("java.lang.Object")) {
                throw new RuntimeException("Method parameter must be a Java Object");
            }
            Map<String, String> assertion2 = createAssertion(param);
            output.append("{\n  \"description\": \"").append(assertion2.get("description")).append("\",\n  \"assertion\": \"assert ").append(assertion2.get("assertion")).append(";\"\n}\n");
        }

        return output.toString();
    }

    public static Map<String, String> createAssertion(Map<String, Object> param) {
        String name = (String) param.get("name");
        String description = "must not be null";
        if ((String) param.get("type").get("qualified_name")).equals("java.lang.String") {
            description = "must not be empty";
        }
        Map<String, String> assertion = new HashMap<>();
        assertion.put("description", description);
        return assertion;
    }
}
