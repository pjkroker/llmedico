            params.append(qualified_name)
        
        elif '@return' in line and param_index < len(params):
            line = line.strip()
            param_index += 1

    # Generate the Java pre-condition assertion statements
    assertions = []
    for param in params:
        if ' @param' in javadoc and param['simple_name'] != 'result':
            description = f"{param['simple_name']} must be of type {param['qualified_name']}"
            array_type = ''
