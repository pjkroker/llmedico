def generate_precondition_assertions(javadoc):
    # Parse the Javadoc to extract the parameters and return type
    params = []
    for tag in javadoc.split('\n\n'):
        if ' @param' in tag:
            param_type = {
                "qualified_name": javadoc.split(' ')[-1].split('(')[0],
                "name": javadoc.split(' ')[-1].split('(')[0].split('=')[0].strip(),
                "is_array": False
            }
            params.append(param_type)
        elif ' @return' in tag:
            return_type = {
                "qualified_name": javadoc.split(' ')[-1].split('(')[0],
                "simple_name": javadoc.split(' ')[-1].split('(')[0].split('=')[0].strip(),
                "is_array": False
            }
        elif ' @throws' in tag:
            continue

    # Generate the Java pre-condition assertion statements
    assertions = []
    for param in params:
        if ' @param' in javadoc and param['name'] != 'result':
            description = f"{param['name']} must be of type {param['qualified_name']}"
            if param.get('array_dimensions') is not None and param['is_array']:
                array_type = f"({param['simple_name']}[])"
                description += f"\n in an array of shape {array_type}"
            assertion = f"assert ({param['qualified_name']})(args[0]) == args[0];"
            assertions.append({
                "description": description,
                "assertion": assertion,
                "name": param["name"],
                "content": javadoc.split('\n\n')[javadoc.split('\n\n').index(' @param' + param['name'])].strip()
            })

    return json.dumps(assertions, indent=4)

# Test the function
