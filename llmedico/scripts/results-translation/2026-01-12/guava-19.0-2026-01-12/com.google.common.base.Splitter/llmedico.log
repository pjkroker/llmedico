                assertion.put("name", (String) parameter.get("name"));
                assertion.put("content", (String) parameter.get("documentation"));

                assertions.add(assertion);
            }
        }

        return assertions;
    }

    private static String getMethodName(String simpleName) {
        switch (simpleName) {
            case "on":
                return "on(char)";
            case "fixedLength":
                return "fixedLength(int)";
            default:
                return null;
        }
    }

    public static void main(String[] args) {
        List<Map<String, Object>> parameters = new ArrayList<>();
        Map<String, Object> separatorMatcherParam = new HashMap<>();
        separatorMatcherParam.put("type", Map.of("qualified_name", "CharMatcher", "simple_name", "on", "is_array", false));
        separatorMatcherParam.put("name", "separatorMatcher");
        parameters.add(separatorMatcherParam);

        // Add other parameter objects here...

        List<Map<String, String>> assertions = generateAssertions(parameters);
        System.out.println(assertions);
    }
}
