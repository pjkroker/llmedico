javadoc_text = """
/**
 * Determines whether a given bloom filter is compatible with this bloom filter. For two
 * bloom filters to be compatible, they must:
 *
 * <ul>
 * <li>not be the same instance
 * <li>have the same number of hash functions
 * <li>have the same bit size
 * <li>have the same strategy
 * <li>have equal funnels
 * <ul>
 *
 * @param that The bloom filter to check for compatibility.
 * @since 15.0
 """

parameters = [{"type": {"qualified_name": "None", "simple_name": "BloomFilter", "is_array": False, "array_dimensions": 0}, 'name': 'that'}]
return_type = {'qualified_name': 'boolean', 'simple_name': 'boolean', 'is_array': False, 'array_dimensions': 0}

# Generate the Java assertions
assertions = []
for parameter in parameters:
    if 'type' not in parameter or 'qualified_name' not in parameter['type']:
        continue

    # Get the parameter name and content
    name = parameter['name']
    content = f"<ul>\n<li>{parameter['type']['content]}</li>\n</ul>"

    # Generate the assertion
    if parameter['type']['is_array']:
        assertion = f"assert args[{name}] != this && args[{name}] == that && args[{name}].type.array_dimensions == this.array_dimensions && args[{name}].type.array_dimensions == that.array_dimensions;"
    else:
        assertion = f"assert {parameter['type']['qualified_name']}(this) == {parameter['type']['qualified_name']}(that)"

    # Add the assertion to the list
    assertions.append({
        "description": parameter['type']['content'],
        "assertion": assertion,
        "name": name,
        "content": content
    })

# Output the JSON
print(json.dumps(assertions, indent=4))
