from typing import List, Dict

class JavaPreconditionAssertions:
    def __init__(self):
        self.output = []

    def generate_assertions(self, javadoc: str, parameters: List[Dict], return_type: Dict, methods: List[str]):
        assert len(parameters) == len(return_type)

        for parameter in parameters:
            name = parameter["name"]
            content = parameter["content"]

            if "must be" not in content or "&lt;" not in content:
                continue

            description = self.format_description(content)
            assertion = self.format_assertion(name, return_type["qualified_name"], description)

            self.output.append({"description": description, "assertion": assertion, "name": name, "content": content})

        for method in methods:
            parts = method.split()
            if len(parts) == 5 and parts[1] == "create" and parts[4] == "None":
                funnel = parts[2]
                expectedInsertions = parts[3]

                self.output.append({"description": f"{funnel} must be of type {funnel}", "assertion": f"assert receiverObjectID.{funnel} instanceof {funnel};", "name": funnel, "content": f"&lt;{funnel}&gt;"})

                if expectedInsertions not in ["int", "long"]:
                    self.output.append({"description": f"{expectedInsertions} must be positive", "assertion": f"assert args[0] > 0;", "name": expectedInsertions, "content": f"The expected number of insertions to the constructed {funnel} must be positive."})

    def format_description(self, content: str) -> str:
        return content.replace("&lt;", "<").replace("&gt;", ">")

    def format_assertion(self, name: str, type_name: str, description: str) -> str:
        return f"assert args[{name}] {description}"

def generate_precondition_assertions(javadoc: str, parameters: List[Dict], return_type: Dict, methods: List[str]) -> str:
    assertions = JavaPreconditionAssertions()
    assertions.generate_assertions(javadoc, parameters, return_type, methods)
    return json.dumps(assertions.output)

