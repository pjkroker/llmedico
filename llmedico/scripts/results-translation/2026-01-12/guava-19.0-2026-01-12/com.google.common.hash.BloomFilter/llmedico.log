    public static String generateAssertion(String content, String name, String description) {
        StringBuilder assertionBuilder = new StringBuilder();
        if (!content.contains("&lt;")) {
            assertionBuilder.append("assert ").append(name).append(" : ").append(description).append(";");
        } else {
            assertionBuilder.append("assert ").append(name).append(" : ").append(content.replace("<", "&lt;")).append(";");
