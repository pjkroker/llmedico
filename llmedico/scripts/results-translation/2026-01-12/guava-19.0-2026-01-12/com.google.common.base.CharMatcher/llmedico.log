import org.json.JSONObject;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class Main {
    public static void main(String[] args) {
        String javadoc = "/**\n * Returns the index of the first matching character in a character sequence, starting from a\n * given position, or {@code -1} if no character matches after that position.\n *\n * <p>The default implementation iterates over the sequence in forward order, beginning at {\code\n * start}, calling {@link #matches} for each character.\n *\n * @param sequence the character sequence to examine\n * @param start the first index to examine; must be nonnegative and no greater than {\code\n *        sequence.length()}\n * @return the index of the first matching character, guaranteed to be no less than {\code\n *         start}, or {@code -1} if no character matches\n *\n * @throws IndexOutOfBoundsException if start is negative or greater than {\code\n *         sequence.length()} \n */";

        String[] parts = javadoc.split("\n");
        for (String part : parts) {
            if (part.contains("/**")) continue;
            Pattern pattern = Pattern.compile("@throws\\s+([^\\(]+).*?\\(.*?\\)");
            Matcher matcher = pattern.matcher(part);
            while (matcher.find()) {
                String description = matcher.group(1);
                System.out.println(generateAssertion(description));
            }
        }
    }

    private static String generateAssertion(String description) {
        if (!description.contains("if") && !description.contains("unless")) {
            return null;
        } else {
            int startIndex = description.indexOf("if") == -1 ? description.indexOf("unless") : description.indexOf("if");
            int endIndex = description.indexOf(":", startIndex);
            String condition = description.substring(startIndex, endIndex).trim();
            System.out.println("{\n" +
                    "    \"description\": \"" + replaceVariableNames(condition) + "\",\n" +
                    "    \"assertion\": \"assert (" + replaceVariableNames(condition) + ");\",\n" +
                    "    \"name\": \"IndexOutOfBoundsException\",\n" +
                    "    \"content\": \"if start is negative or greater than sequence.length()\"}");
        }
        return null;
    }

    private static String replaceVariableNames(String description) {
        if (!description.contains("sequence")) {
            return description;
        } else {
            description = description.replace("sequence", "sequence");
            description = description.replace("start", "start");
            return description;
        }
    }
}
