import java.util.*;

public class AssertionGenerator {
    public static void main(String[] args) {
        // First parameter
        Map<String, Object> parameters = new HashMap<>();
        parameters.put("k1", null);
        parameters.put("v1", null);

        // Second parameter
        parameters.put("k2", null);
        parameters.put("v2", null);

        System.out.println(generateAssertion("IllegalArgumentException", "if two keys are equal according to their natural ordering", parameters));
    }

    public static String generateAssertion(String exceptionName, String description, Map<String, Object> parameters) {
        StringBuilder assertion = new StringBuilder("\"{");
        assertion.append("\"description\":\"").append(description).append("\",");
        assertion.append("\"assertion\":\"");

        // If there are parameters
        if (parameters != null && !parameters.isEmpty()) {
            for (Map.Entry<String, Object> entry : parameters.entrySet()) {
                // Add the parameter to the assertion
                assertion.append("assert ").append(entry.getKey()).append(" == ").append(entry.getValue()).append(";");
            }
        } else {
            // If there are no parameters
            assertion.append("\"assert false;");
        }

        assertion.append("\",");
        assertion.append("\"name\":\"").append(exceptionName).append("\",");
        assertion.append("\"content\":\"").append(description).append("\"}");
        return assertion.toString();
    }
}
