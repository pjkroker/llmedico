            if 'IllegalArgumentException' in tag or 'NullPointerException' in tag:
                throws.append({
                    'description': condition,
                    'assertion': f"assert {condition}",
                    'name': 'NullPointerException' if 'NullPointerException' in tag else 'IllegalArgumentException',
                    'content': '<code>null</code>' if 'NullPointerException' in tag else description
                })
            elif 'NullPointerException' in condition:
