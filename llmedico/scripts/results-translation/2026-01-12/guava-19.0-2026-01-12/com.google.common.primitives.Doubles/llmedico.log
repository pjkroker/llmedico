                assertion.append("assert !").append(parts[1]).append("; ");
            }
        }

        return "{\n" +
               "    \"description\": \"" + description + "\",\n" +
               "    \"assertion\": \"" + assertion.toString().trim() + "\",\n" +
               "    \"name\": \"" + name + "\",\n" +
               "    \"content\": \"" + description + "\"\n" +
               "}";
    }
}
