    public static String generateAssertion(String name, String description) {
        String[] conditions = description.split(" and ");
        StringBuilder assertion = new StringBuilder();
        
        for (String condition : conditions) {
            if (!condition.contains("not")) {
                assertion.append("assert ").append(condition).append(";");
            } else {
