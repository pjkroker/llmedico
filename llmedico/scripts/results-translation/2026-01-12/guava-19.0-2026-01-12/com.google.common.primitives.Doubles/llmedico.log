            String assertion = "assert args[" + ((paramTags.length == 1) ? 0 : paramTags[i].getString("name")) + "] != null && (" + content + ")";
            System.out.println("{\"description\":\"" + description + "\",\"assertion\":\"" + assertion + "\",\"name\":\"" + (paramTags.length == 1 ? "args[0]" : paramTags[i].getString("name")) + "\",\"content\":\"" + content + "\"}");
        }
    }
}
