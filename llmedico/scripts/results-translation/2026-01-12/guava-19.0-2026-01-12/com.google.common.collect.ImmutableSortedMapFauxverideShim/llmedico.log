import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

public class AssertionGenerator {

    public static List<Map<String, String>> generateAssertions(String javadoc) {
        // Parse Javadoc to extract @throws tags
        Map<String, String> throwsTags = parseThrowsTags(javadoc);

        // Generate assertions for each @throws tag
        List<Map<String, String>> assertions = new ArrayList<>();
        for (Map.Entry<String, String> entry : throwsTags.entrySet()) {
            String throwsDescription = entry.getValue();
            String assertion = generateAssertion(throwsDescription);
            Map<String, String> assertionMap = new HashMap<>();
            assertionMap.put("description", throwsDescription);
            assertionMap.put("assertion", assertion);
            assertionMap.put("name", entry.getKey());
            assertionMap.put("content", null); // Not applicable for @throws tags
            assertions.add(assertionMap);
        }

        return assertions;
    }

    private static Map<String, String> parseThrowsTags(String javadoc) {
        // Find all @throws tags in the Javadoc
        List<String> throwsTags = findThrowsTags(javadoc);

        // Create a map to store the extracted information
        Map<String, String> throwsMap = new HashMap<>();

        // Iterate over each @throws tag and extract its description
        for (String tag : throwsTags) {
            int startIndex = javadoc.indexOf(tag);
            int endIndex = javadoc.indexOf("\n", startIndex);
            if (endIndex == -1) {
                endIndex = javadoc.length();
            }
            String description = javadoc.substring(startIndex, endIndex).trim();

            // Remove the @throws tag from the original Javadoc
            javadoc = javadoc.substring(endIndex + 1);

            // Extract the key and value from the description
            String[] parts = description.split(":", 2);
            if (parts.length == 2) {
                throwsMap.put(parts[0].trim(), parts[1].trim());
            }
        }

        return throwsMap;
    }

    private static List<String> findThrowsTags(String javadoc) {
        // Find all @throws tags in the Javadoc
        List<String> throwsTags = new ArrayList<>();
        int startIndex = 0;
        while (startIndex < javadoc.length()) {
            int endIndex = javadoc.indexOf("@throws", startIndex);
            if (endIndex == -1) {
                break;
            }
            startsWith(javadoc.substring(startIndex, endIndex), "@throws");
            throwsTags.add(javadoc.substring(startIndex + 8, endIndex));
            startIndex = endIndex + 1;
        }

        return throwsTags;
    }

    private static boolean startsWith(String str, String prefix) {
        if (str.startsWith(prefix)) {
            return true;
        }
        for (int i = 0; i < prefix.length(); i++) {
            if (i >= str.length() || str.charAt(i) != prefix.charAt(i)) {
                break;
            }
        }
        return i == prefix.length();
    }

    private static String generateAssertion(String throwsDescription) {
        // Remove the "Not supported" message from the description
        throwsDescription = throwsDescription.replace("Not supported. ", "");

        // Extract the key and value from the description
        String[] parts = throwsDescription.split(":", 2);
        if (parts.length == 2) {
            String key = parts[0].trim();
            String value = parts[1].trim();

            // Generate the assertion based on the type of exception
            if (value.equals("always")) {
                return "assert(false);";
            } else if (value.startsWith("<b>You are attempting to create a map that may contain</b> ")) {
                // This is not applicable for this specific @throws tag, so we skip it
                return "";
            } else {
                // Generate the assertion for an UnsupportedOperationException
                String keyParts = key.split("\\s+");
                if (keyParts.length == 1) {
                    return "assert(false);";
                } else {
                    List<String> keys = new ArrayList<>();
                    for (int i = 0; i < keyParts.length - 2; i += 2) {
                        keys.add(keyParts[i] + " instanceof Comparable");
                    }
                    String assertion = "assert(";
                    for (String k : keys) {
                        assertion += k + " || ";
                    }
                    assertion = assertion.substring(0, assertion.length() - 4);
                    assertion += ");";
                    return assertion;
                }
            }
        }

        // If the description is not in the expected format, we raise an exception
        throw new RuntimeException("Invalid @throws tag format");
    }

