public static List<String> generateAssertions(String methodDescription, String methodName, List<Parameter> parameters, List<ReturnType> returnTypes) {
    List<String> assertions = new ArrayList<>();

    if (methodDescription.contains("@throws UnsupportedOperationException always")) {
        String unsupportedClaim = "You are attempting to create a map that may contain\n" +
                "* non-{@code Comparable} keys.\n" +
                "<b>Proper calls will resolve to the version\n" +
                "* in {@code ImmutableSortedMap}, not this dummy version.</b>";
        if (unsupportedClaim.contains(methodName)) {
            String assertion = " * Always";
            assertions.add(assertion);
        }
    }

    for (ReturnType returnType : returnTypes) {
        if (returnType.getQualification() == null) {
            String immutableClaim = "Proper calls will resolve to the version\n" +
                    "* in {@code ImmutableSortedMap}, not this dummy version.";
            if (immutableClaim.contains(methodName)) {
                String assertion = "* Must be called with keys of type {@code Comparable}";
                assertions.add(assertion);
            }
        } else if (returnType.getQualification().equals("ImmutableSortedMap")) {
            String immutableClaim = "Proper calls will resolve to the version\n" +
                    "* in {@code ImmutableSortedMap}, not this dummy version.";
            if (immutableClaim.contains(methodName)) {
                String assertion = "* Must be called with keys of type {@code Comparable}";
                assertions.add(assertion);
            }
        }
    }

    return assertions;
}
