class PreconditionAssertion:
    def __init__(self, description, assertion, name):
        self.description = description
        self.assertion = assertion
        self.name = name

def generate_assertions(method_description, parameters, return_type, available_methods):
    precondition_assertions = []

    if 'TryParse' in method_description:
        for parameter in parameters:
            description = parameter.get('content', '').replace('&lt;', '&lt;')
            if 'must be null' in description:
                assertion = f"assert receiverObjectID.string == null;"
            else:
