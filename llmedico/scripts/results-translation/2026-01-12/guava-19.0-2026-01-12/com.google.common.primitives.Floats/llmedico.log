            assert_type = return_type.get('qualified_name') or return_type.get('simple_name')

            if parameter['name'] == 'string':
                type_param = f"args[0]"
            elif parameter['name'] == 'value':
                type_param = "args[1]"
            else:
                # Ignore unknown parameters
                continue

            assertion += f" && {type_param} {assert_type}"

            precondition_assertions.append(PreconditionAssertion(description, assertion, parameter['name']))

    return json.dumps([precondition_assertion.__dict__ for precondition_assertion in precondition_assertions], indent=4)

