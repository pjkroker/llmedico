                    assertion = "";
                }

                String typeParam;
                if ((String) parameter.get("name").get("qualified_name") != null) {
                    typeParam = (String) parameter.get("name").get("qualified_name");
                } else if ((String) parameter.get("name").get("simple_name") != null) {
                    typeParam = (String) parameter.get("name").get("simple_name");
                } else {
