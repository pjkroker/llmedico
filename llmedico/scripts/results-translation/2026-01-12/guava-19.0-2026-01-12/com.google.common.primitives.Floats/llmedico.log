        this.description = description;
        this.assertion = assertion;
        this.name = name;
    }
}

public class Main {
    public static List<PreconditionAssertion> generateAssertions(String methodDescription, List<Map<String, Object>> parameters, Map<String, Object> returnType, List<String> availableMethods) {
        List<PreconditionAssertion> preconditionAssertions = new ArrayList<>();

        if (methodDescription.contains("TryParse")) {
            for (Map<String, Object> parameter : parameters) {
                String description = (String) parameter.get("content");
                if (description.contains("must be null")) {
                    assertion = "assert receiverObjectID.string == null;";
                } else {
