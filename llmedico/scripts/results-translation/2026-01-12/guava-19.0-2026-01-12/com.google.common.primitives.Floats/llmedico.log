                if (!assertion.isEmpty()) {
                    assertion += " && " + typeParam + " " + assertType;
                }

                preconditionAssertions.add(new PreconditionAssertion(description, assertion, (String) parameter.get("name")));
            }
        }

        return preconditionAssertions;
    }

