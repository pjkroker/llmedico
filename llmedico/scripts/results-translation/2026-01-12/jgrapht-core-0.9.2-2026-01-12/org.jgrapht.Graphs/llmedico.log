        String[] preconditionLines = methodBody.split("// @param {");
        List<JSONObject> assertions = new ArrayList<>();
        for (String line : preconditionLines) {
            if (!line.isEmpty()) {
                JSONObject assertion = createAssertion(line, paramInfo);
                assertions.add(assertion);
            }
        }

        return assertions;
    }

    private static JSONObject createParamInfo(String param) {
        if ("[]" == param) {
            return new JSONObject("{\"type\":\"java.lang.Object\",\"simple_name\":\"Object\",\"is_array\":true,\"array_dimensions\":0}");
        } else if (^ == param) {
