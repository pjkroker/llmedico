    public static List<JSONObject> generateAssertions(String methodBody, String methodSignature) {
        // Parse method signature to get parameter information
        String[] params = methodSignature.split(",");
        List<JSONObject> paramInfo = new ArrayList<>();
        for (String param : params) {
            paramInfo.add(createParamInfo(param));
