                assertions.add(assertion);
            }
        }

        return assertions;
    }

    private static JSONObject createParamInfo(String param) {
        if ("[]" == param) {
            return new JSONObject("{\"type\":\"java.lang.Object\",\"simple_name\":\"Object\",\"is_array\":true,\"array_dimensions\":0}");
        } else if (param.equals("^")) {
            return new JSONObject("{\"type\":\"java.lang.Object\",\"simple_name\":\"Object\",\"is_array\":false,\"array_dimensions\":0}");
        } else if ("<" + param + ">" == param) {
            return new JSONObject("{\"type\":\"java.lang.String\",\"simple_name\":\"String\",\"is_array\":false,\"array_dimensions\":0}");
        }
        return new JSONObject("{\"type\":\"java.lang.Integer\",\"simple_name\":\"Integer\",\"is_array\":false,\"array_dimensions\":0}");
    }

    private static JSONObject createAssertion(String line, List<JSONObject> paramInfo) {
        String[] parts = line.split("\\s+");
        if (parts.length < 2) {
            return new JSONObject("{\"description\":\"\"}");
        }
        String condition = parts[1];
        String paramName = "g";
        for (int i = 0; i < paramInfo.size(); i++) {
            if (((JSONObject) paramInfo.get(i)).get("name").equals(parts[i])) {
                paramName = ((JSONObject) paramInfo.get(i)).get("name");
                break;
            }
        }

        String assertionStr;
        switch (paramName) {
            case "g":
                assertionStr = "assert receiverObjectID.addEdge(null, args[0], null) != null";
                break;
            case "e":
                assertionStr = "assert receiverObjectID.hasEdge(args[0]) && receiverObjectID.containsVertex(args[1]) && receiverObjectID.containsVertex(args[2])";
                break;
            default:
                return new JSONObject("{\"description\":\"\"}");
        }

        JSONObject assertion = new JSONObject();
        assertion.put("description", condition);
        assertion.put("assertion", assertionStr);
        assertion.put("name", paramName);

        return assertion;
    }
}
