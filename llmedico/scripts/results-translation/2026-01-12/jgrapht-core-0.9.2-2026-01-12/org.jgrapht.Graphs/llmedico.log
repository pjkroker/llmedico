boolean addGraph(None destination,None source)
void addGraphReversed(None destination,None source)
boolean addAllEdges(None destination,None source,None edges)
boolean addAllVertices(None destination,None vertices)
None neighborListOf(None g,java.lang.Object vertex)
None predecessorListOf(None g,java.lang.Object vertex)
None successorListOf(None g,java.lang.Object vertex)
None undirectedGraph(None g)
boolean testIncidence(None g,java.lang.Object e,java.lang.Object v)
java.lang.Object getOppositeVertex(None g,java.lang.Object e,java.lang.Object v)
None getPathVertexList(None path)
"""
    )

print(json.dumps(main(), indent=4))

