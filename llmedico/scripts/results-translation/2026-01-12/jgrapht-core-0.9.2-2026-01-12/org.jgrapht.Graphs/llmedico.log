from typing import List

def generate_assertion(params: List[dict], description: str) -> dict:
    assertion = f"assert {description}"
    return {"description": description, "assertion": assertion}

def process_parameters(parameters: List[dict]) -> List[dict]:
    processed_parameters = []
    for parameter in parameters:
        if "type" in parameter:
            type_qualified_name = parameter["type"]["qualified_name"]
            if type_qualified_name is not None:
                return generate_assertion(
                    {"name": parameter["name"], "type": {"qualified_name": type_qualified_name}},
                    f"{parameter['name']} must be a {type_qualified_name}",
                )
    return []

def process_available_methods(methods: str) -> List[dict]:
    lines = methods.split("\n")
    processed_lines = []
    for line in lines:
        if not line.strip().endswith("}"):
            continue
        if " instanceof " in line:
            parts = line.split(" instanceof ")
            parameter_name = parts[-1].strip()
            parameter_type_qualified_name = (
                json.loads(parts[0]).get("type", {}).get("qualified_name")
            )
            processed_lines.append(
                generate_assertion(
                    {"name": parameter_name},
                    f"{parameter_name} must be a {parameter_type_qualified_name}",
                )
            )
    return processed_lines

def main():
    params = [
        {"type": {"qualified_name": "None", "simple_name": "DirectedGraph", "is_array": False, "array_dimensions": 0}, "name": "g"},
        {"type": {"qualified_name": "java.lang.Object", "simple_name": "Object", "is_array": False, "array_dimensions": 0}, "name": "vertex"},
    ]
    description = "the graph to look for successors in."
    return process_parameters(params) + process_available_methods(
        """
java.lang.Object addEdge(None g,java.lang.Object sourceVertex,java.lang.Object targetVertex,double weight)
java.lang.Object addEdgeWithVertices(None g,java.lang.Object sourceVertex,java.lang.Object targetVertex)
boolean addEdgeWithVertices(None targetGraph,None sourceGraph,java.lang.Object edge)
