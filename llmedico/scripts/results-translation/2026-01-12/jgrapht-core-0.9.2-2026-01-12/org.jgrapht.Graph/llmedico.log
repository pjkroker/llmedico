    public static List<JsonElement> generateAssertions(String javadoc) {
        // Parse Javadoc to extract method name, parameters, and return type
        String[] lines = javadoc.split("\n");
        String methodName = "";
        List<Parameter> params = new ArrayList<>();
        String returnType = "";

        for (String line : lines) {
            if (line.trim().startsWith("@param")) {
                // Extract parameter information
                String paramLine = line.trim();
                String[] parts = paramLine.split("\\s+")[1].split(";");
                for (String part : parts) {
                    if (!part.isEmpty()) {
                        String[] typeAndName = part.split(":");
                        String type = typeAndName[0];
                        String name = typeAndName[1];
                        params.add(new Parameter(type, name));
                    }
                }
            } else if (line.trim().startsWith("@return")) {
                // Extract return type
                returnType = line.trim().split("=")[1].trim();
            }
        }

        // Generate assertions for each parameter
        List<JsonElement> assertions = new ArrayList<>();
        for (Parameter param : params) {
            String assertion = "assert " + getAssertion(param.type, param.name);
