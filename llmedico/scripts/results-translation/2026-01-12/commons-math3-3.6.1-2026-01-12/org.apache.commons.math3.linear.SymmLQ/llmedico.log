        return returnType;
    }

    private static String generateAssertion(Parameter param, String methodName, String returnTypeStr) {
        // Generate an assertion for the parameter
        String description = param.getDescription();
        if (description == null || description.isEmpty()) {
            description = "The parameter " + param.getName() + " should not be null.";
        }
        return "Before calling " + methodName + "(...) with " + param.getName() + ", check that " + description;
