                assertions.add(assertion);
            }
        }

        return assertions;
    }

    private static List<Parameter> parseParameters(String javadoc, String[] parameters) {
        // Parse the parameters from the Javadoc
        List<Parameter> paramList = new ArrayList<>();
        for (String param : parameters) {
            String[] parts = param.split(",");
            Parameter paramDef = new Parameter(parts[0].trim(), parts[1].trim());
            if (paramDef.isRequired()) {
                paramList.add(paramDef);
            }
        }

        return paramList;
    }

