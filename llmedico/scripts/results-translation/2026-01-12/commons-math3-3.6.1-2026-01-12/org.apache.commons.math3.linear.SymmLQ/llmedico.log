        availableMethods.add(new AvailableMethod(method, null, false, 0.0, null, null));
        availableMethods.add(new AvailableMethod(method, null, true, null));
        availableMethods.add(new AvailableMethod(method, null, false, 0.0, null, null));
        availableMethods.add(new AvailableMethod(method, null, false, 0.0, null, null, null));

        List<ReturnType> returnTypes = new ArrayList<>();
        returnTypes.add(new ReturnType(null, "RealVector"));

        generatePreConditionAssertions(javadoc, method, parameters, availableMethods, returnTypes);
    }

    private static void generatePreConditionAssertions(String javadoc, String method, List<Parameter> parameters, List<AvailableMethod> availableMethods, List<ReturnType> returnTypes) {
        System.out.println("Pre-conditions for " + method);

        for (AvailableMethod availableMethod : availableMethods) {
            String[] parameterNames = new String[parameters.size()];
            for (int i = 0; i < parameters.size(); i++) {
                parameterNames[i] = parameters.get(i).getName();
            }

            if (availableMethod.isOptional()) {
                System.out.println("    - " + method + "(" + String.join(", ", parameterNames) + ") is optional");
            } else {
                System.out.println("    - " + method + "(" + String.join(", ", parameterNames) + ") is required");
            }

            if (availableMethod.hasParameter()) {
                Parameter parameter = availableMethod.getParameter();
                System.out.println("    - " + parameter.getName() + ": " + parameter.getType().getName());
            }
        }

        for (ReturnType returnType : returnTypes) {
            System.out.println("    - Return type: " + returnType.getType().getName());
        }
    }

    private static class Parameter {
        private String name;
        private Object value;
        private Class<?> type;

        public Parameter(String name, Object value, Class<?> type) {
            this.name = name;
            this.value = value;
            this.type = type;
        }

        public String getName() {
            return name;
        }
    }

    private static class AvailableMethod {
        private String method;
        private boolean isOptional;
        private Parameter parameter;

        public AvailableMethod(String method, Parameter parameter) {
            this.method = method;
            this.parameter = parameter;
        }

        public AvailableMethod(String method, boolean isOptional) {
            this.method = method;
            this.isOptional = isOptional;
        }

        public AvailableMethod(String method, boolean isOptional, Object value) {
            this(method, isOptional);
            this.parameter = new Parameter("shift", value, Double.class);
        }

        public AvailableMethod(String method, boolean isOptional, Object value1, Object value2) {
            this(method, isOptional);
            this.parameter = new Parameter("goodb", value1, Boolean.class);
        }

        public AvailableMethod(String method, boolean isOptional, Object value1, Object value2, Object value3) {
            this(method, isOptional, value1, value2);
            this.parameter = new Parameter("x", value3, Double.class);
        }

        public AvailableMethod(String method, boolean isOptional, Object value1, Object value2, Object value3, Object value4) {
            this(method, isOptional, value1, value2, value3);
            this.parameter = new Parameter("m", value4, RealLinearOperator.class);
        }

        public boolean isOptional() {
            return isOptional;
        }

        public Parameter getParameter() {
            return parameter;
        }
    }

    private static class ReturnType {
        private Object value;

        public ReturnType(Object value) {
            this.value = value;
        }

        public Class<?> getType() {
            return value.getClass();
        }
    }
}"

