import re

class JavadocParser:
    def __init__(self):
        self.output = []

    def parse(self, javadoc):
        # Find all @param tags
        param_tags = re.findall(r'@param\s+(\w+)\s+([^;]+)', javadoc)

        for tag in param_tags:
            name, content = tag

            # Generate a Java assert statement
            assertion = f"assert {content};"
            self.output.append({
                "description": content,
                "assertion": assertion,
                "name": name,
                "content": content
            })

    def get_output(self):
        return json.dumps(self.output)

# Create an instance of the parser
parser = JavadocParser()

# Input Javadoc
javadoc = """
/**
 * Creates a new instance of this class, with <a href="#stopcrit">default
 * stopping criterion</a> and custom iteration manager. Note that setting
 * {@code check} to {@code true} entails an extra matrix-vector product in
 * the initial phase.
 *
 * @param manager the custom iteration manager
 * @param delta the &delta; parameter for the default stopping criterion
 * @param check {@code true} if self-adjointedness of both matrix and
 * preconditioner should be checked
 */
"""

# Parse the Javadoc
parser.parse(javadoc)

# Get the output as a JSON string
output = parser.get_output()

print(output)
