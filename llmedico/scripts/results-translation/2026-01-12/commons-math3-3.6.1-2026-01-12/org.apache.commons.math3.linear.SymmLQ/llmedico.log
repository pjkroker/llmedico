        System.out.println("Pre-conditions for " + method);

        for (AvailableMethod availableMethod : availableMethods) {
            String[] parameterNames = new String[parameters.size()];
            for (int i = 0; i < parameters.size(); i++) {
                parameterNames[i] = parameters.get(i).getName();
            }

            if (availableMethod.isOptional()) {
                System.out.println("    - " + method + "(" + String.join(", ", parameterNames) + ") is optional");
            } else {
                System.out.println("    - " + method + "(" + String.join(", ", parameterNames) + ") is required");
            }

