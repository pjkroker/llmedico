                "assertion": assertion,
                "name": name,
                "content": content
            })

    def _find_pattern(self, text, pattern):
        import re
        matches = []
        for match in re.finditer(pattern, text):
            start, end = match.span()
            yield (text[start:end].strip(), text[start:end+1])

    def get_output(self):
        return json.dumps(self.output)

def main():
    parser = JavadocParser()
    javadoc = """
