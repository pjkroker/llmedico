import json

class JavadocParser:
    def __init__(self):
        self.output = []

    def parse(self, javadoc):
        # Find all @param tags
        param_pattern = r'@param\s+(\w+)\s+([^;]+)'
        param_matches = [m for m in self._find_pattern(javadoc, param_pattern)]

        for match in param_matches:
            name, content = match

            # Check if the parameter is not null
            if "null" in content.lower():
                continue

            # Generate a Java assert statement
            assertion = f"assert args[0] == {content.replace('<', '&lt;').replace('>', '&gt;')}"
            self.output.append({
                "description": content,
                "assertion": assertion,
                "name": name,
                "content": content
            })

        # Find all @throws tags
        throws_pattern = r'@throws\s+([^;]+)'
        throws_matches = [m for m in self._find_pattern(javadoc, throws_pattern)]

        for match in throws_matches:
            name = match
            content = javadoc.split(name)[1].strip()
            # Generate a Java assert statement
            assertion = f"assert false"
            self.output.append({
                "description": content,
                "assertion": assertion,
                "name": name,
                "content": content
            })

    def _find_pattern(self, text, pattern):
        import re
        matches = []
        for match in re.finditer(pattern, text):
            start, end = match.span()
            yield (text[start:end].strip(), text[start:end+1])

    def get_output(self):
        return json.dumps(self.output)

def main():
    parser = JavadocParser()
    javadoc = """
/**
 * Creates a new instance of this class, with <a href="#stopcrit">default
 * stopping criterion</a> and custom iteration manager. Note that setting
 * {@code check} to {@code true} entails an extra matrix-vector product in
 * the initial phase.
 *
 * @param manager the custom iteration manager
 * @param delta the &delta; parameter for the default stopping criterion
 * @param check {@code true} if self-adjointedness of both matrix and
 * preconditioner should be checked
 */
"""
    parser.parse(javadoc)
    print(parser.get_output())

if __name__ == "__main__":
    main()
```

