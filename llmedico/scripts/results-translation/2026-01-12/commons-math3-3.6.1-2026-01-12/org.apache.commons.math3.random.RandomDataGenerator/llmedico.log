public class AssertionGenerator {
    public static List<Map<String, String>> generateAssertions(String method, List<Map<String, Object>> parameters, Map<String, Object> returnType, List<Method> availableMethods) {
        List<Map<String, String>> assertions = new ArrayList<>();

        // Check for NotStrictlyPositiveException
