import java.util.*;

public class AssertionGenerator {
    public static List<Map<String, String>> generateAssertions(String method, List<Map<String, Object>> parameters, Map<String, Object> returnType, List<Method> availableMethods) {
        List<Map<String, String>> assertions = new ArrayList<>();

        // Check for NotStrictlyPositiveException
        if (availableMethods.stream().anyMatch(m -> m.getName().equals("NotStrictlyPositiveException"))) {
            Map<String, String> notStrictlyPositiveExceptionAssertion = generateNotStrictlyPositiveExceptionAssertion(parameters);
            assertions.add(notStrictlyPositiveExceptionAssertion);
        }

        return assertions;
    }

    private static Map<String, String> generateNotStrictlyPositiveExceptionAssertion(List<Map<String, Object>> parameters) {
        List<String> conditionDescriptions = new ArrayList<>();
        for (Map<String, Object> parameter : parameters) {
            if (parameter.get("type").get("qualified_name").equals("int")) {
                conditionDescriptions.add(parameter.get("name") + " <= 0");
            }
        }

        String assertion = String.join(" || ", conditionDescriptions);
        return new HashMap<>();
        {
            "description": String.join(", ", conditionDescriptions),
            "assertion": assertion,
            "name": "NotStrictlyPositiveException",
            "content": String.join(", ", conditionDescriptions)
        };
    }
}
```

