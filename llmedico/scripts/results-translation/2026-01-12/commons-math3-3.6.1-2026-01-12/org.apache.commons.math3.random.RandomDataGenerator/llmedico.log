                // Extract parameter names
                String[] paramNames = line.substring(line.indexOf("["), line.indexOf("]")).split(",");
                int paramIndex = 0;
                while (paramNames[paramIndex].contains(":")) {
                    params[paramIndex++] = paramNames[paramIndex].substring(0, paramNames[paramIndex].indexOf(":"));
                }
            } else if (line.contains("@return")) {
                // Extract return type
                returnType = line.substring(line.indexOf("["), line.indexOf("]")).split("\\s+")[1];
            } else if (line.contains("throws")) {
                // Extract exception conditions
                String[] exceptions = line.split("throws");
                List<String> assertionList = new ArrayList<>();
                for (String exception : exceptions[1].split(",")) {
                    // Extract condition and content from @throws tag
                    String[] parts = exception.trim().split(":");
                    String description = parts[0];
                    String content = parts[1];
                    if (!description.isEmpty()) {
                        assertionList.add(generateAssertion(description, content));
                    }
                }
                return assertionList;
            } else if (line.contains("This implementation")) {
                // Extract method name
                methodName = line.trim();
            }
        }

