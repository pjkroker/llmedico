                returnType.put("qualified_name", parts[1]);
                returnType.put("simple_name", parts[1]);
                returnType.put("is_array", false);
            } else if (line.contains("@throws")) {
                String[] parts = line.split(" @throws ");
                methodName = parts[0].trim();
                Map<String, Object> throwsParams = new HashMap<>();
                for (String throwParam : parts[1].split(",")) {
                    String[] throwParamParts = throwParam.trim().split(":");
                    throwsParams.put(throwParamParts[0], new HashMap<>());
                    throwsParams.get(throwParamParts[0]).put("type", new HashMap<>());
                    throwsParams.get(throwParamParts[0]).get("qualified_name").put("qualified_name", throwParamParts[1]);
                    throwsParams.get(throwParamParts[0]).get("qualified_name").put("simple_name", throwParamParts[1]);
                    throwsParams.get(throwParamParts[0]).get("type").put("is_array", false);
                }
