                "'assertion3': {'name': 'assert', 'content': \"assert(Double.isNaN(lower) || Double.isNaN(upper))\", 'type': 'function'}";

        List<Assertion> assertions = generateAssertions(javadoc, method, parameters, returnType);

        Gson gson = new GsonBuilder().setPrettyPrinting().create();
        System.out.println(gson.toJson(assertions));
