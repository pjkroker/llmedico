import java.util.ArrayList;
import java.util.List;

public class AssertionGenerator {
    public static List<String> generateAssertions(String javadoc) {
        // Parse the Javadoc to extract the method name, parameters, and return type
        String[] lines = javadoc.split("\n");
        String methodName = "";
        String[] params = new String[0];
        String returnType = "";

        for (String line : lines) {
            if (line.contains("@param")) {
                // Extract parameter names
                String[] paramNames = line.substring(line.indexOf("["), line.indexOf("]")).split(",");
                int paramIndex = 0;
                while (paramNames[paramIndex].contains(":")) {
                    params[paramIndex++] = paramNames[paramIndex].substring(0, paramNames[paramIndex].indexOf(":"));
                }
            } else if (line.contains("@return")) {
                // Extract return type
                returnType = line.substring(line.indexOf("["), line.indexOf("]")).split("\\s+")[1];
            } else if (line.contains("throws")) {
                // Extract exception conditions
                String[] exceptions = line.split("throws");
                List<String> assertionList = new ArrayList<>();
                for (String exception : exceptions[1].split(",")) {
                    // Extract condition and content from @throws tag
                    String[] parts = exception.trim().split(":");
                    String description = parts[0];
                    String content = parts[1];
                    if (!description.isEmpty()) {
                        assertionList.add(generateAssertion(description, content));
                    }
                }
                return assertionList;
            } else if (line.contains("This implementation")) {
                // Extract method name
                methodName = line.trim();
            }
        }

        // Generate assertions for each exception condition
        List<String> assertionList = new ArrayList<>();
        for (String param : params) {
            String[] parts = param.trim().split(":");
            String parameterName = parts[0];
            if (!parameterName.isEmpty()) {
                assertionList.add(generateAssertion("shape <= 0 or scale <= 0", "NotStrictlyPositiveException"));
            }
        }

        return assertionList;
    }

    private static String generateAssertion(String description, String content) {
        return "assert " + content + ";";
    }

    public static void main(String[] args) {
        String javadoc = """
 * /**
 * <p>Generates a random value from the
 * {@link org.apache.commons.math3.distribution.GammaDistribution Gamma Distribution}.</p>
 *
 * <p>This implementation uses the following algorithms: </p>
 *
 * <p>For 0 < shape < 1: <br/>
 * Ahrens, J. H. and Dieter, U., <i>Computer methods for
 * sampling from gamma, beta, Poisson and binomial distributions.</i>
 * Computing, 12, 223-246, 1974.</p>
 *
 * <p>For shape >= 1: <br/>
 * Marsaglia and Tsang, <i>A Simple Method for Generating
 * Gamma Variables.</i> ACM Transactions on Mathematical Software,
 * Volume 26 Issue 3, September, 2000.</p>
 *
 * @param shape the median of the Gamma distribution
 * @param scale the scale parameter of the Gamma distribution
 * @return random value sampled from the Gamma(shape, scale) distribution
 * @throws NotStrictlyPositiveException if {@code shape <= 0} or
 * {@code scale <= 0}.
 */
""";

        List<String> assertions = generateAssertions(javadoc);
        for (String assertion : assertions) {
            System.out.println(assertion);
        }
    }
}
```

