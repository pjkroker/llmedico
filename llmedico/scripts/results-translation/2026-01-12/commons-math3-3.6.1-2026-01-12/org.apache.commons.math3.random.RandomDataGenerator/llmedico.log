            description.append("assert(Double.isNaN(").append(paramMap.get("lower").getName()).append(") || Double.isNaN(").append(paramMap.get("upper").getName()).append("))");
        }

        return description.toString();
    }
}

class Assertion {
    private String name;
    private String content;

    public Assertion(String name, String content) {
        this.name = name;
        this.content = content;
    }

    public String getName() {
        return name;
    }

    public String getContent() {
        return content;
    }
}
```

