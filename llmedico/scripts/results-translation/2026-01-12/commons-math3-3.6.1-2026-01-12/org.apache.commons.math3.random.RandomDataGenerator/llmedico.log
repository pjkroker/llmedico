    private static Map<String, String> generateNotStrictlyPositiveExceptionAssertion(List<Map<String, Object>> parameters) {
        List<String> conditionDescriptions = new ArrayList<>();
        for (Map<String, Object> parameter : parameters) {
            if (parameter.get("type").get("qualified_name").equals("int")) {
