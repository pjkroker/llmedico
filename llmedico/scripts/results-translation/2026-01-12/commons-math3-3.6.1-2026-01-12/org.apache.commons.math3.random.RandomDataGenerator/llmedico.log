import java.util.*;

public class AssertionGenerator {
    public static void main(String[] args) {
        String javadoc = "/**
 * {@inheritDoc}
 *
 * <p>
 * <strong>Algorithm Description</strong>: if the lower bound is excluded,
 * scales the output of Random.nextDouble(), but rejects 0 values (i.e.,
 * will generate another random double if Random.nextDouble() returns 0).
 * This is necessary to provide a symmetric output interval (both
 * endpoints excluded).
 * </p>
 *
 * @throws NumberIsTooLargeException if {@code lower >= upper}
 * @throws NotFiniteNumberException if one of the bounds is infinite
 * @throws NotANumberException if one of the bounds is NaN
 */
";

        String method = "nextUniform";
        List<Parameter> parameters = Arrays.asList(
            new Parameter("lower", "double"),
            new Parameter("upper", "double"),
            new Parameter("lowerInclusive", "boolean")
        );
        String returnType = "{'qualified_name': 'double', 'simple_name': 'double', 'is_array': False, 'array_dimensions': 0}";

        List<Assertion> assertions = generateAssertions(javadoc, method, parameters, returnType);

        for (Assertion assertion : assertions) {
            System.out.println(assertion);
        }
    }

    public static List<Assertion> generateAssertions(String javadoc, String method, List<Parameter> parameters, String returnType) {
        // Extract @throws tags
        String[] throwsTags = javadoc.split("@throws\\s*{");

        List<Assertion> assertions = new ArrayList<>();

        for (String tag : throwsTags) {
            if (!tag.isEmpty()) {
                String[] parts = tag.split("@throws\\s*{([^}]*)}");
                String description = parts[1].trim();

                // Split into individual conditions
                String[] conditions = description.split(" and ");

                for (String condition : conditions) {
                    // Extract parameters
                    Map<String, Parameter> paramMap = new HashMap<>();
                    for (Parameter parameter : parameters) {
                        if (condition.contains(parameter.getName())) {
                            paramMap.put(parameter.getName(), parameter);
                        }
                    }

                    // Generate assertion
                    String assertionDescription = generateAssertionDescription(method, condition, paramMap);

                    // Add to list of assertions
                    Assertions.add(assertionDescription);
                }
            }
        }

        return assertions;
    }

    public static String generateAssertionDescription(String method, String condition, Map<String, Parameter> paramMap) {
        StringBuilder description = new StringBuilder();

        if (condition.contains("if lower >= upper")) {
            description.append("assert(lower >= upper)");
        } else if (condition.contains("if one of the bounds is infinite")) {
            description.append("assert(Math.isInfinite(").append(paramMap.get("lower").getName()).append(") || Math.isInfinite(").append(paramMap.get("upper").getName()).append("))");
        } else if (condition.contains("if one of the bounds is NaN")) {
            description.append("assert(Double.isNaN(").append(paramMap.get("lower").getName()).append(") || Double.isNaN(").append(paramMap.get("upper").getName()).append("))");
        }

        return description.toString();
    }
}

class Parameter {
    private String name;
    private String type;

    public Parameter(String name, String type) {
        this.name = name;
        this.type = type;
    }

    public String getName() {
        return name;
    }

    public String getType() {
        return type;
    }
}

class Assertion {
    private String description;

    public Assertion(String description) {
        this.description = description;
    }

    @Override
    public String toString() {
        return "assert(" + description + ")";
    }
}
