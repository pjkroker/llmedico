import org.json.*;

public class Main {
    public static void main(String[] args) throws Exception {
        String javadoc = "/**
 * Linear constructor
 * Build a vector from four other ones and corresponding scale factors.
 * The vector built will be a1 * u1 + a2 * u2 + a3 * u3 + a4 * u4
 * @param a1 first scale factor
 * @param u1 first base (unscaled) vector
 * @param a2 second scale factor
 * @param u2 second base (unscaled) vector
 * @param a3 third scale factor
 * @param u3 third base (unscaled) vector
 * @param a4 fourth scale factor
 * @param u4 fourth base (unscaled) vector
 */";

        String parameters = "[{\"type\": {\"qualified_name\": \"double\", \"simple_name\": \"double\", \"is_array\": False, \"array_dimensions\": 0}, \"name\": \"a1\"}, {\"type\": {\"qualified_name\": None, \"simple_name\": \"Vector3D\", \"is_array\": False, \"array_dimensions\": 0}, \"name\": \"u1\"}, {\"type\": {\"qualified_name\": \"double\", \"simple_name\": \"double\", \"is_array\": False, \"array_dimensions\": 0}, \"name\": \"a2\"}, {\"type\": {\"qualified_name\": None, \"simple_name\": \"Vector3D\", \"is_array\": False, \"array_dimensions\": 0}, \"name\": \"u2\"}, {\"type\": {\"qualified_name\": \"double\", \"simple_name\": \"double\", \"is_array\": False, \"array_dimensions\": 0}, \"name\": \"a3\"}, {\"type\": {\"qualified_name\": None, \"simple_name\": \"Vector3D\", \"is_array\": False, \"array_dimensions\": 0}, \"name\": \"u3\"}, {\"type\": {\"qualified_name\": \"double\", \"simple_name\": \"double\", \"is_array\": False, \"array_dimensions\": 0}, \"name\": \"a4\"}, {\"type\": {\"qualified_name\": None, \"simple_name\": \"Vector3D\", \"is_array\": False, \"array_dimensions\": 0}, \"name\": \"u4\"}]";
        String returnType = "None";

        System.out.println(generateAssertions(javadoc, parameters, returnType));
    }

    public static String generateAssertions(String javadoc, String parameters, String returnType) {
        JSONObject paramsJson = new JSONObject(parameters);
        JSONArray paramArray = paramsJson.getJSONArray("type");

        StringBuilder assertions = new StringBuilder();

        for (int i = 0; i < paramArray.length(); i++) {
            JSONObject param = paramArray.getJSONObject(i);

            if (!param.has("qualified_name") || !param.has("simple_name")) {
                continue;
            }

            String name = param.getString("name");

            if (name.equals("a1") || name.equals("a2") || name.equals("a3") || name.equals("a4")) {
                assertions.append(name).append(" != 0.0\n");
            } else if (name.equals("u1") || name.equals("u2") || name.equals("u3") || name.equals("u4")) {
                assertions.append(name).append(" != null\n");
            }
        }

        return assertions.toString();
    }
}
```

