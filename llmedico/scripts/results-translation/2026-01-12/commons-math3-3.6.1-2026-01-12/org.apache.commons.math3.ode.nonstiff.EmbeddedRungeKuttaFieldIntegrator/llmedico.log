        "type": "method",
        "name": "integrate",
        "return_type": {
          "qualified_name": null,
          "simple_name": "FieldODEStateAndDerivative",
          "is_array": false,
          "array_dimensions": 0
        },
        "parameters": [
          {
            "type": {
              "qualified_name": null,
              "simple_name": "FieldExpandableODE",
              "is_array": false,
              "array_dimensions": 0
            },
            "name": "equations"
          },
          {
            "type": {
