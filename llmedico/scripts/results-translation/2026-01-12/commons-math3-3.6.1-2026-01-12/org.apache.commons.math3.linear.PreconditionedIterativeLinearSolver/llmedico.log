import java.util.*;

public class Main {
    public static void main(String[] args) {
        String javadoc = "/**
 * Returns an estimate of the solution to the linear system A \u00bd x =
 * b.
 *
 * @param a the linear operator A of the system
 * @param m the preconditioner, M (can be {@code null})
 * @param b the right-hand side vector
 * @param x0 the initial guess of the solution
 * @return a new vector containing the solution
 * @throws NullArgumentException if one of the parameters is {@code null}
 * @throws NonSquareOperatorException if {@code a} or {@code m} is not
 * square
 * @throws DimensionMismatchException if {@code m}, {@code b} or
 * {@code x0} have dimensions inconsistent with {@code a}
 * @throws MaxCountExceededException at exhaustion of the iteration count,
 * unless a custom
 * {@link org.apache.commons.math3.util.Incrementor.MaxCountExceededCallback callback}
 * has been set at construction of the {@link IterationManager}
 */";

        String[] parameters = "[{'type': {'qualified_name': null, 'simple_name': 'RealLinearOperator', 'is_array': false, 'array_dimensions': 0}, 'name': 'a'}, {'type': {'qualified_name': null, 'simple_name': 'RealLinearOperator', 'is_array': false, 'array_dimensions': 0}, 'name': 'm'}, {'type': {'qualified_name': null, 'simple_name': 'RealVector', 'is_array': false, 'array_dimensions': 0}, 'name': 'b'}, {'type': {'qualified_name': null, 'simple_name': 'RealVector', 'is_array': false, 'array_dimensions': 0}, 'name': 'x0'}]";
        String returnType = "{'qualified_name': null, 'simple_name': 'RealVector', 'is_array': false, 'array_dimensions': 0}";

        List<String> throwsExceptions = new ArrayList<>();
        throwsExceptions.add("NullArgumentException");
        throwsExceptions.add("NonSquareOperatorException");
        throwsExceptions.add("DimensionMismatchException");
        throwsExceptions.add("MaxCountExceededException");

        for (String exception : throwsExceptions) {
            String[] parts = exception.split("\\s+");
            if (parts.length > 1) {
                String parameterName = parts[0];
                List<String> parameters = Arrays.asList(parts);
                String parameterType = "";
                for (int i = 1; i < parameters.size(); i++) {
                    parameterType += parameters.get(i) + " ";
                }
                throwsExceptions.add("if (" + parameterName + " == null || " + parameterType + ")");
            } else {
                throwsExceptions.add(exception);
            }
        }

        System.out.println(generateAssertions(javadoc, parameters, returnType));
    }

    public static String generateAssertions(String javadoc, String[] parameters, String returnType) {
        StringBuilder assertions = new StringBuilder();

        for (String exception : throwsExceptions) {
            String[] parts = exception.split("\\s+");
            if (parts.length > 1) {
                String parameterName = parts[0];
                List<String> parameters = Arrays.asList(parts);
                String parameterType = "";
                for (int i = 1; i < parameters.size(); i++) {
                    parameterType += parameters.get(i) + " ";
                }
                assertions.append("assert ").append(parameterName).append(" == null || ").append(parameterType).append(";\n");
            } else {
                assertions.append("assert ").append(exception).append(";\n");
            }
        }

        return assertions.toString();
    }

    public static List<String> throwsExceptions = new ArrayList<>();
}
