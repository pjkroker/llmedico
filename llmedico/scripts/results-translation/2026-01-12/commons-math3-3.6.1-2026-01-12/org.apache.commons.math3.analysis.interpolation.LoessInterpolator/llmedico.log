import java.util.Map;

public class Main {
    public static void main(String[] args) {
        List<Map<String, Object>> parameters = 
            List.of(
                Map.of("type", Map.of("qualified_name", "double", "simple_name" , "double", "is_array" , true, "array_dimensions" , 1),
                "name", "xval"),
                Map.of("type", Map.of("qualified_name", "double", "simple_name" , "double", "is_array" , true, "array_dimensions" , 1),
                "name", "yval")
            );

        String returnType = "{\"qualified_name\":\"double\",\"simple_name\":\"double\",\"is_array\":true,\"array_dimensions\":1}";

        System.out.println(generateAssertions(parameters, returnType));
    }

    public static String generateAssertions(List<Map<String, Object>> parameters, String returnType) {
        StringBuilder output = new StringBuilder();

        if (parameters.isEmpty()) return "";

        for (Map<String, Object> parameter : parameters) {

            if (!parameter.containsKey("type") || !parameter.containsKey("name")) continue;

            Map<String, Object> type = (Map<String, Object>) parameter.get("type");
            String name = (String) parameter.get("name");

            output.append("{\n")
                .append("  \"description\": \"").append(type.getOrDefault("qualified_name", "unknown")).append(" must be an array of finite real numbers\",\n")
                .append("  \"assertion\": \"if (args[0] == null || !java.util.Arrays.asList((double[]) args[0]).stream().anyMatch(Double::isInfinite)) throw new AssertionError();\",\n")
                .append("  \"name\": \"").append(name).append("\",\n")
                .append("  \"content\": \"<table><tr><td>").append(type.getOrDefault("qualified_name", "unknown")).append("</td></tr></table>\"\n")
                .append("}\n\n");
        }

        return output.toString();
    }
}
