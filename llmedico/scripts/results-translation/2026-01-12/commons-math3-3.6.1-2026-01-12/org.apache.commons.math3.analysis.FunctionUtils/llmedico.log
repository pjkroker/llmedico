def generate_assertions(javadoc):
    # Parse the Javadoc to extract parameters and return type
    params = []
    return_type = None
    for line in javadoc.split('\n'):
        if line.startswith('@param'):
            param = {}
            param['type'] = parse_param_type(line)
            param['name'] = line.split(' ')[1].strip()
            params.append(param)
        elif line.startswith('@return'):
            return_type = parse_return_type(line)
    return type, params, return_type

def parse_param_type(line):
    if '<' in line:
        start_idx = line.index('<')
        end_idx = line.index('>')
        param_type_str = line[start_idx+1:end_idx]
        return {'qualified_name': None, 'simple_name': param_type_str, 'is_array': False, 'array_dimensions': 0}
    else:
        return {'qualified_name': None, 'simple_name': line.split('=')[0].strip(), 'is_array': False, 'array_dimensions': 0}

def parse_return_type(line):
    if '<' in line:
        start_idx = line.index('<')
        end_idx = line.index('>')
        return_type_str = line[start_idx+1:end_idx]
        return {'qualified_name': None, 'simple_name': return_type_str, 'is_array': False, 'array_dimensions': 0}
    else:
        return {'qualified_name': None, 'simple_name': line.split('=')[0].strip(), 'is_array': False, 'array_dimensions': 0}

def generate_assertions_for_method(javadoc, method_name):
    type, params, return_type = generate_assertions(javadoc)
    if method_name not in type:
        return []
    method_params = type[method_name]['parameters']
    assertions = []
    for param in params:
        if param['name'] in method_params:
            assertion = {
                'description': param.get('content', ''),
                'assertion': f'assert {param["name"]} == {param["type"]["simple_name"]}',
                'name': param['name'],
                'content': param.get('content', '')
            }
            assertions.append(assertion)
    return assertions

