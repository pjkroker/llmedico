import json

def generate_precondition_assertions(javadoc, method_name, parameters, return_type):
    precondition_assertions = []
    
    # Split the javadoc into lines
    for line in javadoc.split('\n'):
        if not line.strip():
            continue
        
        start_index = line.find('@param') + len('@param')
        end_index = line.find('\n', start_index)
        
        # Extract the description of each parameter
        description = line[start_index:end_index].strip()
        
        # Split the description into lines
        param_description_lines = [line.strip() for line in description.split(')')]
        
        # Create a dictionary to store the precondition assertion
        precondition_assertion = {
            "description": "",
            "name": method_name,
            "content": ""
        }
        
        # Extract the parameter name and type from each line
        for param_line in param_description_lines:
            if '->' in param_line:
                param_type, param_name = param_line.split('->')
            else:
                param_name = param_line
                param_type = ''
            
            # Add the parameter to the precondition assertion
            precondition_assertion["content"] += f"{param_name} {param_type}\n"
        
        # Remove the trailing newline character
        precondition_assertion["content"] = precondition_assertion["content"].strip()
        
        # Append the precondition assertion to the list
        precondition_assertions.append(precondition_assertion)
    
    # Generate the Java assert statement for each parameter
    for i, param_description in enumerate(precondition_assertions):
        parameter = parameters[i]
        content = param_description["content"]
        
        # Replace HTML entities and <code> tags with their escaped versions
        content = content.replace('&lt;', '&amp;').replace('&gt;', '&amp;')
        content = content.replace('<code>', '\\\\code\\').replace('</code>', '\\\\\\/code\\\\')
        
        # Generate the Java assert statement
        if 'null' in content:
            assertion = f"assert {parameter['name']} != null;"
        else:
            assertion = f"assert {parameter['name']} instanceof {content.split(' ')[0]};"
        
        precondition_assertions[i]["assertion"] = assertion
    
    return json.dumps(precondition_assertions)

