  {
    "method": "sample",
    "type": "method",
    "parameters": [
      {
        "type": {
          "qualified_name": null,
          "simple_name": "UnivariateFunction",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "f"
      },
      {
        "type": {
          "qualified_name": "double",
          "simple_name": "double",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "min"
      },
      {
        "type": {
          "qualified_name": "double",
          "simple_name": "double",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "max"
      },
      {
        "type": {
          "qualified_name": "int",
          "simple_name": "int",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "n"
      }
    ],
    "conditions": {
      "PARAM": [
        {
          "description": "f must be a UnivariateFunction",
          "assertion": "assert receiverObjectID instanceof com.example.UnivariateFunction;",
          "name": "f",
          "content": "&lt;UnivariateFunction&gt;"
        },
        {
          "description": "min must be a double and greater than or equal to the lower bound of the interval",
          "assertion": "assert args[1] instanceof java.lang.Double && args[1] >= min;",
          "name": "min",
          "content": "&lt;double&gt; and &lt;= &lt;min&gt;"
        },
        {
          "description": "max must be a double, greater than the upper bound of the interval, and not equal to the lower bound of the interval",
          "assertion": "assert args[2] instanceof java.lang.Double && args[2] > max && args[2] != min;",
          "name": "max",
          "content": "&lt;double&gt;, &lt;> &lt;= &lt;min&gt;"
        },
        {
          "description": "n must be a positive integer",
          "assertion": "assert args[3] instanceof java.lang.Integer && args[3] > 0;",
          "name": "n",
          "content": "&lt;positive integer&gt;"
        }
      ],
      "RETURN": [
        {
          "tag": "return",
          "name": null,
          "content": "the array of samples.",
          "assertion": "",
          "description": "the array of samples."
        }
      ],
      "THROWS": [
        {
          "description": "if min is greater than or equal to max.",
          "assertion": "assert receiverObjectID.sample(args[2],args[1],args[3]-1)<0;",
          "name": "NumberIsTooLargeException",
          "content": "if the lower bound min is greater than, or equal to the upper bound max."
        },
        {
          "description": "if n is negative.",
          "assertion": "assert args[3] < 0;",
          "name": "NotStrictlyPositiveException",
          "content": "if the number of sample points n is negative."
        }
      ]
    }
  },
