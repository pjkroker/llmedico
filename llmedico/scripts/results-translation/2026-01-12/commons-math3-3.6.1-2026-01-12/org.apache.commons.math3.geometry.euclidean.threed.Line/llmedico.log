        if name is not None:
            assertions.append({
                "description": doc,
                "assertion": f"assert {name} >= 0.0;",
                "name": name,
                "content": content
            })

    # Return the list of generated assertions as JSON
    return json.dumps(assertions, indent=4)

def parse_params(javadoc: str) -> list:
    params = []
    lines = javadoc.split('\n')
    for line in lines:
        if line.strip().startswith('import'):
            continue
        if line.strip().startswith('@param'):
            param = {}
            parts = line.strip().split(' @param ')
            param['name'] = parts[1].strip()
            param['content'] = '&lt;strong&gt;' + parts[2].strip() + '&lt;/strong&gt;'
            param['doc'] = ''
        elif line.strip().startswith('@return'):
            return_type = {}
            parts = line.strip().split(' @return ')
            if len(parts) > 1:
                return_type['qualified_name'] = parts[1].strip()
                return_type['doc'] = ''
            params.append(param)
    return params

def parse_return_type(javadoc: str) -> dict:
    return_type = {}
    lines = javadoc.split('\n')
    for line in lines:
        if line.strip().startswith('@return'):
            parts = line.strip().split(' @return ')
            if len(parts) > 1:
                return_type['qualified_name'] = parts[1].strip()
                return_type['doc'] = ''
    return return_type

def generate_assertion(param: dict, return_type: dict) -> (str, str, str):
    name = param.get("name")
    content = param.get("content", "")
    doc = param.get("doc", "")

    if name is None:
        raise ValueError("Parameter name is missing")

    # Generate assertion based on parameter type
    if "qualified_name" in return_type and return_type["qualified_name"] == "boolean":
        assertion = f"assert {name} == null;"
    else:
        assertion = f"assert {name} >= 0.0;"

    return name, assertion, doc

