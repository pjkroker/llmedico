import java.util.ArrayList;
import java.util.List;

public class AssertionGenerator {

    public static List<Assertion> generateAssertions(String methodDescription, String methodName, List<Parameter> parameters, String returnType, List<String> availableMethods) {
        List<Assertion> assertions = new ArrayList<>();

        // Extract @throws tags from the Javadoc
        String[] throwsTags = methodDescription.split("@throws\\s*{");
        for (String tag : throwsTags) {
            if (!tag.isEmpty()) {
                String[] conditions = tag.split("if\\s*([^\\s]+)");
                for (String condition : conditions) {
                    // Remove leading/trailing whitespace and split into individual conditions
                    String[] individualConditions = condition.trim().split("\\s+and\\s+");
                    for (String individualCondition : individualConditions) {
                        // Extract parameter names from the @throws description
                        String[] paramNames = extractParamNames(individualCondition);
                        if (paramNames != null) {
                            // Create an assertion statement based on the condition
                            Assertion assertion = createAssertion(methodName, returnType, availableMethods, parameters, paramNames, individualCondition);
                            assertions.add(assertion);
                        }
                    }
                }
            }
        }

        return assertions;
    }

    private static String[] extractParamNames(String condition) {
        // Find the substring that starts with 'if' and ends with ')'
        int startIndex = condition.indexOf("if");
        int endIndex = condition.indexOf(')');
        if (startIndex != -1 && endIndex != -1) {
            return condition.substring(startIndex + 3, endIndex).split("\\s+");
        } else {
            return null;
        }
    }

    private static Assertion createAssertion(String methodName, String returnType, List<String> availableMethods, List<Parameter> parameters, String[] paramNames, String condition) {
