        return new Assertion(methodName, returnType, availableMethods, parameters, exceptionType, assertion);
    }

    private static String getExceptionType(String condition) {
        if (condition.contains("NotStrictlyPositiveException")) {
            return "NotStrictlyPositiveException";
        } else if (condition.contains("NumberIsTooSmallException")) {
            return "NumberIsTooSmallException";
        } else {
            return "UnknownException"; // default to UnknownException
        }
    }

    private static String createAssertionStatement(String exceptionType, String[] paramNames, String condition) {
