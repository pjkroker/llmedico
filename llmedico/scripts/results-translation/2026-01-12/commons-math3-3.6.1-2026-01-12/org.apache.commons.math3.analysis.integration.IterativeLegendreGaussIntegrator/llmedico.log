                for (String paramName : paramNames) {
                    if (paramName.equals("minimalIterationCount") || paramName.equals("pointsCount")) {
                        assertion.append(paramName).append("=").append(condition).append(",");
                    }
                }
                assertion = new StringBuilder(assertion.substring(0, assertion.length() - 1));
            }

        } else if (exceptionType.equals("NumberIsTooSmallException")) {
            boolean isMaxIterationCount = false;
            boolean isMinIterationCount = false;

            for (String paramName : paramNames) {
                if (paramName.equals("maximalIterationCount") || paramName.equals("minimalIterationCount")) {
                    isMaxIterationCount |= condition.contains(paramName);
                    isMinIterationCount |= condition.contains(paramName);
                }
            }

            if (isMaxIterationCount && isMinIterationCount) {
                assertion.append("assert ").append(exceptionType).append("(");
                for (String paramName : paramNames) {
                    if (paramName.equals("maximalIterationCount") || paramName.equals("minimalIterationCount")) {
                        assertion.append(paramName).append("=").append(condition).append(",");
                    }
                }
                assertion = new StringBuilder(assertion.substring(0, assertion.length() - 1));
