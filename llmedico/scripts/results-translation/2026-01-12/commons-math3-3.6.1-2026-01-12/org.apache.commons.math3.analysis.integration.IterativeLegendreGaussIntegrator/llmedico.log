                        assertion.append(paramName).append("=").append(condition).append(",");
                    }
                }
                assertion = new StringBuilder(assertion.substring(0, assertion.length() - 1));
            }

        } else {
            // Handle other exception types (e.g., UnknownException)
            for (String paramName : paramNames) {
                assertion.append(paramName).append("=").append(condition).append(",");
            }
