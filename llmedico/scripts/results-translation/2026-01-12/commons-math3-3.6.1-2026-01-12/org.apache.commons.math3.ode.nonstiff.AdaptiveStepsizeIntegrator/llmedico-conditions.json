          "description": "minimal step (sign is irrelevant, regardless of integration direction, forward or backward), the last step can be smaller than this",
          "assertion": "assert receiverObjectID.initializeStep(args[0], args[1], args[2], None, null, null, null, null) == null;",
          "name": "initializeStep",
          "content": "the first number; must be positive"
        },
        {
          "description": "maximal step (sign is irrelevant, regardless of integration direction, forward or backward), the last step can be smaller than this",
          "assertion": "assert receiverObjectID.initializeStep(args[2], args[1], args[0], None, null, null, null, null) == null;",
          "name": "initializeStep",
          "content": "the second number; must be positive"
        },
        {
          "description": "allowed absolute error",
          "assertion": "assert receiverObjectID.sanityChecks(args[3], None) == null;",
          "name": "sanityChecks",
          "content": "scalAbsoluteTolerance"
        },
        {
          "description": "allowed relative error",
          "assertion": "assert receiverObjectID.sanityChecks(args[4], None) == null;",
          "name": "sanityChecks",
          "content": "scalRelativeTolerance"
        }
      ]
    }
