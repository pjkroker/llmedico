  {
    "method": "filterStep",
    "type": "method",
    "parameters": [
      {
        "type": {
          "qualified_name": "double",
          "simple_name": "double",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "h"
      },
      {
        "type": {
          "qualified_name": "boolean",
          "simple_name": "boolean",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "forward"
      },
      {
        "type": {
          "qualified_name": "boolean",
          "simple_name": "boolean",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "acceptSmall"
      }
    ],
    "conditions": {
      "PARAM": [
        {
          "description": "h must be signed",
          "assertion": "assert args[0] >= 0;",
          "name": "h",
          "content": "signed step"
        },
        {
          "description": "forward must be true or false",
          "assertion": "assert args[1] == true || args[1] == false;",
          "name": "forward",
          "content": "forward integration indicator"
        },
        {
          "description": "acceptSmall must be true or false",
          "assertion": "assert args[2] == true || args[2] == false;",
          "name": "acceptSmall",
          "content": "if true, steps smaller than the minimal value are silently increased up to this value, if false such small steps generate an exception"
        }
      ],
      "RETURN": [
        {
          "description": "a bounded integration step (h if no bound is reach, or a bounded value).",
          "assertion": "assert methodResultID == ((args[0] >= getMinStep()) && (args[0] <= getMaxStep())) || methodResultID == (getMinStep());",
          "name": null,
          "content": "a bounded integration step (h if no bound is reach, or a bounded value)."
        }
      ],
      "THROWS": [
        {
          "description": "if step is too small and acceptSmall is false",
          "assertion": "assert args[0] < NumberIsTooSmallException.MIN_VALUE && !args[2];",
          "name": "NumberIsTooSmallException",
          "content": "if the step is too small and acceptSmall is false"
        }
      ]
    }
