        "code": "/**\n * {@inheritDoc}\n */\npublic double[] nextVector() {\n    final double[] v = new double[dimension];\n    for (int i = 0; i < dimension; i++) {\n        int index = count;\n        double f = 1.0 / base[i];\n        int j = 0;\n        while (index > 0) {\n            final int digit = scramble(i, j, base[i], index % base[i]);\n            v[i] += f * digit;\n            // floor( index / base )\n            index /= base[i];\n            f /= base[i];\n        }\n    }\n    count++;\n    return v;\n}"
