    public static List<Assertion> generateAssertions(List<String> conditions, String exceptionName, String content) {
        List<Assertion> assertions = new ArrayList<>();
        for (String condition : conditions) {
            assertions.add(new Assertion(condition, exceptionName, content));
        }
        return assertions;
    }

    public static Assertion generateAssertion(String condition, String exceptionName, String content) {
        return new Assertion(condition, exceptionName, content);
    }

    private static class Assertion {
        private final String description;
        private final String name;
        private final String assertion;

        public Assertion(String description, String name, String assertion) {
            this.description = description;
            this.name = name;
            this.assertion = assertion;
        }

        @Override
        public String toString() {
            return "{\"description\":\"" + description + "\",\"assertion\":\"" + assertion + "\",\"name\":\"" + name + "\"}";
        }
    }
}
