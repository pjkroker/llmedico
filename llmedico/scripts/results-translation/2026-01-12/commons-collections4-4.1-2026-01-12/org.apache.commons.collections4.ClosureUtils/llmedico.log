                    // Add the assertion to the list
                    assertions.add(assertion);
                }
            }
        }

        return assertions;
    }

    private static String getReceiverObjectID(String condition) {
        if (condition.contains("<code>null</code>")) {
            return "receiverObjectID";
        } else {
            return "receiverObjectID.containsVertex(args[0])";
        }
