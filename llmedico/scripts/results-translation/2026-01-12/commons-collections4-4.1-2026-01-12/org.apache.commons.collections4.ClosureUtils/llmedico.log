                    assertion.put("assertion", createAssertion(condition, receiverObjectID));
                    assertion.put("name", exceptionType);
                    assertion.put("content", getContent(condition));

                    // Add the assertion to the list
                    assertions.add(assertion);
                } else {
                    // Extract the parameter names from the condition
                    String[] params = condition.split(",");
                    List<String> paramNames = new ArrayList<>();
                    for (String param : params) {
