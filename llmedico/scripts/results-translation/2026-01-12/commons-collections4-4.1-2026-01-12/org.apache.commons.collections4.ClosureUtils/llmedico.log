                    assertion.put("assertion", createAssertion(condition, receiverObjectID));
                    assertion.put("name", exceptionType);
                    assertion.put("content", getContent(condition));

                    // Add the assertion to the list
                    assertions.add(assertion);
                } else {
                    // Extract the parameter names from the condition
                    String[] params = condition.split(",");
                    List<String> paramNames = new ArrayList<>();
                    for (String param : params) {
                        paramNames.add(param.trim());
                    }

                    // Create an assertion for the exception type and condition
                    Map<String, Object> assertion = new HashMap<>();
                    assertion.put("description", condition);
                    assertion.put("assertion", createAssertion(condition, paramNames));
                    assertion.put("name", exceptionType);
                    assertion.put("content", getContent(condition));

                    // Add the assertion to the list
                    assertions.add(assertion);
                }
            }
        }

        return assertions;
    }

    private static String getReceiverObjectID(String condition) {
        if (condition.contains("<code>null</code>")) {
            return "receiverObjectID";
        } else {
            return "receiverObjectID.containsVertex(args[0])";
        }
    }

    private static String createAssertion(String condition, List<String> paramNames) {
        StringBuilder assertion = new StringBuilder();
        for (String paramName : paramNames) {
            assertion.append(paramName).append("==null");
        }
        if (!paramNames.isEmpty()) {
            assertion.insert(0, "assert ");
        }
        return assertion.toString();
    }

    private static String getContent(String condition) {
        if (condition.contains("<code>null</code>")) {
            return "<code>null</code>";
        } else {
            return "";
        }
    }
}
