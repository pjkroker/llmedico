    private static List<Map<String, Object>> generateAssertions(String javadoc) {
        String[] parts = javadoc.split("\n");
        List<Map<String, Object>> assertions = new ArrayList<>();

        for (String part : parts) {
            if (!part.isEmpty()) {
                String exceptionType = part.trim().split("<")[0].trim();
                String condition = part.substring(part.indexOf(">") + 1).trim();

                // Check if the condition mentions a map or a null reference
