public class Main {
    public static List<String> generateAssertions(String javadoc, String method, List<String> parameters, String returnType) {
        // Split the Javadoc into lines
        String[] lines = javadoc.split("\n");

        // Initialize an empty list to store the assertions
        List<String> assertions = new ArrayList<>();

        // Iterate over each line in the Javadoc
        for (String line : lines) {
            // Check if the line starts with "@param"
            if (line.startsWith("@param")) {
                // Extract the parameter name and content
                String[] parts = line.split(" ");
                String paramName = parts[parts.length - 1].split(";")[0];
                String paramContent = line.replace(line, "");

                // Remove any HTML tags from the parameter content
                paramContent = paramContent.replaceAll("&lt;", "<").replaceAll("&gt;", ">");

                // Add an assertion for the parameter to the list
                assertions.add(generateAssertion(paramName, paramContent));
            }
        }

        // Return the list of assertions
        return assertions;
    }

    public static String generateAssertion(String paramName, String paramContent) {
        // Create a JSON object for the assertion
        StringBuilder json = new StringBuilder("{\"description\":\"");
        json.append(paramContent);
        json.append("\",\"assertion\":\"assert ").append(paramName).append(" == null || ").append(paramName).append(".getClass().equals(\"").append(returnType).append("\");\"}");
        return json.toString();
    }

