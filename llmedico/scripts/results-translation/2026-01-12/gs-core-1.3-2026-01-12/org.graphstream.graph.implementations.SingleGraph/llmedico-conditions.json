    "conditions": {
      "PARAM": [
        {
          "description": "id must be a non-empty string",
          "assertion": "assert receiverObjectID.id != null && !receiverObjectID.id.isEmpty() && receiverObjectID.id.matches(\"[a-zA-Z0-9_]+\");",
          "name": "id",
          "content": "Unique identifier of the graph."
        },
        {
          "description": "strictChecking must be a boolean value",
          "assertion": "assert receiverObjectID.strictChecking == true || receiverObjectID.strictChecking == false;",
          "name": "strictChecking",
          "content": "If true any non-fatal error throws an exception."
        },
        {
          "description": "autoCreate must be a boolean value",
          "assertion": "assert receiverObjectID.autoCreate == true || receiverObjectID.autoCreate == false;",
          "name": "autoCreate",
          "content": "If true (and strict checking is false), nodes are automatically created when referenced when creating a edge, even if not yet inserted in the graph."
        },
        {
          "description": "initialNodeCapacity must be a non-negative integer",
          "assertion": "assert receiverObjectID.initialNodeCapacity >= 0;",
          "name": "initialNodeCapacity",
          "content": "Initial capacity of the node storage data structures. Use this if you know the approximate maximum number of nodes of the graph."
        },
        {
          "description": "initialEdgeCapacity must be a non-negative integer",
          "assertion": "assert receiverObjectID.initialEdgeCapacity >= 0;",
          "name": "initialEdgeCapacity",
          "content": "Initial capacity of the edge storage data structures. Use this if you know the approximate maximum number of edges of the graph."
        }
      ]
