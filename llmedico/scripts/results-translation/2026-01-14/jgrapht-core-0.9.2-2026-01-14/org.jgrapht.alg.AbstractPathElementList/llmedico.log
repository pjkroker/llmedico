import json
from javadoc_parser import parse

def generate_preconditions(javadoc):
    # Parse the Javadoc
    parsed_javadoc = parse(javadoc)

    conditions = []

    for tag in parsed_javadoc['tags']:
        if tag['type'] == 'param':
            param_type = {
                "qualified_name": tag['value']['type']['qualified_name'],
                "simple_name": tag['value']['type']['simple_name'],
                "is_array": False,
                "array_dimensions": 0
            }

            param_content = json.dumps({
                "content": tag['description']
            })

            assertion = f"assert args[{tag['index']}] {param_content}"
            
            if tag.get('documentation') is not None:
                documentation = tag['documentation']['text']

                # Check for nullability
                if 'null' in documentation.lower():
                    nullability = 'assert receiverObjectID.get(0) != null && receiverObjectID.get(1) != null;'
                else:
                    nullability = ''

                description = f"{tag['description']} {nullability}"
            else:
                description = tag['description']

            conditions.append({
                "description": description,
                "assertion": assertion,
                "name": tag['value']['name'],
                "content": param_content
            })

    return conditions

javadoc = """
/**
 * Creates paths obtained by concatenating the specified edge to the
 * specified paths.
 *
 * @param maxSize maximum number of paths the list is able to store.
 * @param elementList paths, list of <code>AbstractPathElement</code>.
 * @param edge edge reaching the end vertex of the created paths.
 *
 * @throws NullPointerException if the specified prevPathElementList or edge
 * is <code>null</code>.
 * @throws IllegalArgumentException if <code>maxSize</code> is negative or
 * 0.
 */
"""
conditions = generate_preconditions(javadoc)
assert len(conditions) == 3, f"Expected exactly 3 conditions, but only got {len(conditions)}"

print(json.dumps(conditions, indent=4))
