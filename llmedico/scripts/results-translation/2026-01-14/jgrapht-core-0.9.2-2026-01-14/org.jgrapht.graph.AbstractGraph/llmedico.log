import re


def generate_java_assertions(doc, method_name, parameters, return_type):
    java_assertions = []

    for parameter in parameters:
        param_doc = None
        param_index = 0
        for line in doc.split("\n"):
            if " @param" in line:
                param_doc = line
                break

        if param_doc is None:
            continue

        match = re.search(r'@param (\w+):\s*(.*)', param_doc)
        if match is not None:
            param_name, param_content = match.groups()
        else:
            continue

        param_type_match = re.search(
            r'\[.*?(\w+)\]', parameter["type"]["qualified_name"])
        if param_type_match is not None:
            param_type = param_type_match.group(1)
        elif 'int' in parameter['type']['name']:
            param_type = "int"
        elif 'boolean' in parameter['type']['name']:
            param_type = "boolean"
        else:
            continue

        # Check if the parameter is being used as a method call
        assert_method_call = False
        for line in doc.split("\n"):
            match = re.search(r'\b' + parameter["name"] + r'\(', line)
            if match is not None:
                assert_method_call = True
                break

        # Generate the assertion
        if param_type == "int":
            assertion = f"assert args[{param_index}] instanceof {param_type};"
        elif param_type == "boolean":
            assertion = f"assert args[{param_index}] instanceof {param_type};"
        else:
            assertion = f"assert args[{param_index}] instanceof java.util.Collection;"

        if assert_method_call:
            # If the parameter is being used as a method call, it's likely that we're passing an object
            param_content = re.sub(r'\b' + parameter["name"] + r'\(', '', param_content)
            param_content += ", java.lang.Object"
            assertion = f"assert args[{param_index}] instanceof {param_type} && args[{param_index}].getClass().getName() == '{parameter['type']['name']}'"

        java_assertions.append(
            {
                "description": parameter["content"],
                "assertion": assertion,
                "name": parameter["name"]
            }
        )

    return java_assertions


