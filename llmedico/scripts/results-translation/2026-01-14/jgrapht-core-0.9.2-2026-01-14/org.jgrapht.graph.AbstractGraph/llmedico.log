Here's an updated code snippet that uses recursion to handle nested objects and arrays of objects:
```javascript
function extractValues(obj) {
  const result = {};
  Object.keys(obj).forEach(key => {
    const value = obj[key];
    if (typeof value === 'object' && !Array.isArray(value)) {
      // recursive call for nested objects
      result[key] = extractValues(value);
    } else if (Array.isArray(value)) {
      // array of objects, handle each object separately
      value.forEach(item => {
        Object.keys(item).forEach(key => {
          result[`${key}_${key}`] = item[key];
        });
      });
    } else {
      // simple key-value pair
      result[key] = value;
    }
  });
  return result;
}

const originalJson = {
  "key1": "value1",
  "key2": "value2",
  "key3": {
    "subKey1": "subValue1",
    "subKey2": "subValue2"
  },
  "key4": [
    { "key4_1": "value4_1" },
    { "key4_2": "value4_2" }
  ]
};

const resultJson = extractValues(originalJson);
