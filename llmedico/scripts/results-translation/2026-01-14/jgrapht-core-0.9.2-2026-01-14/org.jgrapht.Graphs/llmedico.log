    private static String getValidAssertion(String parameterName, Class<?> clazz) {
        // Get the method
        Method method = null;
        for (String m : new String[] {"addGraph", "addEdge", "addGraphReversed"}) {
            if (m.startsWith(parameterName)) {
                method = Class.forName(m.split("(.*)")[0]).getMethod(parameterName);
                break;
            }
        }

        // Get the parameters
        Parameter[] params = method.getParameters();

        // Create the assertion
        StringBuilder assertion = new StringBuilder();
        for (Parameter param : params) {
            if (!param.getName().equals("__unnamed") && !param.getName().equals("this")) {
                if (assertion.length() > 0) {
                    assertion.append(",");
                }
                assertion.append(param.getType()).append(" ").append(param.getName());
            }
        }

        return assertion.toString();
    }
}
