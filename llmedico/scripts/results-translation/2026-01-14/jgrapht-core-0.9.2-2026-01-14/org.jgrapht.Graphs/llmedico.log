        # Extract parameter name and content from the Javadoc
        match = re.search(r'@param\s+(.*)\s+must\s+be\s+([^\n]+)', javadoc, re.DOTALL)
        if match:
            name = match.group(1).strip()
            content = match.group(2).strip().replace('&lt;', '&lt;').replace('&gt;', '&gt;')
            
            # Generate Java assertion
            for method in ["addEdge", "addGraphReversed", "addAllEdges"]:
                if method in javadoc:
                    parameter_type = re.search(r'None', javadoc).group()
                else:
                    parameter_type = re.search(r'([a-zA-Z_][a-zA-Z0-9_]*)', javadoc).group()
                
                # Check for null content
                if 'null' in content:
                    assertion = f"assert ({name} != null)"
                else:
                    # Check for List, Map or Collection
                    if 'java.util.List&lt;' in content:
                        list_content = re.sub(r'(&lt;|\s+)', '', content)
                        assertion = f"assert (({parameter_type} instanceof java.util.List&lt;>) && !({parameter_type}.isEmpty() && ({parameter_type}.get(0) == null)))"
                    elif 'java.util.Map&lt;' in content:
