                "{\"type\": {\"qualified_name\": 'java.lang.Object', \"simple_name\": 'Object', \"is_array\": False, \"array_dimensions\": 0}, \"name\": 'vertex'}"
        };
        String returnType = "{\"qualified_name\": None, \"simple_name\": 'List', \"is_array\": False, \"array_dimensions\": 0}";

        List<JsonElement> jsonElements = generateAssertions(javadoc, parameters, returnType);

        for (JsonElement element : jsonElements) {
            System.out.println(element);
        }
    }

    public static List<JsonElement> generateAssertions(String javadoc, String[] parameters, String returnType) {
        // Parse the Javadoc to get the parameter names
        String[] paramNames = getParameterNames(javadoc);

        // Generate assertions for each parameter
        List<JsonElement> jsonElements = new ArrayList<>();
        for (String param : parameters) {
            jsonElements.add(generateAssertion(param, paramNames));
        }

        return jsonElements;
    }

    private static String generateAssertion(String param, String[] paramNames) {
        int index = ArrayUtils.indexOf(paramNames, param);
        if (index == -1) {
