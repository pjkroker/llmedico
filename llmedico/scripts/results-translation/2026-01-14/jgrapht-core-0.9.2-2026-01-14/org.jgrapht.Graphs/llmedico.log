    public static List<Assertion> generateAssertions(String javadoc, String[] methods) {
        // Split the Javadoc into lines
        String[] lines = javadoc.split("\n");

        // Initialize a list to store the assertions
        List<Assertion> assertions = new ArrayList<>();

        // Iterate over each line in the Javadoc
        for (String line : lines) {
            if (line.startsWith("@param")) {
                continue;
            }

            if (line.contains("throws")) {
                continue;
            }

            if (line.isEmpty()) {
                continue;
            }

            String[] parts = line.split("\\s+");

            // Check if the line contains a parameter
            for (String part : parts) {
                if (part.startsWith("throws ")) {
                    throw new RuntimeException("Throwing a RuntimeException in Javadoc is not allowed.");
                }
            }

            Assertion assertion = new Assertion();

            // Extract the parameter name and description
            int index = 0;
            while (index < parts.length && !parts[index].startsWith("@")) {
                index++;
            }

            if (index == parts.length) {
                continue;
            }

            String paramName = parts[index];

            for (int i = index + 1; i < parts.length; i++) {
                if (parts[i].equals("None")) {
                    // The parameter is of type None
                    assertion.setType("None");
                } else if (parts[i].contains("(")) {
                    // The parameter is of a complex type
                    int openParenIndex = parts[i].indexOf('(');
                    int closeParenIndex = parts[i].indexOf(')');
                    String paramType = parts[i].substring(openParenIndex + 1, closeParenIndex);

                    // Check if the parameter type matches any method in the methods array
                    for (String method : methods) {
                        if (paramType.equals(method)) {
