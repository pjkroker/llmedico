        // It does not handle method parameters, generic types, etc.
        String[] lines = javadoc.split("\n");
        List<String> paramNames = new ArrayList<>();
        for (String line : lines) {
            if (line.contains("@param")) {
                String[] params = line.split("@param\\s+");
                paramNames.addAll(Arrays.asList(params[1].split(",")));
            }
        }
        return paramNames.toArray(new String[0]);
    }

    private static class JsonElement {
        public String description;
        public String assertion;
        public String name;
        public String content;

        @Override
        public String toString() {
            return "{\"description\":\"" + description + "\",\"assertion\":\"" + assertion + "\",\"name\":\"" + name + "\",\"content\":\"" + content + "\"}";
        }
