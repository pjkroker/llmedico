            "description": f"param1 must be an array of {array_dimension_str}, possibly empty",
            "assertion": f"assert param1 instanceof java.lang.Object[] && ((java.lang.Object[])param1).length > 0 && ((java.lang.Object[])param1)[0] instanceof {array_dimension_str};",
            "name": name,
            "content": content
        })

    return json.dumps(assertions)

