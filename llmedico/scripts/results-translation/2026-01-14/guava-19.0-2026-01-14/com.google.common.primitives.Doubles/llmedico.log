import java.util.*;
import org.json.*;

public class PreconditionAssertions {
    public static void main(String[] args) {
        String javadoc = "/**
 * Returns an array containing each value of {@code collection}, converted to
 * a {@code double} value in the manner of {@link Number#doubleValue}.
 *
 * <p>Elements are copied from the argument collection as if by {@code
 * collection.toArray()}.  Calling this method is as thread-safe as calling
 * that method.
 *
 * @param collection a collection of {@code Number} instances
 * @return an array containing the same values as {@code collection}, in the
 *     same order, converted to primitives
 * @throws NullPointerException if {@code collection} or any of its elements
 *     is null
 * @since 1.0 (parameter was {@code Collection<Double>} before 12.0)
 */
";

        String[] parameters = "[{'type': {'qualified_name': None, 'simple_name': 'Collection', 'is_array': False, 'array_dimensions': 0}, 'name': 'collection'}]";
        String returnType = "{\"qualified_name\": \"double\", \"simple_name\": \"double\", \"is_array\": True, \"array_dimensions\": 1}";

        List<JSONElement> preconditionAssertions = generatePreconditionAssertions(javadoc, parameters, returnType);

        System.out.println(JSON.stringify(preconditionAssertions));
    }

    public static List<JSONElement> generatePreconditionAssertions(String javadoc, String[] parameters, String returnType) {
        Map<String, JSONElement> preconditionAssertions = new HashMap<>();

        // Extract the parameter descriptions from the @param tags
        for (String parameter : parameters[0].split("),")) {
            String description = extractDescription(parameter);
            String assertion = generateAssertion(javadoc, description);

            if (assertion != null) {
                preconditionAssertions.put(extractNameFromParameter(parameter), JSONElement.fromObject(new JSONObject().put("description", description).put("assertion", assertion).put("name", extractNameFromParameter(parameter)).put("content", description)));
            }
        }

        return new ArrayList<>(preconditionAssertions.values());
    }

    public static String extractDescription(String parameter) {
        // Find the @param tag in the javadoc
        int startIndex = javadoc.indexOf("@param " + parameter);
        if (startIndex == -1) {
            return "";
        }
        int endIndex = javadoc.indexOf("\n", startIndex);
        if (endIndex == -1) {
            endIndex = javadoc.length();
        }

        // Extract the description
        String description = javadoc.substring(startIndex + 7, endIndex).trim();

        return description;
    }

    public static String generateAssertion(String javadoc, String description) {
        if (description.isEmpty()) {
            return null;
        }

        // Check if the collection must be a Collection
        String assertion1 = "assert receiverObjectID instanceof java.util.Collection;";
        String content1 = "<p>Elements are copied from the argument collection as if by <code>collection.toArray</code>.</p>";

        // Check if the collection must not be null
        String assertion2 = "assert receiverObjectID != null;";
        String content2 = "<p>Calling this method is as thread-safe as calling that method.</p>";

        return description.equals("collection must be a Collection") ? assertion1 + "\n" + content1 : assertion2;
    }

    public static String extractNameFromParameter(String parameter) {
        // Remove the name part from the @param tag
        int startIndex = parameter.indexOf("@param ");
        if (startIndex != 0) {
            return parameter.substring(startIndex + 7).trim();
        } else {
            return "";
        }
    }
}
```

