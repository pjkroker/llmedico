{
  "generate_precondition_assertions": function(javadoc, method_name, parameters, return_type) {
    // Parse parameter tags from javadoc string
    var param_tags = [];
    for (var line in javadoc.split('\n')) {
      if ('@param' in line) {
        var tag = line.trim();
        var end_index = tag.lastIndexOf(') must be');
        var content_start_index = tag.indexOf('<p>') + len('<p>');
        var param_tag = {
          'description': tag.replace('@param', '').trim(),
          'assertion': tag.split(' ')[tag.split(' ').length - 1].replace(',', ''),
          'name': tag.split(' ')[tag.split(' ').length - 1],
          'content': tag.substring(content_start_index, end_index)
        };
        param_tags.push(param_tag);
      }
    }

    // Generate the Java pre-condition assertion statements
    var precondition_assertions = [];
    for (var i in param_tags) {
      if (Array.isArray(parameters)) {
        var parameter_type = parameters[param_tags[i]['name']]['type'];
      } else {
        var parameter_type = return_type['qualified_name'].split('[]')[0];
      }
      var assert_statement = 'assert ' + parameter_type + ' == ' + param_tags[i]['content'] + ';';
      precondition_assertions.push(param_tags[i]);
    }

    // Generate assertion for method calls
    var method_call_assertions = [];
    for (var name in parameters) {
      var parameter_names = [parameters[name].split('(')[2].split(')')[0]];
      var assert_statement = 'assert ' + parameter_names[0];
      method_call_assertions.push({
        'description': method_name + ' assertion',
        'assertion': assert_statement,
        'name': method_name,
        'content': method_name + ' must be called with the correct parameters.'
