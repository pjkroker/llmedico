    params = [{'type': {'qualified_name': 'java.lang.Object', 'simple_name': 'Object', 'is_array': False}, 'name': param.get('name')} for param in javadoc.get('parameters', [])]
    return_type = javadoc.get('return_type')

    unsupported_operation_assertion = {
        "description": "Unsupported operation.",
        "assertion": "assert True;",
        "name": "UnsupportedOperationException",
        "content": "Unsupported operation."
    }

    always_throws_assertion = {
        "description": "always.",
        "assertion": "assert true;",
        "name": "UnsupportedOperationException",
        "content": "Always throws UnsupportedOperationException"
    }

    unsupported_operation_throws_assertions = []

    for param in params:
        if 'name' not in param or param['name'] is None:
            continue
        unsupported_operation_throws_assertions.append({
            "description": f"If {param['name']} == null.",
            "assertion": f"assert args[0] == null;",
            "name": "NullPointerException",
            "content": f"If {param['name']} is <code>None</code>"
        })

    unsupported_operation_throws_assertions.append(always_throws_assertion)

    return unsupported_operation_throws_assertions + [unsupported_operation_assertion]

