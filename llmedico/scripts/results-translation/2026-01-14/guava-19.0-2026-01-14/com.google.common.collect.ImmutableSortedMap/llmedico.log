import json

def generate_assertion(description):
    if 'if' in description:
        condition = description.split('if')[1].strip()
        return f"assert {condition};"
    elif 'if not' in description:
        condition = description.split('if not')[1].strip()
        return f"assert not {condition};"
    else:
        raise ValueError("Invalid assertion format")

def generate_throws_assertion(method_name, parameters, return_type):
    throws_conditions = []
    # Check if the method has any @throws tags
    for tag in ['@throws', '@param', '@return']:
        if tag in method_name:
            continue

    # Get the first @throws tag
    throws_tag_start = 0
    while throws_tag_start < len(method_name) and method_name[throws_tag_start] != '<':
        throws_tag_start += 1

    # Extract the @throws condition(s)
    if throws_tag_start == len(method_name):
        return []
    throws_description_end = throws_tag_start + 1
    while throws_description_end < len(method_name) and method_name[throws_description_end] != '>':
        throws_description_end += 1

    for i in range(throws_tag_start, throws_description_end):
        if method_name[i] == '<' and method_name[i+1] == ' ':
            condition_start = i + 2
            condition_end = throws_description_end - 1
            while method_name[condition_end] != '>':
                condition_end -= 1

            parameter_names = []
            for j in range(condition_start, condition_end):
                if method_name[j] == ',':
                    continue
                else:
                    parameter_names.append(method_name[j+1])

            throws_conditions.append(f"({parameter_names})")

    # Generate the @throws assertion(s)
    assertions = []
    for i, condition in enumerate(throws_conditions):
        if i > 0:
            assertions.append("&&")
        assertions.append(generate_assertion(condition))

    return assertions

def generate_java_assertions(method_name, parameters, return_type):
    throws_assertions = generate_throws_assertion(method_name, parameters, return_type)

    # Get the first @throws tag
    throws_tag_start = 0
    while throws_tag_start < len(method_name) and method_name[throws_tag_start] != '<':
        throws_tag_start += 1

    # Extract the return type(s)
    if 'None' in return_type:
        return_type = None
    else:
        return_type = return_type.replace("{'qualified_name': '" + parameters[0]['name'] + "',", "").replace("', 'is_array': False,")

    # Generate the main assertion
    assertions = []
    if throws_tag_start == 0 or method_name.count('None') > 1:
        for i, parameter in enumerate(parameters):
            if i > 0:
                assertions.append("&&")
            assertions.append(f"assert {parameter['name']} is not None;")
    else:
        for i, condition in enumerate(throws_conditions):
            if i > 0:
                assertions.append("&&")
            assertions.append(generate_assertion(condition))

    return json.dumps({'method_name': method_name, 'parameters': parameters, 'return_type': return_type, 'assertions': assertions})

# Example usage
