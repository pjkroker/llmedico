import java.lang.reflect.ParameterizedType
import java.util.ArrayList
import java.util.List

class AssertionGenerator {
  fun generateAssertions(javadoc: String, method: String, parameters: List<Parameter>, returnType: ParameterizedType) {
    val assertions = ArrayList<Assertion>()

    for (param in parameters) {
      if (!param.name.equals("return")) {
        val content = paramDocToContent(param.documentation)
        var assertion = "assert ${content}.name == '${param.name}'"
        if (param.isArray) {
          assertion += ", ${content}.type.qualified_name == 'java.lang.Object[]'"
        }
        assertions.add(Assertion(content = content, assertion = assertion))
      }
    }

    for (field in returnType.elementType.genericSuperclass?.actualTypeArguments?.toList()) {
      if (!field.name.equals("return")) {
        val content = fieldDocToContent(field.documentation)
        var assertion = "assert ${content}.name == '${field.name}'"
        if (field.typeParameters[0].typeParameters.size > 0) {
          assertion += ", ${content}.typeParameters[0].typeParameters[0].typeParameters.size > 0"
        }
        assertions.add(Assertion(content = content, assertion = assertion))
      }
    }

    println(json.dumps(asString(assemblies = assertions)))
  }

  private fun ParameterDocToContent(paramDoc: String): Content {
    return if (paramDoc.contains("<code>") && paramDoc.contains("</code>")) {
      Content(
        name = paramDoc.split("<code>")[1].split("</code>")[0],
        content = paramDoc
      )
    } else {
      Content(name = paramDoc, content = "")
    }
  }

  private fun ParameterDocToContent(paramDoc: java.util.Map<String, String>): Content {
    return if (paramDoc["name"] != null && paramDoc["content"] != null) {
      Content(
        name = paramDoc["name"],
        content = paramDoc["content"]
      )
    } else {
      Content(name = "", content = "")
    }
  }

  private fun ParameterDocumentationToContent(param: Parameter): String {
    return if (param.documentation.contains("<code>") && param.documentation.contains("</code>")) {
      "${param.name} must be a ${param.type}"
    } else {
      ""
    }
  }

  class Assertion(val name: String, val assertion: String) {
    override fun toString(): String = "$name : $assertion"
  }

  private fun parameterToContent(param: Parameter): Content {
    return if (param.documentation.contains("<code>") && param.documentation.contains("</code>")) {
      Content(
        name = param.name,
        content = "${param.name} must be a ${param.type}"
      )
    } else {
      Content(name = "", content = "")
    }
  }

  private fun parameterizedToContent(param: ParameterizedType): Content {
    return if (param.documentation.contains("<code>") && param.documentation.contains("</code>")) {
      Content(
        name = "an array of ${param.returnType.typeParameters[0].typeParameters[0].typeParameterBounds[0]}",
        content = "${param.name} must be an array of ${param.returnType.typeParameters[0].typeParameters[0].typeParameterBounds[0]}"
      )
    } else {
      Content(name = "", content = "")
    }
  }

  private fun listToContent(param: List<Parameter>): String {
    return if (param.documentation.contains("<code>") && param.documentation.contains("</code>")) {
      "${param.name} must be a ${param.type}"
    } else {
      ""
    }
  }

  private val typeParameters = """
typeParameters = [
${(0..parameterTypes.size - 1).joinToString { "${it}: ${parameterTypes[it]}" }}
]
"""

  private fun listToContent(param: List<ParameterizedType>): String {
    return if (param.documentation.contains("<code>") && param.documentation.contains("</code>")) {
      "an array of ${typeParameters}"
    } else {
      ""
    }
  }

  private fun parameterTypeToString(param: Parameter): String {
    return "${param.name} must be a ${param.type}"
  }

  private fun fieldToContent(field: ParameterizedType): Content {
    return if (field.documentation.contains("<code>") && field.documentation.contains("</code>")) {
      Content(
        name = "a ${typeParameters}",
        content = "an array of ${typeParameters}"
      )
    } else {
      Content(name = "", content = "")
    }
  }

  private fun listToString(param: List<ParameterizedType>): String {
    return "${(0..param.size - 1).joinToString { "it" }}"
  }

  private fun asString(assemblies: List<Assertion>) : String {
    return assemblies.joinToString("\n") { "\t$it"}
  }
}

data class Content(val name: String, val content: String)
data class ParameterDoc(val documentation: String)

class Parameter(
  val name: String,
  val type: Type,
  var isArray: Boolean = false
)

class Field(
  val typeParameters: List<ParameterizedType>
)
