import java.util.*;

public class Main {
    public static void main(String[] args) {
        String javadoc = "/**
 * Returns the first of two given parameters that is not {@code null}, if either is, or otherwise
 * throws a {@link NullPointerException}.
 *
 * <p><b>Note:</b> if {@code first} is represented as an {@link Optional}, this can be
 * accomplished with {@link Optional#or(Object) first.or(second)}. That approach also allows for
 * lazy evaluation of the fallback instance, using {@link Optional#or(Supplier)
 * first.or(supplier)}.
 *
 * @return {@code first} if it is non-null; otherwise {@code second} if it is non-null
 * @throws NullPointerException if both {@code first} and {@code second} are null
 * @since 18.0 (since 3.0 as {@code Objects.firstNonNull()}).
 */
";

        Map<String, Assertion> assertions = generateAssertions(javadoc);

        for (Assertion assertion : assertions.values()) {
            System.out.println(asString(assertion));
        }
    }

    private static Map<String, Assertion> generateAssertions(String javadoc) {
        // Initialize the map to store the generated assertions
        Map<String, Assertion> assertions = new HashMap<>();

        // Parse the Javadoc string to extract the @throws tags
        String[] throwsTags = javadoc.split(" *@throws");
        for (String tag : throwsTags) {
            if (!tag.isEmpty()) {
                String[] lines = tag.split("\n");
                for (int i = 1; i < lines.length; i++) {
                    String line = lines[i].trim();
                    if (line.startsWith("@throws")) {
                        // Extract the exception name and condition
                        int index = line.indexOf(" ");
                        String exceptionName = line.substring(index + 1).split("<")[0];
                        String condition = line.substring(12, line.length() - 2);

                        // Generate the assertion statement based on the condition
                        if (condition.contains("if")) {
                            // Condition is a single "if" statement
                            int ifIndex = condition.indexOf("if");
                            String condition1 = condition.substring(0, ifIndex);
                            String condition2 = condition.substring(ifIndex + 3);
                            assertions.put(exceptionName, new Assertion(condition1, exceptionName, condition2));
                        } else {
                            // Condition is a logical "or" statement
                            int orIndex = condition.indexOf(" || ");
                            String condition1 = condition.substring(0, orIndex);
                            String condition2 = condition.substring(orIndex + 4);
                            assertions.put(exceptionName, new Assertion(condition1, exceptionName, condition2));
                        }
                    }
                }
            }
        }

        // Return the map of generated assertions
        return assertions;
    }

    private static String asString(Assertion assertion) {
        StringBuilder sb = new StringBuilder();
        sb.append("assert (").append(assertion.getCondition1()).append(" || ").append(assertion.getCondition2()).append(");\n");
        sb.append("// @throws " + assertion.getExceptionName());
        return sb.toString();
    }

    private static class Assertion {
        String condition1;
        String exceptionName;
        String condition2;

        public Assertion(String condition1, String exceptionName, String condition2) {
            this.condition1 = condition1;
            this.exceptionName = exceptionName;
            this.condition2 = condition2;
        }
    }
}
```

