```python
def parse_javadoc(javadoc, method_name):
  # Split Javadoc into sections
  sections = javadoc.split('\n\n')

  preconditions = []

  for section in sections:
    if 'Precondition' not in section:
      continue

    description = ''
    params = []
    return_type = None
    documentation_start = section.find('@param')
    if documentation_start != -1:
      # Extract parameters from @param tag
      documentation_end = section.find('\n', documentation_start)
      documentation = section[documentation_start:documentation_end].strip()
      param_docs = documentation.split('\n')

      for doc in param_docs:
        param_match = re.search(r'@param\s+(\w+)\s+([^;]+);?', doc, re.IGNORECASE)
        if param_match:
          param_name = param_match.group(1).strip()
          param_type_match = re.search(r'\(([^)]+)\)', param_match.group(2))
          param_type = param_type_match.group(1) if param_type_match else None
          params.append({'type': {'qualified_name': param_type, 'name': param_name, 'is_array': False}, 'name': param_name})
        elif '<' in doc:
          # Extract parameter from <...> tag
          param_start = doc.find('<')
          param_end = doc.find('>')
          param_content = doc[param_start+1:param_end].strip()
          params.append({'type': {'qualified_name': None, 'simple_name': None, 'is_array': False}, 'name': param_content})
        elif '&' in doc:
          # Extract parameter from &lt;...&gt; tag
          param_start = doc.find('&lt;')
          param_end = doc.find('&gt;')
          param_content = doc[param_start+4:param_end].strip()
          params.append({'type': {'qualified_name': None, 'simple_name': None, 'is_array': False}, 'name': param_content})
        elif '"' in doc:
          # Extract parameter from @param tag with quote
          param_start = doc.find('"')
          param_end = doc.find('"', param_start+1)
          param_content = doc[param_start:param_end].strip()
          params.append({'type': {'qualified_name': None, 'simple_name': None, 'is_array': False}, 'name': param_content})
        else:
          # Extract parameter from @param tag without any special characters
          param_start = 0
          while param_start < len(doc) and not doc[param_start].isspace():
            param_start += 1
          param_end = param_start
          while param_end < len(doc) and doc[param_end].isalnum() or doc[param_end] == '_':
            param_end += 1
          param_content = doc[param_start:param_end].strip()
          params.append({'type': {'qualified_name': None, 'simple_name': None, 'is_array': False}, 'name': param_content})

    return_type_match = re.search(r'(\w+)\s+([a-zA-Z]+);?', section)
    if return_type_match:
      return_type = return_type_match.group(2).strip()

  # Add precondition for method
  preconditions.append({
    'name': method_name,
    'type': {'qualified_name': None, 'simple_name': None, 'is_array': False},
    'content': '/' + javadoc.replace('\n\n', '\n')
  })

  return {
    'preconditions': [
      {'description': description, **param, 'name': param['name'], 'content': param['content']}
      for param in params
    ],
    'return_type': {'qualified_name': return_type, 'simple_name': None, 'is_array': False}
  }

# Usage:
javadoc = """Here is the corrected Java pre-condition assertion statement that represents the requirements described in the @param tag:
[
  {
    "keys": {
      "description": "assert (keys instanceof Iterable && ((Iterable) keys).iterator().hasNext())",
      "name": "keys",
