import re

class PreconditionGenerator:
    def __init__(self, javadoc):
        self.javadoc = javadoc
        self.methods = []
        self.parse_methods()

    def parse_methods(self):
        pattern = r'@([a-zA-Z]+)\s+(\w+)\s*\(.*?\)'
        for match in re.finditer(pattern, self.javadoc):
            method_name = match.group(2)
            parameters = self._parse_parameters(match.group(1))
            self.methods.append((method_name, parameters))

    def _parse_parameters(self, param_tag):
        if not param_tag:
            return []

        param_json = json.loads(param_tag)

        params = []
        for param in param_json['type']:
            if 'name' not in param:
                raise ValueError('Missing name field in parameter')
            params.append({'type': param, 'name': param['name']})

        return params

    def generate_assertions(self):
        assertions = []

        for method_name, parameters in self.methods:
            assertion_json = {
                'description': f'the {method_name} must be valid',
                'assertion': '',
                'name': method_name,
                'content': ''
            }

            for param in parameters:
                param_type = param['type']
                if param_type['qualified_name'] is None:
                    param_type = self._get_default_type(param_type)
                assertion_json['assertion'] += f' assert {self._get_name(param)} : {param["name"]} must be of type {self._get_qualified_name(param_type)};'
                assertion_json['content'] += f'{param["name"]} must be of type {self._get_qualified_name(param_type)}\n'

            assertions.append(assertion_json)

        return assertions

    def _get_default_type(self, param_type):
        if 'qualified_name' in param_type:
            return param_type
        elif 'simple_name' in param_type:
            return f'int{param_type["array_dimensions"]}'
        else:
            raise ValueError('Invalid parameter type')

    def _get_qualified_name(self, param_type):
        if 'qualified_name' in param_type:
            return param_type['qualified_name']
        elif 'simple_name' in param_type:
            return param_type['simple_name']

    def _get_name(self, param):
        if 'name' not in param:
            raise ValueError('Missing name field in parameter')
        return f'{param["name"]}'

