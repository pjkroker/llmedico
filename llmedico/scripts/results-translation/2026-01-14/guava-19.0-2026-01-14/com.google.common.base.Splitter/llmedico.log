            "tag": "param",
            "name": "separator",
            "content": "the literal, nonempty string to recognize as a separator",
            "assertion": "assert receiverObjectID.args[0].equals(\"\\u0009, \\u000A, \\u000D\\u000B\\u2028\\u2029\\u00B7\");",
            "description": "the literal, nonempty string to recognize as a separator"
