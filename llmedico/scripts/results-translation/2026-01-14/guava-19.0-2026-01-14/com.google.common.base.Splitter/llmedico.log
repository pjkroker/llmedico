    }

    public static String getThrowsTag(String javadoc) {
        // Find the @throws tag
        int startsWithThrows = 0;
        for (int i = 0; i < javadoc.length(); i++) {
            if (javadoc.startsWith("@throws", i)) {
                startsWithThrows = i;
                break;
            }
        }

        if (startsWithThrows == 0) return null;

        int endsAt = javadoc.indexOf("\n", startsWithThrows);
        if (endsAt == -1) endsAt = javadoc.length();

        return javadoc.substring(startsWithThrows, endsAt);
    }

    public static String generateCondition(List<String> conditions, Map<String, Object> argsMap) {
        for (String condition : conditions) {
            if (condition.contains("null")) {
                condition = condition.replace("null", "null");
            }
            if (condition.contains("{")) {
                condition = condition.replace("{}", "(" + argsMap.get(condition.split("\\{")[1]) + ")");
            } else {
                condition = condition + " && " + ((String) argsMap.get(condition)).equals("") ? true : false;
            }
        }

        return condition;
    }
}
