            return_type_info['simple_name'] = return_type_name
            return_type_info['is_array'] = False
            return_type = return_type_info

    # Extract method name from first line
    lines = javadoc.split('\n')
    for line in lines:
        if line.startswith('/*'):
            break
        if line.strip().endswith('@throws') or line.strip().endswith('Deprecated'):
            continue
        if line.startswith('*'):
