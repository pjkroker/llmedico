            doc = param['type']['documentation']
            start_index = 0
            while start_index < len(doc):
                end_index = doc.find('>', start_index)
                if end_index == -1:
                    break
                content = doc[start_index + 1:end_index]
                description = ''
                if 'description' in param['type']:
                    description = param['type']['description']
                content = content.strip().replace('&lt;', '<').replace('&gt;', '>')
                if description and not content:
                    continue
                output.append({
                    "description": description,
                    "assertion": f"assert {content} != null;",
                    "name": param['name'],
                    "content": content
                })
                start_index = end_index + 1
    return json.dumps(output)

