 *
 * @param position position of the element to return
 * @param defaultValue the default value to return if the iterator is empty
 *     or if {@code position} is greater than the number of elements
 *     remaining in {@code iterator}
 * @return the element at the specified position in {@code iterator} or
 *     {@code defaultValue} if {@code iterator} produces fewer than
 *     {@code position + 1} elements.
 * @throws IndexOutOfBoundsException if {@code position} is negative
 * @since 4.0
 */
";

        String[] lines = javadoc.split("\n");
        String[] methodLines = lines[lines.length - 1].split("\\s+");
        String methodName = methodLines[methodLines.length - 1];
        JSONArray parameters = new JSONArray();
        String[] parameterLines = lines[2 * lines.length - 3].split(",");
        for (int i = 0; i < parameterLines.length; i++) {
            JSONObject param = new JSONObject();
            param.put("type", new JSONObject(lines[i * 2 + 1]).get("qualified_name"));
            param.put("name", lines[i * 2]);
            parameters.put(param);
        }

        String returnType = lines[lines.length - 3];
        JSONArray methods = new JSONArray();
        if (!methodLines[methodLines.length - 2].equals("None")) {
            methods.add(new JSONObject(lines[methodLines.length - 1]).get("name"));
        }
        
        System.out.println(generateAssertion(methodName, parameters.toString(), returnType, methods.toString()));
    }

    private static String generateAssertion(String methodName, String parameters, String returnType, String methods) {
        StringBuilder assertion = new StringBuilder("@Test\npublic void test" + methodName + "() {\n" +
                "    Iterator iterator = new ArrayList<>().iterator();\n" +
                "    Object position = 0;\n" +
                "    Object defaultValue = null;\n" +
                "    Object element = null;\n" +
                "    try {\n" +
                "        // Advance the iterator 'position + 1' times\n" +
                "        for (int i = 0; i <= position; i++) {\n" +
                "            if (!iterator.hasNext()) {\n" +
                "                element = defaultValue;\n" +
                "                break;\n" +
                "            }\n" +
                "            iterator.next();\n" +
                "        }\n" +
                "    } catch (Exception e) {\n" +
                "        // Handle exception\n" +
                "    }\n" +
                "    Assert.assertEquals(element, null);\n" +
                "}\n");

        if (!methods.toString().equals("None")) {
            assertion.insert(0, "@Test\npublic void test" + methodName + "() {\n" +
                    "    Iterator iterator = new ArrayList<>().iterator();\n" +
                    "    Object position = 0;\n" +
                    "    Object defaultValue = null;\n" +
                    "    Object element = null;\n" +
                    "    try {\n" +
