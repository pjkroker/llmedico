    private static String generateAssertions(String javadoc, String[] parameters, String[] returnTypes, String[] instanceMethods) {
        StringBuilder assertions = new StringBuilder();

        // Check if size is nonpositive
        for (String parameter : parameters) {
            if (!parameter.contains("int")) continue;
            String[] parts = parameter.split(":");
            String name = parts[1];
            if (name.equals("size")) {
