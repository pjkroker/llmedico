import org.json.JSONObject;

public class Main {
    public static void main(String[] args) {
        String javadoc = "/* Returns the least value present in {code}array}. /* @param array a <i>nonempty</i> array of {code}short{code} values */";
        Object[] params = new Object[]{new JSONObject("[{\"type\":{\"qualified_name\":\"short\",\"simple_name\":\"short\",\"is_array\":false,\"array_dimensions\":0},\"name\":\"array}\"}")};
        String returnType = "{\"qualified_name\":\"short\",\"simple_name\":\"short\",\"is_array\":false,\"array_dimensions\":0}";

        System.out.println(generateAssertions(javadoc, params, returnType));
    }

    public static String generateAssertions(String javadoc, Object[] params, String returnType) {
        StringBuilder jsonAssertions = new StringBuilder();
        JSONObject paramsJson = (JSONObject) params[0];
        String[] paramNames = paramsJson.getJSONArray("type").getJSONArray(0).getString("name").split(",");

        for (String paramName : paramNames) {
            String content = "the value present in {code}array{code} that is less than or equal to {code}every{code} other value in the array";

            if (paramsJson.getJSONArray("type").getJSONArray(0).getString("qualified_name").equals("short")) {
                jsonAssertions.append("{");
                jsonAssertions.append("\"description\":\"" + content.replace("{code}", "<i>").replace("{code}array", "<code>array{code}`).replace("{code}every", "</code>{code} other value in the array") + "{code}\",");
                jsonAssertions.append("\"assertion\":\"assert " + paramName + ".checkedCast(0) >= 0;\",");
                jsonAssertions.append("\"name\":\"" + paramName.replace(",", ", ").trim() + "\",");
                jsonAssertions.append("\"content\":\"" + content.replace("{code}", "<i>").replace("{code}array{code}", "<code>array{code")).append("}\",");
                jsonAssertions.append("}");
            }
        }

        return jsonAssertions.toString();
    }
}
```

