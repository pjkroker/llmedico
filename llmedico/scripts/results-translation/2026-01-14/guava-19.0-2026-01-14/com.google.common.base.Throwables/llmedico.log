from collections import namedtuple

Throwable = namedtuple('Throwable', ['qualified_name', 'simple_name', 'is_array'])
DeclaredType = namedtuple('DeclaredType', ['qualified_name', 'simple_name', 'is_array'])

class JavadocParser:
    def __init__(self, javadoc):
        self.javadoc = javadoc
        self.parameters = []
        self.return_type = None

    def parse(self):
        # Extract parameters and return type from the Javadoc
        params = re.findall(r'@param (\[.*?\])?', self.javadoc)
        return_type = re.search(r'@return\s*[\s\S]*?(?=\\n)', self.javadoc).group()
        
        if return_type:
            return_type = re.sub(r'@return\s*', '', return_type)
            matches = re.findall(r'\[.*?\]?', return_type)

        for param in params:
            start = param.index('[')
            end = param.index(']')
            self.parameters.append(re.sub('[^a-zA-Z0-9_]', '', param[start+1:end]))

        # Extract the return type
        if matches:
            return_type = matches[0]
            matches = re.findall(r'\s*\([.*?\]\s*', return_type)
            if matches:
                return_type = re.sub(r'@return\s*[\s\S]*?(?=\\n)', '', self.javadoc).strip()
                if 'None' in return_type:
                    return_type = None
            else:
                return_type = re.search(r'\[.*?\]?', return_type)
        else:
            return_type = re.sub(r'@return\s*', '', return_type)

        # Parse the parameter types
        parameter_types = []
        for param in self.parameters:
            if '=' in param:
                start = param.index('=')
                end = param.index(';', start+1)
                parameter_name = re.sub('[^a-zA-Z0-9_]', '', param[:start])
                parameter_content = re.sub('[^a-zA-Z0-9_]', '', param[start+1:end])
            else:
                parameter_type = re.search(r'@param\s+(\[.*?\])?', self.javadoc)
                if parameter_type:
                    start = parameter_type.start()
                    end = parameter_type.end()
                    parameter_name = re.sub('[^a-zA-Z0-9_]', '', param[start+6:end])
                    parameter_content = ''
                else:
                    continue
            parameter_types.append((parameter_name, parameter_content))

        # Extract the return type types
        if matches:
            for match in matches:
                start = match.index('(')
