import re

def process_javadoc(javadoc):
    # Extract parameters from @param tags
    params = []
    for line in javadoc.split('\n'):
        if line.startswith('@param'):
            match = re.search(r'@param\s+(\w+)\s+([^]+)', line)
            if match:
                param_type = match.group(2).strip()
                param_name = match.group(1)
                params.append({'type': {'qualified_name': param_type, 'simple_name': param_type, 'is_array': False}, 'name': param_name})

    # Check for null checks
    null_check = re.search(r'@param\s+([^]+)\s+must\s+not\s+be\s+null', javadoc)
    if null_check:
        params.append({'type': {'qualified_name': None, 'simple_name': None, 'is_array': False}, 'name': 'throwable'})

    # Extract return type
    match = re.search(r'@return\s+(\w+)', javadoc)
    if match:
        return_type = {'qualified_name': match.group(1), 'simple_name': match.group(1), 'is_array': False}

    # Process instance methods
    methods = []
    for line in javadoc.split('\n'):
        if line.startswith('void'):
            method_match = re.search(r'void\s+([a-zA-Z0-9_]+)\s*\(', line)
            if method_match:
                method_name = method_match.group(1)
                params_list = [params[i] for i in range(len(params)) if params[i]['name'] == method_name]
                methods.append({'name': method_name, 'parameters': params_list})

    # Generate assertions
    assertions = []
    for param in params:
        assertion = {
            "description": f"&lt;code&gt;{param['name']}&lt;/code&gt; must be of type &lt;strong&gt;" + param['type']['qualified_name'] + "&lt;/strong&gt;",
            "assertion": f"assert {param['name']} instanceof {" + param['type']['qualified_name'] + "}",
            "name": param['name'],
            "content": f"&lt;code&gt;{param['name']}&lt;/code&gt; must be of type &lt;strong&gt;" + param['type']['qualified_name'] + "&lt;/strong&gt;"
        }
        assertions.append(assertion)

    # Add null check assertion
    null_check_assertion = {
        "description": "&lt;code&gt;throwable&lt;/code&gt; must not be null",
        "assertion": f"assert {params[0]['name']} != null",
        "name": 'throwable',
        "content": "&lt;code&gt;throwable&lt;/code&gt; must not be null"
    }
    assertions.append(null_check_assertion)

    # Add return type assertion
    return_type_assertion = {
        "description": f"&lt;code&gt;{return_type['name']}&lt;/code&gt; must be of type &lt;strong&gt;" + return_type['qualified_name'] + "&lt;/strong&gt;",
        "assertion": f"assert {return_type['name']} instanceof {" + return_type['qualified_name'] + "}",
        "name": return_type['name'],
        "content": f"&lt;code&gt;{return_type['name']}&lt;/code&gt; must be of type &lt;strong&gt;" + return_type['qualified_name'] + "&lt;/strong&gt;"
    }
    assertions.append(return_type_assertion)

    # Add method-specific assertions
    for method in methods:
        for param in method['parameters']:
            assertion = {
                "description": f"&lt;code&gt;{param['name']}&lt;/code&gt; must be of type &lt;strong&gt;" + param['type']['qualified_name'] + "&lt;/strong&gt;",
                "assertion": f"assert {param['name']} instanceof {" + param['type']['qualified_name'] + "}",
                "name": param['name'],
                "content": f"&lt;code&gt;{param['name']}&lt;/code&gt; must be of type &lt;strong&gt;" + param['type']['qualified_name'] + "&lt;/strong&gt;"
            }
            assertions.append(assertion)

    return assertions

# Process javadoc
