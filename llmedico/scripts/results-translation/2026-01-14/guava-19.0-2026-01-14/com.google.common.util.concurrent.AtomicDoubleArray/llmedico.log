from typing import List, Dict

class JavadocParser:
    def __init__(self, javadoc: str):
        self.javadoc = javadoc.strip()

    def parse(self) -> List[Dict]:
        # Remove comments and documentation tags
        lines = [line.strip() for line in self.javadoc.split('\n') if not line.startswith('*/')]
        
        # Find the method signature
        start_idx = -1
        end_idx = -1
        for i, line in enumerate(lines):
            if '@param' in line:
                start_idx = i
            elif 'return' in line or '@throws' in line:
                end_idx = i + 1
                break
        
        # Extract parameters and return type
        params = []
        for i in range(start_idx, end_idx - 1):
            param = {}
            parts = lines[i].split(' ')
            if len(parts) > 2:
                name = parts[0]
                doc = ' '.join(parts[2:])
                param['name'] = name
                param['content'] = doc
                params.append(param)
        
        # Extract return type
        if end_idx < len(lines):
            lines.pop(end_idx)
            for i, line in enumerate(lines):
                if '@return' in line:
                    return_type = {'qualified_name': '', 'simple_name': '', 'is_array': False, 'array_dimensions': 0}
                    parts = line.split(' ')
                    if len(parts) > 2:
                        return_type['qualified_name'] = parts[1]
                        return_type['simple_name'] = parts[2]
                        return_type['is_array'] = False
                        return_type['array_dimensions'] = 0
                    break
        
        # Generate assertions
        assertions = []
        for param in params:
            if 'return' in lines or '@throws' in lines:
                continue
            doc = param['content']
            if '&' in doc:
                doc = doc.replace('&amp;', '&lt;')
            assertion = {
                "description": f"{param['name']} must be {doc}",
                "assertion": f"assert args[" + str(params.index(param) + 1) + "] instanceof {" + param['qualified_name'] + "};",
                "name": param['name'],
                "content": doc
            }
            assertions.append(assertion)
        
        return assertions


# Test the parser
javadoc = """
/**
 * Atomically sets the element at position {@code i} to the given
 * updated value
 * if the current value is <a href="#bitEquals">bitwise equal</a>
 * to the expected value.
 *
 * @param i  the index
 * @param expect  the expected value
 * @param update  the new value
 */
int length()
double get(int i)
double getAndAdd(int i,double delta)
double addAndGet(int i,double delta)
None toString()
"""
parser = JavadocParser(javadoc)
output = parser.parse()

# Print the output as JSON
print(json.dumps(output, indent=4))
