                        return new Assertion(lines[j - 1].split("\\s+")[0], " instanceof " + lines[j - 1].split("\\s+")[1] + ";");
                    }
                }
            }
        }
        return null;
    }

    private List<Assertion> generateAssertions(List<Param> params, Assertion returnType) {
        List<Assertion> assertions = new ArrayList<>();

