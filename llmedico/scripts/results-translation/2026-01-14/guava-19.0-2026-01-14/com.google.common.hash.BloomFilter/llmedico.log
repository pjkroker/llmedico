import re

def generate_assertions(javadoc, parameters, return_type):
    precondition = re.search(r'@param \s*(\w+)\s*must be (.*?)\n', javadoc)

    if precondition is None:
        precondition = re.search(r'@param \s*\(([^)]*)\)', javadoc)

    # Extract the parameter names and their constraints
    param_constraints = []
    for param in parameters:
        name = param['name']
        constraint = param['type']['qualified_name']
        content = param['content'].replace('&lt;', '<').replace('&gt;', '>')

        if precondition is None:
            description = f"{name} must be {constraint}"
        else:
            match = re.search(r'@param \s*' + name + r'\s*must be (.*?)\n', javadoc)
            if match is not None:
                constraint = match.group(1).strip()
                description = f"{name} must be {constraint}"

        param_constraints.append({'description': description, 'assertion': f'args[{parameters.index(name)}] == {constraint}', 'content': content})

    # Add the return type constraint if it's not null
    if return_type is not None:
        param_constraints.append({
            'description': f'return value must be of type {return_type["qualified_name"]}',
            'assertion': f'args[-1] instanceof {return_type["qualified_name"]}',
            'content': ''
        })

    # Generate the output JSON
    output = []
    for constraint in param_constraints:
        if constraint['language'] != "json":
            constraint['language'] = "json"
        output.append(constraint)

    return {
        "code_snippets": [
            {
                "description": constraint["description"],
                "assertion": constraint["assertion"],
                "name": constraint["name"],
                "content": constraint["content"]
            } for constraint in param_constraints
        ],
        "language": "json"
    }

# Input Javadoc
javadoc = """
/**
 * Creates a {@link BloomFilter BloomFilter<T>} with the expected number of
 * insertions and a default expected false positive probability of 3%.
 *
 * <p>Note that overflowing a {@code BloomFilter} with significantly more elements
 * than specified, will result in its saturation, and a sharp deterioration of its
 * false positive probability.
 *
 * <p>The constructed {@code BloomFilter<T>} is returned.
 */
BloomFilter create(None funnel,int expectedInsertions,double fpp)
"""

# Parameters
parameters = [
    {'name': 'funnel', 'type': {'qualified_name': 'Funnel'}, 'content': '<code>Funnel</code>'},
    {'name': 'expectedInsertions', 'type': {'qualified_name': 'int'}, 'content': 'the number of expected insertions to the constructed BloomFilter'}
]

# Return Type
return_type = {
    'qualified_name': None,
    'is_array': False,
    'array_dimensions': 0
}

output = generate_assertions(javadoc, parameters, return_type)
print('''
{
"code_snippets": [
[
"```json",
{"description": "funnel must be <code>Funnel</code>", "assertion": "args[0] == <code>Funnel</code>", "name": "funnel", "content": "<code>Funnel</code>"}
],
{
"description": "expectedInsertions must be the number of expected insertions to the constructed BloomFilter",
"assertion": "args[1] == int(the number of expected insertions to the constructed BloomFilter)",
"name": "expectedInsertions",
"content": "the number of expected insertions to the constructed BloomFilter"
},
{
"description": "return value must be of type <code>BloomFilter</code>",
"assertion": "args[-1] instanceof <code>BloomFilter</code>",
"name": "return_value",
"content": ""
}
]
],
"language": "json"
