            "noneOf(None sequence)",
            "inRange(char startInclusive,char endInclusive)",
            "forPredicate(None predicate)",
            "matches(char c)",
            "negate()",
            "and(None other)",
            "or(None other)",
            "precomputed()",
            "precomputedInternal()",
            "matchesAnyOf(None sequence)",
            "matchesAllOf(None sequence)",
            "matchesNoneOf(None sequence)",
            "indexIn(None sequence)"
        );

        List<Assertion> assertions = new ArrayList<>();
        for (String method : instanceMethods) {
            String assertion = generateAssertion(method, parameters(), returnType());
            if (!method.equals("indexIn")) {
                // Add IndexOutOfBoundsException check
                String indexOutOfBoundsExceptionCheck = "assert start >= 0 && start < sequence.length();";
                assertions.add(new Assertion(asString(method), asString(indexOutOfBoundsExceptionCheck), new Parameter("start", "int"), new Parameter("sequence", "CharSequence")));
            }
            assertions.add(new Assertion(asString(method), assertion, parameters()));
        }

        // Print Assertions
        for (Assertion assertion : assertions) {
            System.out.println(JSON.stringify(assertion));
        }
    }

    private static List<Parameter> parameters() {
        return Arrays.asList(
            new Parameter("start", "int"),
            new Parameter("sequence", "CharSequence")
        );
    }

    private static Parameter returnType() {
        return new Parameter("result", "int");
    }

    private static String generateAssertion(String method, List<Parameter> parameters, Parameter returnType) {
        return "assert " + method + "(receiverObjectID) == -1;";
    }

    private static class Assertion {
        private String description;
        private String assertion;
        private List<Parameter> parameters;

        public Assertion(String description, String assertion, List<Parameter> parameters) {
            this.description = description;
            this.assertion = assertion;
            this.parameters = parameters;
        }
    }

    private static class Parameter {
        private String name;
        private String type;

        public Parameter(String name, String type) {
            this.name = name;
            this.type = type;
        }
    }

    private static String asString(Parameter parameter) {
        return "{" +
                "\"name\":\"" + parameter.name + "\"," +
                "\"type\":\"" + parameter.type + "\"}";
    }

    private static String JSON.stringify(Assertion assertion) {
        return "{" +
                "\"description\":\"" + assertion.description + "\", " +
                "\"assertion\":\"" + assertion.assertion + "\", " +
                "\"parameters\":[";
        for (int i = 0; i < assertion.parameters.size(); i++) {
            if (i > 0) JSON.stringify(assertion.parameters.get(i));
            else JSON.stringify(assertion.parameters.get(0));
        }
        return "{\"parameters\":" + JSON.stringify("]") + "})";
    }
}
