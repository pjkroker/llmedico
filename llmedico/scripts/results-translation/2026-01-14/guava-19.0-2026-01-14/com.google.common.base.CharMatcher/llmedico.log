        "name": "setBits",
        "return_type": null,
        "parameters": [
          {
            "type": {
              "qualified_name": null,
              "simple_name": "BitSet",
              "is_array": false,
              "array_dimensions": 0
            },
            "name": "table"
          }
        ],
        "javadoc": "/**\n * Sets bits in {@code table} matched by this matcher.\n */\n",
        "tags": [],
        "code": "/**\n * Sets bits in {@code table} matched by this matcher.\n */\n@GwtIncompatible(\"java.util.BitSet\")\nvoid setBits(BitSet table) {\n    for (int c = Character.MAX_VALUE; c >= Character.MIN_VALUE; c--) {\n        if (matches((char) c)) {\n            table.set(c);\n        }\n    }\n}"
