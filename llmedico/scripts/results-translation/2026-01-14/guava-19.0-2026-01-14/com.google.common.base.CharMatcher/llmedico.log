```java
import java.util.List;
import java.util.Map;

public class AssertionGenerator {

    public static String generateAssertion(List<Map<String, Object>> parameters, boolean returnType) {
        StringBuilder assertionBuilder = new StringBuilder();
        for (Map<String, Object> parameter : parameters) {
            if (!returnType && "return".equals(parameter.get("name"))) {
                continue;
            }
            if ("@param".equals(parameter.get("tag"))) {
                String description = (String) parameter.get("content");
                String assertionName = (String) parameter.get("name");
                String assertionContent = description.replace("&lt;", "<").replace("&gt;", ">").replace("&amp;", "&");
                assertionBuilder.append("{{\n  \"description\": \"" + description.trim() + "\",\n  \"assertion\": \"assert " +
                        assertionName + " " + assertionContent + ";\",\n  \"name\": \"" + assertionName + "\",\n  \"content\": \"" +
                        assertionContent + "\"}}");
            }
        }
        return assertionBuilder.toString();
    }

    public static void main(String[] args) {
        List<Map<String, Object>> parameters = List.of(
                Map.of("tag", "@param", "name", "sequence", "content": "the character sequence to examine, possibly empty"),
                Map.of("tag", "@return", "name", "result", "content": "true if this matcher matches every character in the sequence, including when the sequence is empty")
        );
        String assertion = generateAssertion(parameters, true);
        System.out.println(assertion);

        List<Map<String, Object>> parameters2 = List.of(
                Map.of("tag", "@param", "name", "x", "content": "the first number; must be positive"),
                Map.of("tag", "@param", "name", "y", "content": "the second number; must be positive")
        );
        String assertion2 = generateAssertion(parameters2, false);
        System.out.println(assertion2);

        List<Map<String, Object>> parameters3 = List.of(
                Map.of("tag", "@param", "name", "sequence"),
                Map.of("tag", "@return", "name", "result"),
                Map.of("tag", "@throws", "name", "IllegalArgumentException", "content": "if either x or y is zero or negative")
        );
        String assertion3 = generateAssertion(parameters3, true);
        System.out.println(assertion3);
    }
}
```

