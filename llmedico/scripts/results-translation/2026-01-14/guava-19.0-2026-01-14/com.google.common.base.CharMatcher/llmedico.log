import java.util.*;

class Main {
    public static void main(String[] args) {
        List<String> instanceMethods = Arrays.asList(
            "any",
            "none",
            "whitespace",
            "breakingWhitespace",
            "ascii",
            "digit",
            "javaDigit",
            "javaLetter",
            "javaLetterOrDigit",
            "javaUpperCase",
