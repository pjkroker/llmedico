```java
import java.util.*;

public class Main {
    public static void main(String[] args) {
        String javadoc = """
/**
 * Returns a string copy of the input character sequence, with each character that matches this
 * matcher replaced by a given replacement sequence. For example: <pre>   {@code
 *
 *   CharMatcher.is('a').replaceFrom("yaha", "oo")}</pre>
 *
 * ... returns {@code "yoohoo"}.
 *
 * <p><b>Note:</b> If the replacement is a fixed string with only one character, you are better
 * off calling {@link #replaceFrom(CharSequence, char)} directly.
 *
 * @param sequence the character sequence to replace matching characters in
 * @param replacement the characters to append to the result string in place of each matching
 *        character in {@code sequence}
 * @return the new string
 */
""";

        Map<String, Object> params = parseJavadoc(javadoc);
        List<Map<String, Object>> assertions = generateAssertions(params);

        System.out.println(generateJson(assemblies(assemblies(assemblies(assertions)))));

    }

    private static Map<String, Object> parseJavadoc(String javadoc) {
        // For simplicity, let's assume the Javadoc only contains @param tags
        List<Map<String, Object>> parameters = new ArrayList<>();
        String[] lines = javadoc.split("\n");

        for (String line : lines) {
            if (line.contains("@param")) {
                Map<String, Object> param = new HashMap<>();
                param.put("name", line.substring(line.indexOf(":") + 1).trim());
                param.put("description", "No description provided");
                parameters.add(param);
            }
        }

        return Collections.singletonMap("parameters", parameters);
    }

    private static List<Map<String, Object>> generateAssertions(Map<String, Object> params) {
        List<Map<String, Object>> assertions = new ArrayList<>();

        for (Map<String, Object> param : (List<Map<String, Object>>) params.get("parameters")) {
            Map<String, Object> assertion = new HashMap<>();
            assertion.put("name", param.get("name"));
            assertion.put("description", param.get("description") + " is not null");
            assertions.add(assertion);
        }

        return assertions;
    }

    private static String generateJson(List<Map<String, Object>> assemblies) {
        StringBuilder json = new StringBuilder();
        json.append("{");

        for (Map<String, Object> assembly : assemblies) {
            json.append("\"").append(assembly.get("name")).append("\": {");
            json.append("\"languages\": [");
            List<Object> languages = (List<Object>) assembly.get("codeSnippets");
            if (languages != null && !languages.isEmpty()) {
                for (Object language : languages) {
                    Map<String, Object> lang = new HashMap<>();
                    lang.put("name", ((Map<String, Object>) language).get("languageId"));
                    lang.put("description", "");
                    lang.put("isCodeSnippetEnabled", true);
                    lang.put("codeSnippets", ((List<Object>) ((Map<String, Object>) language).get("replaceFrom")).stream().map(s -> "{\"languageId\":\"" + s + "\",\"replaceWith\":\"\"}").collect(Collectors.toList()));
                    json.append("{");
                    json.append("\"name\": \"" + lang.get("name") + "\", \"description\": \"" + lang.get("description") + "\", \"isCodeSnippetEnabled\": " + (Boolean) lang.get("isCodeSnippetEnabled") + ", \"codeSnippets\": [");
                    for (Object snippet : (List<Object>) ((Map<String, Object>) language).get("replaceFrom")) {
                        json.append("{\"languageId\":\"" + snippet + "\",\"replaceWith\":\"\"}");
                    }
                    json.append("]}");
                }
            } else {
                json.append("{ \"name\": \"JSON\", \"description\": \"\", \"isCodeSnippetEnabled\": true, \"codeSnippets\": []}");
            }

            json.append(", ");
        }

        json.deleteCharAt(json.length() - 2);
        json.append("]}");

        return json.toString();
    }
}
```

