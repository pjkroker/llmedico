        String returnTypeStr = "{\"qualified_name\": None, \"simple_name\": 'NoAddReason', \"is_array\": False, \"array_dimensions\": 0}";

        List<Parameter> parameters = parseParameters(parametersStr);
        List<String> assertions = generateAssertions(javadocString, parameters);

        System.out.println(assertions);
    }

    private static List<Parameter> parseParameters(String parametersStr) {
