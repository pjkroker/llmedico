                param_type = next((p["qualified_name"] for p in param_info if p["name"] == pos), None)
                assertion += f"receiverObject{get_next_name(i)}.{param_type} != null && receiverObject{get_next_name(i)}."
            
            # Check parameter type
            if "int" in content:
                if param_type is not None and param_type != "int":
