import org.json.JSONObject;

public class AssertionGenerator {
    public static String generateAssertion(String name, String description, String content) {
        JSONObject assertion = new JSONObject();
        assertion.put("name", name);
        if (description != null && !description.isEmpty()) {
            assertion.put("description", description);
        }
        if (content != null && !content.isEmpty()) {
            assertion.put("content", content);
        }
        assertion.put("assertion", "assert (" + content + ")");
        return assertion.toString();
    }

    public static String parseParameter(String javadoc, JSONObject params) {
        // This is a very simplified example. In real life you would need to use a full-fledged Javadoc parser.
        for (int i = 0; i < params.length(); i++) {
            if (javadoc.contains(" must be " + ((String) params.get(i).get("name")).toLowerCase() + ";")) {
                return generateAssertion((String) params.get(i).get("name"), "", "<" + ((String) params.get(i).get("content")) + ">");
            }
        }
        return null;
    }

    public static void main(String[] args) {
        String name = "values";
        JSONObject params = new JSONObject("[{\"type\":{\"qualified_name\":\"Values\",\"simple_name\":\"Values\",\"is_array\":false,\"array_dimensions\":0},\"name\":\"values\"},{\"type\":{\"qualified_name\":\"int\",\"simple_name\":\"int\",\"is_array\":false,\"array_dimensions\":0},\"name\":\"index\"}]");
        String content = "The values set containing the value to convert (it contains its own units).";
        JSONObject assertion = new JSONObject();
        if (!params.toString().isEmpty()) {
            assertion.put("content", content);
        }
        for (int i = 0; i < params.length(); i++) {
            if (!((String) params.get(i).get("name")).equals("index")) {
                String assertionContent = parseParameter(name, params);
                System.out.println(assertion.put("assertions", new JSONObject().put("content", assertionContent)));
            }
        }
        System.out.println(assertion.toString());
    }
}
