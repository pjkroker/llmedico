        assertion.put("name", name);
        if (description != null && !description.isEmpty()) {
            assertion.put("description", description);
        }
        if (content != null && !content.isEmpty()) {
            assertion.put("content", content);
        }
        assertion.put("assertion", "assert (" + content + ")");
        return assertion.toString();
