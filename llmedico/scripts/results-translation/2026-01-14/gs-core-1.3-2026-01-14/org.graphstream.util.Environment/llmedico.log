    public static String JSON.stringify(Map<String, Object> map) {
        StringBuilder sb = new StringBuilder();
        sb.append("{");
        for (Map.Entry<String, Object> entry : map.entrySet()) {
            if (!sb.toString().endsWith(",")) {
                sb.append("\"").append(entry.getKey()).append("\":");
            } else {
