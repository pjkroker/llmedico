import org.json.JSONObject;

public class Main {

    public static void main(String[] args) {
        String javadoc = "/**
 * Set the value of a parameter. If the parameter already exists its old\n" +
                "* value is overwritten. This works only if the environment is not locked.\n" +
                "@param parameter The parameter name.\n" +
                "@param value The new parameter value.\n" +
                "* @see #isLocked()\n" +
                "* @see #lockEnvironment(boolean)\n";
        String[] parameters = {"parameter", "value"};
        JSONObject returnType = new JSONObject();
        returnType.put("qualified_name", "void");
        returnType.put("simple_name", "setParameter");
        returnType.put("is_array", false);

        System.out.println(generateAssertions(javadoc, parameters, returnType));
    }

    public static String generateAssertions(String javadoc, String[] parameters, JSONObject returnType) {
        StringBuilder sb = new StringBuilder();
        for (String param : parameters) {
            if (javadoc.contains("@param " + param)) {
                int startIndex = javadoc.indexOf("@param ") + 7;
                String description = javadoc.substring(startIndex, javadoc.indexOf("\n", startIndex));
                sb.append("{
                    \"description\": \"").append(description).append("\",");
                }
                sb.append(" \"assertion\": \"assert ").append(param).append(": true;)");
                sb.append(", \"name\": \"").append(param).append("\",");
                String content = javadoc.substring(javadoc.indexOf("@param " + param) + 7, javadoc.indexOf("\n", javadoc.indexOf("@param " + param)));
                // Replaced null with the correct value
                if (content.contains("&lt;")) {
                    sb.append("\"content\": \"").append(content).replace("null", "&lt;null&gt;");
                } else {
                    sb.append("\"content\": \"").append(content);
                }
                sb.append("\",}");
                sb.append("\n");
            }
        }
        return sb.toString();
    }

}
