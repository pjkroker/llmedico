import java.util.ArrayList;
import java.util.List;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class Main {
    public static void main(String[] args) {
        String javadoc = "/**
 * Create a new Closure that calls each closure in turn, passing the
 * result into the next closure.
 *
 * @see org.apache.commons.collections4.functors.ChainedClosure
 *
 * @param <E>  the type that the closure acts on
 * @param closures  an array of closures to chain
 * @return the <code>chained</code> closure
 * @throws NullPointerException if the closures array is null
 * @throws NullPointerException if any closure in the array is null
 */";

        List<Map<String, String>> throwsAssertions = generateAssertions(javadoc);
        
        StringBuilder sb = new StringBuilder();
        for (Map<String, String> assertion : throwsAssertions) {
            sb.append("{{");
            sb.append("\"assertion\": \"").append(assertion.get("assertion")).append("\"}");
            if (assertion.containsKey("qualified_name")) {
                sb.append(", \"qualified_name\": \"").append(assertion.get("qualified_name")).append("\"");
            }
            sb.append("}}\n");
        }

        System.out.println(sb.toString());
    }

    private static List<Map<String, String>> generateAssertions(String javadoc) {
        int startIndex = javadoc.indexOf("@throws");
        if (startIndex != -1) {
            String throwsDescription = trimTag(javadoc.substring(startIndex + 8));
            return Arrays.asList(generateThrowsAssertions(throwsDescription));
        } else {
            return Collections.singletonList(Collections.singletonMap("assertion", "TODO"));
        }
    }

    private static List<Map<String, String>> generateThrowsAssertions(String javadoc) {
        List<String> parameterNames = new ArrayList<>();
        Pattern pattern = Pattern.compile("<\\d+>");
        Matcher matcher = pattern.matcher(javadoc);
        while (matcher.find()) {
            parameterNames.add(matcher.group());
        }
        
        if (parameterNames.isEmpty()) {
            return Collections.singletonList(Collections.singletonMap("assertion", "TODO"));
        }
        
        List<Map<String, String>> assertions = new ArrayList<>();
        for (String parameterName : parameterNames) {
            int startIndex = javadoc.indexOf(parameterName);
            int endIndex = javadoc.indexOf(">", startIndex);
            if (startIndex != -1 && endIndex != -1) {
                Map<String, String> assertionMap = new HashMap<>();
                assertionMap.put("name", parameterName.substring(1));
                String description = trimTag(javadoc.substring(startIndex + 2, endIndex));
                switch (description) {
                    case "null":
                        assertionMap.put("assertion", "assert receiverObjectID == null;");
                        break;
                    case "is null":
                        assertionMap.put("assertion", "assert !receiverObjectID.containsKey();");
                        break;
                    default:
                        assertionMap.put("assertion", "TODO");
                }
                if (parameterName.equals(parameterNames.get(0))) {
                    assertionMap.put("qualified_name", "org.apache.commons.collections4.functors.ChainedClosure");
                }
                assertions.add(assertionMap);
            }
        }
        
        return assertions;
    }

    private static String trimTag(String javadoc) {
        int startIndex = javadoc.indexOf("@throws");
        if (startIndex != -1) {
            return javadoc.substring(startIndex + 8).trim();
        } else {
            return "";
        }
    }
}
