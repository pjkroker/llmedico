import json
from typing import Any, Dict, List

def generate_precondition_assertion(closures: List[Dict[str, Any]], chained_closure: str) -> str:
    # Generate description and content for each parameter
    descriptions = []
    contents = []
    has_nullability_comment = False
    
    for closure in closures:
        name = closure["name"]
        param_type = closure["type"]["qualified_name"]

        # Check if the type contains nullability information
        if "array_dimensions" in closure["type"]:
            array_dimensions = closure["type"]["array_dimensions"]
            parameter = f"{param_type}[?][{array_dimensions}]"
            content = f"&lt;{parameter}&gt; must be positive&lt;/{parameter}&gt;"
            description = f"{name} must not be null"
        else:
            parameter = param_type
            content = f"&lt;{parameter}&gt; must not be null&lt;/{parameter}&gt;"
            description = f"{name} must not be null"

        descriptions.append(description)
        contents.append(content)

    # Generate assertion for each parameter
    assertions = []
    for description, content in zip(descriptions, contents):
        if "null" in content:
            content += " && closures != null"
            has_nullability_comment = True
        
        if name == 'closures':
            content += " && closures != null"
        
        assertion = f"assert {content};"
        assertions.append({"description": description, "assertion": assertion, "name": name, "content": content})

    return json.dumps({"descriptions": descriptions, "assertions": assertions}, indent=4)


