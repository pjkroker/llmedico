            end_param = line.find('>')
            param_content_start = line.find('&lt;') + 2
            param_content_end = line.find('&gt;')
            param_name = line[start_param:end_param].strip()
            param_content = line[param_content_start:param_content_end].replace('\n', '&lt;').replace('\t', '&lt;')

