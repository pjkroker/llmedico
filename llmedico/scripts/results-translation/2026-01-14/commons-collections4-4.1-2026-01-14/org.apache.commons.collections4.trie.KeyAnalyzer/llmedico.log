                String[] parts = typeDefinition.split(" ");
                String qualifiedName = parts[parts.length - 2];

                parameter["type"] = {"qualified_name": qualifiedName, "name": parameter};
                parameter["is_array"] = true;
            } else {
                parameterIndex++;
                continue;
            }
        }

        self.parameters.append(parameters);
    }

    public json generate_assertions() {
