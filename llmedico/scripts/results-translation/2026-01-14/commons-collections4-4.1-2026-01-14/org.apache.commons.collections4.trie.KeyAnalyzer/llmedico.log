        parseJavadoc();
    }

    private void parseJavadoc() {
        // Find the method signature and parameters
        String[] lines = javadoc.split("\n");
        StringBuilder methodSignatureBuilder = new StringBuilder();
        boolean foundParameters = false;

        for (String line : lines) {
            if (!foundParameters && line.startsWith(" * @param")) {
                parameterIndex = 0;
                foundParameters = true;
                continue;
            }
            if (foundParameters && line.trim().isEmpty()) {
                foundParameters = false;
                continue;
            }

            if (foundParameters) {
                String[] parts = line.split("\\s+");
                if (parts.length > 1 && parts[parts.length - 2].equals("of")) {
                    methodSignatureBuilder.append(parts[0]).append(" of ");
                } else {
                    methodSignatureBuilder.append(parts[0]);
                }
            }

            if (foundParameters && line.trim().startsWith("//")) {
                // Ignore // comments
                continue;
            }
        }

        String[] parameters = methodSignatureBuilder.toString().split("\\s+");

        for (String parameter : parameters) {
            if (parameter.startsWith("int") || parameter.endsWith("*")) {
                parameterIndex++;
                continue;
            }

            if (parameterIndex < self.parameters.length) {
