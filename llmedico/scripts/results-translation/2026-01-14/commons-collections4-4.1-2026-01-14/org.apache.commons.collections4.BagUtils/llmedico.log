import org.json.JSONObject;

public class Main {

    public static void main(String[] args) {
        String javadoc = """
/**
 * Returns a synchronized (thread-safe) bag backed by the given bag. In
 * order to guarantee serial access, it is critical that all access to the
 * backing bag is accomplished through the returned bag.
 * <p>
 * It is imperative that the user manually synchronize on the returned bag
 * when iterating over it:
 *
 * <pre>
 * Bag bag = BagUtils.synchronizedBag(new HashBag());
 * ...
 * synchronized(bag) {
 *     Iterator i = bag.iterator(); // Must be in synchronized block
 *     while (i.hasNext())
 *         foo(i.next());
 *     }
 * }
 * </pre>
 *
 * Failure to follow this advice may result in non-deterministic behavior.
 *
 * @param <E> the element type
 * @param bag the bag to synchronize, must not be null
 * @return a synchronized bag backed by that bag
 * @throws NullPointerException if the Bag is null
 */
""";

        String[] parameters = "[{'type': {'qualified_name': None, 'simple_name': 'Bag', 'is_array': False, 'array_dimensions': 0}, 'name': 'bag'}]";

        String returnType = '{"qualified_name": None, "simple_name": "Bag", "is_array": False, "array_dimensions": 0}';

        System.out.println(generateAssertions(javadoc, parameters, returnType));
    }

    public static String generateAssertions(String javadoc, String[] parameters, String returnType) {
        StringBuilder json = new StringBuilder();
        json.append("[");
        for (int i = 0; i < parameters.length; i++) {
            JSONObject paramJson = new JSONObject(parameters[i]);
            if (!paramJson.getString("type").equals("null")) {
                generateAssert(paramJson, returnType);
            }
        }
        json.append("]");
        return json.toString();
    }

    public static void generateAssert(JSONObject paramJson, String returnType) {
        String name = paramJson.getString("name");
        String content = paramJson.getString("content");

        if (paramJson.getString("type").contains("<")) {
            // Check for HTML Character Entities
            content = content.replace("&lt;", "<")
                    .replace("&gt;", ">")
                    .replace("\\n", "\\\\n")
                    .replace("\n", "\\n");
        }

        String assertion = "assert receiverObjectID == null";

        if (content.contains("<pre>")) {
            // Check for code snippets
            content = content.replace("<pre>", "\\&lt;pre\\&gt;")
                    .replace("</pre>", "\\\\&lt;/pre\\&gt;");
        } else {
            assertion = "assert " + name + " == null";
        }

        String description = "Failure to follow this advice may result in non-deterministic behavior.";

        json.append("{" +
                "description: \"" + description + "\", " +
                "\"assertion\": \"" + assertion + "\", " +
                "\"name\": \"" + name + "\", " +
                "\"content\": \"" + content + "\"" +
                "}");
    }
}
