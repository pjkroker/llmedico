import java.util.List;
import java.util.Map;

public class AssertGenerator {
    public static List<Map<String, Object>> generateAssertions(List<Method> methods) {
        List<Map<String, Object>> assertions = new ArrayList<>();

        for (Method method : methods) {
            if (method.getAnnotation(Throws.class) != null) {
                String description = getThrowsDescription(method);
                Map<String, Object> assertionMap = createAssertionMap(method, description);
                assertions.add(assertionMap);
            }
        }

        return assertions;
    }

    private static String getThrowsDescription(Method method) {
        for (throws Annotation throwsAnnotation : method.getAnnotationsByType(Throws.class)) {
            String description = throwsAnnotation.value();
            if (!description.isEmpty()) {
                return description;
            }
        }
        return null;
    }

    private static Map<String, Object> createAssertionMap(Method method, String description) {
        Map<String, Object> assertionMap = new HashMap<>();
        assertionMap.put("description", description);
        assertionMap.put("assertion", getAssertion(method));
        assertionMap.put("name", method.getAnnotation(Throws.class).value());
        return assertionMap;
    }

    private static String getAssertion(Method method) {
        // Ignore null and empty parameters
        if (method.getParameters().isEmpty()) {
            return "";
        }

        StringBuilder assertionBuilder = new StringBuilder();
        for (Parameter parameter : method.getParameters()) {
            Object typeValue = parameter.getType().getAnnotation(Type.class);
            if (typeValue != null) {
                String typeName = ((Type) typeValue).qualifiedName();
                if (!typeName.isEmpty()) {
                    assertionBuilder.append(typeName).append(" ");
                }
            }
        }

        // Determine the assertion operator
        char operator;
        if ("int".equals(method.getReturnType().getAnnotation(Type.class).qualifiedName())) {
            operator = '|';
        } else {
            operator = '==';
        }

        return "assert " + assertionBuilder.toString() + " == receiverObjectID." + method.getName();
    }
}

class Method {
    private List<Parameter> parameters;
    private Type returnType;

    // Getters and setters
}

class Throws {
    @Retention(RetentionPolicy.RUNTIME)
    @Target(ElementType.METHOD)
    public @interface Throws {
        String value();
    }

    class Parameter {
        private Type type;

        // Getters and setters
    }
}

class Type {
    private String qualifiedName;
    private String simpleName;

    public String getQualifiedName() {
        return qualifiedName;
    }

    public String getSimpleName() {
        return simpleName;
    }
}
```

