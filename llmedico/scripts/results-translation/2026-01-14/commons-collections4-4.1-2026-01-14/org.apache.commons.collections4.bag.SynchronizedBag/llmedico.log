        assert isinstance(javadoc, str), "Javadoc must be a string"
        assert isinstance(parameters, list), "Parameters must be a list"
        assert isinstance(return_type, dict), "Return type must be a dictionary"
        assert isinstance(methods, list), "Methods must be a list"

        output = []

        # Find the pre-condition tags
        for param in parameters:
            if re.search(r'@param\s+[\s\S]*?(\w+)\s+must\s+be\s+(.*?)', param["type"]["documentation"]):
                doc = param["type"]["documentation"]
                match = re.search(r'@param\s+([\s\S]*?)\s+must\s+be\s+(.*?)', doc)
                name = match.group(1).strip()
                content = match.group(2).strip()

                # Generate the assertion
                if return_type.get("qualified_name") == "null":
                    assert isinstance(content, str), "Content must be a string"
                    output.append({
                        "description": f"{name} must {content}",
                        "assertion": f"assert (args[0].{name}) == {(content)};",
                        "name": name,
                        "content": content
                    })
                else:
                    # No pre-condition assertion for return type
                    continue

        return output

