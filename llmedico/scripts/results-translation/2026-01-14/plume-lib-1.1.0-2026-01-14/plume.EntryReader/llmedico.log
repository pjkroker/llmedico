    public static List<Assertion> generateAssertions(String javadoc, String method, List<Parameter> parameters, String returnType) {
        List<Assertion> assertions = new ArrayList<>();

        // Extract @throws tags
        String[] throwsTags = javadoc.split("\n@throws");
        for (String tag : throwsTags) {
            if (!tag.isEmpty()) {
                String[] lines = tag.split(" @param");
                if (lines.length > 1) {
                    String condition = lines[0];
                    String exceptionName = lines[1].split(" ")[0];

                    // Extract parameter names
                    List<String> paramNames = new ArrayList<>();
                    for (Parameter p : parameters) {
                        paramNames.add(p.getName());
                    }

                    // Create assertion
                    Assertion assertion = new Assertion(condition, exceptionName, paramNames);
                    assertions.add(assertion);
                }
            }
        }

        return assertions;
    }

    public static class Parameter {
        private String name;
        private String type;

        public Parameter(String name, String type) {
            this.name = name;
            this.type = type;
        }

        public String getName() {
            return name;
        }

        public String getType() {
            return type;
        }
    }

    public static class Assertion {
        private String condition;
        private String exceptionName;
        private List<String> paramNames;

        public Assertion(String condition, String exceptionName, List<String> paramNames) {
            this.condition = condition;
            this.exceptionName = exceptionName;
            this.paramNames = paramNames;
        }

        @Override
        public String toString() {
            return "Assertion{" +
                    "condition='" + condition + '\'' +
                    ", exceptionName='" + exceptionName + '\'' +
                    ", paramNames=" + paramNames +
                    '}';
        }
    }

    public static String asString(JSONObject jsonObject) {
        StringBuilder sb = new StringBuilder();
        for (int i = 0; i < jsonObject.length(); i++) {
            Object value = jsonObject.get(i);
            if (value instanceof JSONObject) {
                sb.append(asString((JSONObject) value));
            } else if (value instanceof JSONArray) {
                sb.append(asArray((JSONArray) value));
            }
        }
        return sb.toString();
    }

    public static String asArray(JSONArray jsonArray) {
        StringBuilder sb = new StringBuilder("[");
        for (int i = 0; i < jsonArray.length(); i++) {
            Object value = jsonArray.get(i);
            if (value instanceof JSONObject) {
                sb.append(asString((JSONObject) value));
                if (i < jsonArray.length() - 1) {
                    sb.append(", ");
                }
            } else if (value instanceof JSONArray) {
                sb.append(asArray((JSONArray) value));
                if (i < jsonArray.length() - 1) {
                    sb.append(", ");
                }
            }
        }
        sb.append("]");
        return sb.toString();
    }

}
