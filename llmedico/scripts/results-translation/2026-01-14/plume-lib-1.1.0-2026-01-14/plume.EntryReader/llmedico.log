    public static List<Map<String, String>> generateAssertions(String javadoc) throws Exception {
        // Parse the Method Name and Parameters from the Javadoc
        Map<String, Object> methodInfo = parseJavadoc(javadoc);

        if (!methodInfo.containsKey("name") || !methodInfo.containsKey("parameters")) {
            throw new Exception("Invalid Javadoc format");
        }

        String methodName = (String) methodInfo.get("name");
        List<Map<String, Object>> parameters = (List<Map<String, Object>>) methodInfo.get("parameters");

        // Create a list to store the generated assertions
        List<Map<String, String>> assertions = new ArrayList<>();

        // Check for IOException and throw it if file does not exist or cannot be read
        Map<String, String> ioAssertion = generateThrowsAssertion(methodName, "IOException", parameters);
        if (ioAssertion != null) {
            assertions.add(ioAssertion);
        }

        return assertions;
    }

    private static Map<String, Object> parseJavadoc(String javadoc) {
        // This is a simplified version of the Javadoc parsing logic
        // In a real-world scenario, you would need to use a dedicated Javadoc parser library

        String[] lines = javadoc.split("\n");

        Map<String, Object> methodInfo = new HashMap<>();

        for (String line : lines) {
            if (line.contains("@throws")) {
                // Extract the exception class and description
                String exceptionClass = line.trim().split("\\s+")[1].split("<").first();
                String exceptionDescription = line.trim().split(" ").last();

                Map<String, Object> throwsAssertion = new HashMap<>();
                throwsAssertion.put("name", exceptionClass);
                throwsAssertion.put("description", exceptionDescription);

                // Generate the assertion
                Map<String, String> assertion = generateThrowsAssertion(methodName, exceptionClass, parameters);
                if (assertion != null) {
                    throwsAssertion.put("assertion", assertion.get("assertion"));
                    throwsAssertion.put("content", assertion.get("content"));
                    assertions.add(throwsAssertion);
                }
            }
        }

        return methodInfo;
    }

    private static Map<String, String> generateThrowsAssertion(String methodName, String exceptionClass, List<Map<String, Object>> parameters) {
