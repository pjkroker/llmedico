```java
import java.util.List;
import java.util.Map;

public class PreconditionGenerator {
    public static String generateAssertion(List<Map<String, Object>> params, boolean nullAllowed) {
        StringBuilder assertionBuilder = new StringBuilder();
        
        for (Map<String, Object> param : params) {
            if (!param.containsKey("qualified_name") && !param.containsKey("simple_name")) {
                continue;
            }
            
            String paramName = (String) param.get("name");
            String paramContent = (String) param.get("content");
            
            String assertion;
            if (nullAllowed || param.containsKey("is_array")) {
                assertionBuilder.append("assert ").append(paramName).append(" != null;");
            } else {
                if (param.containsKey("type") && ((Map<String, Object>) param.get("type")).containsKey("qualified_name")) {
                    assert ((String) ((Map<String, Object>) param.get("type")).get("qualified_name")).equals("java.lang.NullPointerException");
                }
                assertionBuilder.append("assert ").append(paramName).append(" == null;");
            }
            
            assertionBuilder.append(", ");
        }
        
        String assertionStr = assertionBuilder.toString();
        return "{\"description\": \"The process must be non-null and the time limit and cacheStdout must have their expected values\", " +
               "\"assertion\": \"" + assertionStr.substring(0, assertionStr.length() - 2) + ";\", " +
               "\"name\": \"p\", \"content\": \"non-null Process to limit the execution of\"}";
    }

    public static void main(String[] args) {
        List<Map<String, Object>> params = List.of(
                Map.of("type", Map.of("qualified_name", null, "simple_name", "Process", "is_array", 0)),
                Map.of("type", Map.of("qualified_name", "long", "simple_name", "long", "is_array", 0)),
                Map.of("type", Map.of("qualified_name", "boolean", "simple_name", "boolean", "is_array", 0))
        );
        
        System.out.println(generateAssertion(params, true));
    }
}
```

This code generates the pre-condition assertion in the format specified. Note that the `nullAllowed` parameter determines whether the null pointer exception is allowed or not. If it's `true`, the assertion will check for non-null values; otherwise, it will check for null values.
