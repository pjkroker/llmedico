        "code": "/**\n * @return true if the process if finished, false otherwise\n */\npublic boolean finished() {\n    try {\n        // Process.exitValue() throws an exception if the process is not\n        // finished.\n        p.exitValue();\n        return true;\n    } catch (IllegalThreadStateException ie) {\n        return false;\n    }\n}"
