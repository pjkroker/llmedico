```python
from javadocparser import parse_javadoc, parse_method

def generate_precondition_assertion(javadoc):
    # Parse Javadoc content
    parsed_doc = parse_javadoc(javadoc)
    
    # Generate precondition assertions
    precondition_assertions = []
    for param in parsed_doc.params:
        # Ignore @return and @throws tags
        if param.tag == 'param':
            precondition_assertion = {
                "description": param.documentation,
                "assertion": f"assert receiverObjectID.{param.name} {param.content};",
                "name": param.name,
                "content": param.content
            }
            
            # Check for nullability
            if 'null' not in precondition_assertion['content']:
                precondition_assertion["description"] += " must not be null"
                
            # Update assertion based on documentation
            precondition_assertion["assertion"] = generate_assertion(precondition_assertion["description"])
    
    return precondition_assertions

def generate_assertion(description):
    import re
    description = description.replace("&lt;", "<").replace("&gt;", ">")
    assert_statement = re.search(r'(.*) must (.*)', description).group(1) + " " + \
                      re.search(r'(.*) must (.*)', description).group(2)
    
    if "or" in assert_statement:
        left, right = assert_statement.split(" or ")
        return f"assert ({left}) {','.join([f'{a} == null' for a in right.split(' and ')])}"
        
    else:
        left, right = assert_statement.split(" must ")
        return f"assert ({left}) > 0 || {right} == null"

# Test the function
javadoc = """
/**
 * Returns an estimate of the solution to the linear system A &middot; x =
 * b.
