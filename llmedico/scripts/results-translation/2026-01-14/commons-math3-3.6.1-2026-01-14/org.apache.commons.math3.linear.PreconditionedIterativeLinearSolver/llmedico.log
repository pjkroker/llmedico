    return precondition_assertions

def generate_assertion(description):
    import re
    description = description.replace("&lt;", "<").replace("&gt;", ">")
    assert_statement = re.search(r'(.*) must (.*)', description).group(1) + " " + \
                      re.search(r'(.*) must (.*)', description).group(2)
    
    if "or" in assert_statement:
        left, right = assert_statement.split(" or ")
        return f"assert ({left}) {','.join([f'{a} == null' for a in right.split(' and ')])}"
        
    else:
        left, right = assert_statement.split(" must ")
        return f"assert ({left}) > 0 || {right} == null"

