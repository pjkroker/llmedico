            parameters.append({'type': {'qualified_name': None if 'RealLinearOperator' == parameter_type else parameter_type, 'simple_name': parameter_type.replace('Real', ''), 'is_array': True if array_dimensions > 1 else False}, 'name': parameter_name})
    
    return {
        'description': '',
        'assertion': '',
        'name': method_name,
        'content': ''
    }

def generate_assertions(methods: List[Dict]) -> List[Dict]:
    assertions = []
    
    for method in methods:
        name = method['description']
        
        if 'if' not in method['content']:
            throw_name, content = 'NullArgumentException', 'if one of the parameters is null'
        else:
            _, condition = method['content'].split(' * ')
            throw_name, content = 'NonSquareOperatorException' if condition.startswith('if') else 'DimensionMismatchException', condition
        
        assertion = {
            'description': '',
            'assertion': f'{name}.solve({{"type": {{"qualified_name": None, "simple_name": type.split("[")[0], "is_array": True}}}}, {content}, null) == null',
            'name': name,
            'content': content
        }
        
        assertions.append(assertion)
    
    return assertions

# Javadoc for the Method
