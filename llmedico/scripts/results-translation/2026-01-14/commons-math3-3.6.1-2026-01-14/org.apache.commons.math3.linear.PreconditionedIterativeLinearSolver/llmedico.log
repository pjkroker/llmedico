    lines = javadoc.strip().split('\n')
    method_name = ''
    parameters = []
    return_type = None
    
    for line in lines:
        if line.startswith(' * @param'):
            continue
        
        if line.startswith(' * @throws'):
            throws_description = line.split(' * ')[1].strip()
            
            if 'if' not in throws_description:
                throw_name, content = 'NullArgumentException', 'if one of the parameters is null'
            else:
                _, condition = throws_description.split(' * ')
                throw_name, content = 'NonSquareOperatorException' if condition.startswith('if') else 'DimensionMismatchException', condition
        elif line.startswith(' * @return'):
            continue
        
        if not line.strip():
            continue
        
        parts = line.split()
        
        if len(parts) == 2 and parts[0] == 'None':
            return_type = None
        elif len(parts) > 1:
