import org.json.JSONObject;
import java.util.Arrays;

public class Main {
    public static void main(String[] args) {
        JSONObject jdoc = new JSONObject("""
/**
 * Verifies that the input arrays are valid.
 * <p>
 * The centers must be distinct for interpolation purposes, but not
 * for general use. Thus it is not verified here.</p>
 *
 * @param a the coefficients in Newton form formula
 * @param c the centers
 * @throws NullArgumentException if any argument is {@code null}.
 * @throws NoDataException if any array has zero length.
 * @throws DimensionMismatchException if the size difference between
 * {@code a} and {@code c} is not equal to 1.
 * @see org.apache.commons.math3.analysis.interpolation.DividedDifferenceInterpolator#computeDividedDifference(double[],
 * double[])
 */
""");

        System.out.println(generateAssertion(jdoc, "NullArgumentException", Arrays.asList("a", "c")));
    }

    public static JSONObject generateAssertion(JSONObject jdoc, String exceptionName, List<String> parameters) {
        JSONObject assertion = new JSONObject();
        assertion.put("description", jdoc.getString("description"));
        assertion.put("assertion", evaluateAssertion(jdoc, exceptionName, parameters));
        assertion.put("name", exceptionName);
        return assertion;
    }

    public static String evaluateAssertion(JSONObject jdoc, String exceptionName, List<String> parameters) {
        if (exceptionName.equals("NullArgumentException")) {
            // Null check for both 'a' and 'c'
            StringBuilder sb = new StringBuilder();
            for (String param : parameters) {
                sb.append("assert ").append(param).append(" == null || ");
            }
            return sb.toString().replaceAll("\\s+$", "");
        } else if (exceptionName.equals("NoDataException")) {
            // Check if any array has zero length
            String[] conditions = new String[parameters.size()];
            for (int i = 0; i < parameters.size(); i++) {
                conditions[i] = "assert receiverObjectID[" + parameters.get(i) + "] != 0;";
            }
            return String.join(" && ", conditions);
        } else if (exceptionName.equals("DimensionMismatchException")) {
            // Check if the size difference between 'a' and 'c' is not equal to 1
            String[] conditions = new String[parameters.size()];
            for (int i = 0; i < parameters.size(); i++) {
                conditions[i] = "assert receiverObjectID[" + parameters.get(i) + "] != null && receiverObjectID[" + parameters.get(i) + "] - receiverObjectID[" + getOppositeParameter(parameters, i) + "] == 1;";
            }
            return String.join(" && ", conditions);
        } else {
            throw new UnsupportedOperationException("Unsupported exception name: " + exceptionName);
        }
    }

    public static String getOppositeParameter(List<String> parameters, int index) {
        if (index % 2 == 0) {
            return (String) parameters.get(index + 1);
        } else {
            return (String) parameters.get(index - 1);
        }
    }
}

