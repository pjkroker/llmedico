        "code": "/**\n * Resets all statistics and storage\n */\npublic void clear() {\n    this.n = 0;\n    minImpl.clear();\n    maxImpl.clear();\n    sumImpl.clear();\n    sumLogImpl.clear();\n    sumsqImpl.clear();\n    geoMeanImpl.clear();\n    secondMoment.clear();\n    if (meanImpl != mean) {\n        meanImpl.clear();\n    }\n    if (varianceImpl != variance) {\n        varianceImpl.clear();\n    }\n}"
