import java.util.*;

public class AssertionGenerator {
    public static void main(String[] args) {
        String javadoc = "/**
 * Copies source to dest.
 * <p>Neither source nor dest can be null.</p>
 *
 * @param source SummaryStatistics to copy
 * @param dest SummaryStatistics to copy to
 * @throws NullArgumentException if either source or dest is null
 */";

        String method = "copy";
        List<Parameter> parameters = Arrays.asList(
            new Parameter("source", "SummaryStatistics"),
            new Parameter("dest", "SummaryStatistics")
        );
        String returnType = "None";

        Map<String, Assertion> assertions = generateAssertions(javadoc, method, parameters, returnType);

        for (Assertion assertion : assertions.values()) {
            System.out.println(assertion.getJson());
        }
    }

    public static Map<String, Assertion> generateAssertions(String javadoc, String method, List<Parameter> parameters, String returnType) {
        Map<String, Assertion> assertions = new HashMap<>();

        // Extract @throws tags
        String[] throwsTags = javadoc.split("@throws\\s*([\\w\\s]+)", 2);

        for (int i = 1; i < throwsTags.length - 1; i += 2) {
            String description = throwsTags[i + 1].trim();
            if (!description.isEmpty()) {
                String[] conditions = description.split(" and ");

                // Convert conditions to assertion
                Assertion assertion = new Assertion(method, parameters, returnType);
                for (String condition : conditions) {
                    assertion.addCondition(condition);
                }

                assertions.put("IllegalArgumentException", assertion);
            }
        }

        return assertions;
    }

    public static class Assertion {
        private String method;
        private List<Parameter> parameters;
        private String returnType;
        private List<String> conditions;

        public Assertion(String method, List<Parameter> parameters, String returnType) {
            this.method = method;
            this.parameters = parameters;
            this.returnType = returnType;
            this.conditions = new ArrayList<>();
        }

        public void addCondition(String condition) {
            conditions.add(condition);
        }

        public String getJson() {
            StringBuilder sb = new StringBuilder("<");
            sb.append("description\":\"").append(getDescription()).append("\",");
            sb.append("assertion\":\"").append(getAssertion()).append("\",");
            sb.append("name\":\"").append(getName()).append("\",");
            sb.append("content\":\"").append(getContent()).append("\">");

            if (conditions.size() > 0) {
                String[] conditionsStr = new String[conditions.size()];
                for (int i = 0; i < conditions.size(); i++) {
                    conditionsStr[i] = conditions.get(i);
                }
                sb.append("conditions\": [");
                for (int i = 0; i < conditions.size(); i++) {
                    if (i > 0) {
                        sb.append(",");
                    }
                    sb.append("\"").append(conditionsStr[i]).append("\",");
                }
                sb.append("]");
            }

            return sb.toString();
        }

        private String getDescription() {
            return "Neither source nor dest can be null.";
        }

        private String getAssertion() {
            StringBuilder sb = new StringBuilder();
            for (String condition : conditions) {
                if (sb.length() > 0) {
                    sb.append(" and ");
                }
                sb.append(condition);
            }
            return sb.toString();
        }

        private String getName() {
            return "NullArgumentException";
        }

        private String getContent() {
            return "if either source or dest is null";
        }
    }

    public static class Parameter {
        private String name;
        private String type;

        public Parameter(String name, String type) {
            this.name = name;
            this.type = type;
        }

        public String getName() {
            return name;
        }

        public String getType() {
            return type;
        }
    }
}
