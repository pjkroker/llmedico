import java.util.*;

public class AssertionGenerator {
    public static List<Map<String, Object>> generateAssertions(List<MethodDescriptor> methodDescriptors) {
        List<Map<String, Object>> assertions = new ArrayList<>();
        
        for (MethodDescriptor descriptor : methodDescriptors) {
            String methodName = descriptor.getMethodName();
            List<ParameterDescriptor> parameters = descriptor.getParameters();
            String returnType = descriptor.getReturnType().qualified_name;
            List<AvailableInstanceMethod> instanceMethods = descriptor.getInstanceMethods();

            if (!returnType.isEmpty()) {
                continue;
            }

            for (AvailableInstanceMethod method : instanceMethods) {
                String methodDescription = method.getMethodDescription();
                List<String> conditions = new ArrayList<>();

                // Condition 1: NullArgumentException
                if (methodDescription.contains("NullArgumentException")) {
                    conditions.add("if either source or dest is null");
                }
                
                for (ParameterDescriptor parameter : parameters) {
                    String condition = "assert receiverObjectID." + parameter.name + " == null;";
                    conditions.add(condition);
                }

                Map<String, Object> assertionMap = new HashMap<>();
                assertionMap.put("name", method.getName());
                assertionMap.put("description", methodDescription);
                assertionMap.put("content", "if either source or dest is null");
                assertionMap.put("conditions", conditions);
                assertionMap.put("assertion", String.join(" || ", conditions));
                
                assertions.add(assertionMap);
            }
        }

        return assertions;
    }
}

class MethodDescriptor {
    private String methodName;
    private ParameterDescriptor[] parameters;
    private ReturnType returnType;
    private List<AvailableInstanceMethod> instanceMethods;

    public String getMethodName() { return methodName; }
    public ParameterDescriptor[] getParameters() { return parameters; }
    public ReturnType getReturnType() { return returnType; }
    public List<AvailableInstanceMethod> getInstanceMethods() { return instanceMethods; }

}

class ParameterDescriptor {
    private String name;
    private TypeDescriptor type;

    public String getName() { return name; }
    public TypeDescriptor getType() { return type; }
}

class ReturnType {
    private String qualified_name;

    public String getQualified_name() { return qualified_name; }
}

interface AvailableInstanceMethod {
    String getMethodName();
    String getMethodDescription();
}
