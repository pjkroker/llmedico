        String javadoc = "/**
 * Generate next pseudorandom number.
 * <p>This method is the core generation algorithm. It is used by all the
 * public generation methods for the various primitive types {@link
 * #nextBoolean()}, {@link #nextBytes(byte[])}, {@link #nextDouble()},
 * {@link #nextFloat()}, {@link #nextGaussian()}, {@link #nextInt()},
 * {@link #next(int)} and {@link #nextLong()}.</p>
 * @param bits number of random bits to produce
 * @return random bits generated
 */";

        List<Map<String, Object>> parameters = List.of(
            Map.of("type", Map.of("qualified_name", "int", "simple_name", "bits", "is_array", false)),
            Map.of("type", Map.of("qualified_name", "int", "simple_name", "n", "is_array", false))
        );

        Map<String, Object> returnType = Map.of(
            "qualified_name", "int",
            "simple_name", "nextInt",
            "is_array", false,
            "array_dimensions", 0
        );

        List<String> availableMethods = List.of(
            "int next(int bits)",
            "boolean nextBoolean()",
            "double nextDouble()",
            "float nextFloat()",
            "double nextGaussian()",
            "int nextInt()",
            "int nextInt(int n)",
            "long nextLong()",
            "long nextLong(long n)",
            "void clear()",
            "void nextBytes(byte bytes)",
            "void nextBytes(byte bytes,int start,int len)"
        );

        String[] assertionTemplates = {
            "assert args[0] == %d;",
            "assert args[1] >= 0 && args[1] < %d;",
            "assert return_val >= 0 && return_val < %d;",
            "assert return_val >= -2^31 && return_val < 2^31;",
            "assert return_val >= -2^63 && return_val < 2^63;"
        };

        List<Map<String, Object>> assertions = new ArrayList<>();

        for (Map<String, Object> parameter : parameters) {
            Map<String, Object> assertion = new HashMap<>();
            assertion.put("description", String.format("the number of random bits to produce; must be %s", parameter.get("name")));
            assertion.put("assertion", String.format(assertionTemplates[0], parameter.get("name")));
            assertion.put("name", parameter.get("name"));
            assertion.put("content", String.format("%s; must be positive", parameter.get("name")));
            assertions.add(assertion);
        }

        for (Map<String, Object> method : availableMethods) {
            if (!method.equals("void clear()") && !method.equals("void nextBytes(byte bytes)") && !method.equals("void nextBytes(byte bytes,int start,int len)")) {
                int index = Integer.parseInt(method.split("\\(")[1].split(")")[0]);
                Map<String, Object> parameter = parameters.get(index - 1);
                String assertionTemplate = String.format(assertionTemplates[2], "return_val");
                Map<String, Object> assertion = new HashMap<>();
                assertion.put("description", String.format("%s; must be positive", method));
                assertion.put("assertion", assertionTemplate.replace("%d", parameter.get("name")));
                assertion.put("name", parameter.get("name"));
                assertion.put("content", String.format("%s; must be positive", method));
                assertions.add(assertion);
            }
        }

        for (Map<String, Object> method : availableMethods) {
            if (!method.equals("void clear()") && !method.equals("void nextBytes(byte bytes)") && !method.equals("void nextBytes(byte bytes,int start,int len)")) {
                int index = Integer.parseInt(method.split("\\(")[1].split(")")[0]);
                Map<String, Object> parameter = parameters.get(index - 2);
                String assertionTemplate = String.format(assertionTemplates[3], "return_val");
                Map<String, Object> assertion = new HashMap<>();
                assertion.put("description", String.format("%s; must be positive", method));
                assertion.put("assertion", assertionTemplate.replace("%d", parameter.get("name")));
                assertion.put("name", parameter.get("name"));
                assertion.put("content", String.format("%s; must be positive", method));
                assertions.add(assertion);
            }
        }

        for (Map<String, Object> method : availableMethods) {
            if (!method.equals("void clear()") && !method.equals("void nextBytes(byte bytes)") && !method.equals("void nextBytes(byte bytes,int start,int len)")) {
                int index = Integer.parseInt(method.split("\\(")[1].split(")")[0]);
                Map<String, Object> parameter = parameters.get(index - 3);
                String assertionTemplate = String.format(assertionTemplates[4], "return_val");
                Map<String, Object> assertion = new HashMap<>();
                assertion.put("description", String.format("%s; must be positive", method));
                assertion.put("assertion", assertionTemplate.replace("%d", parameter.get("name")));
                assertion.put("name", parameter.get("name"));
                assertion.put("content", String.format("%s; must be positive", method));
                assertions.add(assertion);
            }
        }

        System.out.println(String.join("\n", assertions.stream().map(Map::toJSONString).toArray(String[]::new)));
    }
}
