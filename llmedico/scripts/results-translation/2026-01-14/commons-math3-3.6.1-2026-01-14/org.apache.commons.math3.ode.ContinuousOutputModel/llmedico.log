from typing import List

def generate_precondition_assertions(javadoc: str, method_name: str, parameters: List[dict], return_type: dict) -> List[dict]:
    precondition_assertions = []

    # Extract the description of each parameter
    for param in parameters:
        assert 'name' in param
        content = javadoc.split('\n')[javadoc.split('\n').index(f"@param {param['name']}") + 1].strip()
        if content.startswith('<strong>'):
            content = content.replace('</strong>', '').replace('&lt;', '<')
        elif content.startswith('<em>'):
            content = content.replace('</em>', '').replace('&lt;', '<')

        # Check for nullability
        if 'null' in param['content']:
            content += '. is not null'
        else:
            content += '. must be non-null'

        precondition_assertions.append({
            'description': f'{param["name"]} must {content}',
            'assertion': f'assert args[{parameter_index}] {content};',
            'name': param['name'],
            'content': param['content']
        })

    return precondition_assertions

def fix_json(json_str: str) -> str:
    import json
    try:
        json_obj = json.loads(json_str)
        if len(json_obj) != 1:
            raise ValueError("Expected exactly 1 conditions, but got " + str(len(json_obj)))
        return json.dumps(json_obj[0])
    except ValueError as e:
        print(e)
        return ''

javadoc = """
/**
 * Set the time of the interpolated point.
