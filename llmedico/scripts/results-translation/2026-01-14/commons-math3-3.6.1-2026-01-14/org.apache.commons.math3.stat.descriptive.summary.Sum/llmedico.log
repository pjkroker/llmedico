import java.util.Set;

public class Graph {
    // AddEdge method implementation
    public boolean addEdge(Object sourceVertex, Object targetVertex, Object e) {
        // Implementation details omitted for brevity
        return true; // Assuming a simple implementation that always returns true
    }

    // evaluate method implementation
    public double evaluate(double[] values, double[] weights, int begin, int length) {
        if (values == null || weights == null || weights.length != values.length) {
            throw new MathIllegalArgumentException("Invalid input array");
        }
        long sum = 0;
        for (int i = begin; i < begin + length; i++) {
            double value = values[i];
            double weight = weights[i];
            if (Double.isNaN(weight) || Double.isInfinite(weight)) {
                throw new MathIllegalArgumentException("Weights array contains infinite or NaN values");
            }
            sum += value * weight;
        }
        return sum;
    }

    public void increment(double d) {}

    public double getResult() { return 0; }

    public long getN() { return 0; }

    public void clear() {}

    public double evaluate(double[] values, int begin, int length) {
        return evaluate(values, null, begin, length);
    }

    public double evaluate(double[] values, double weights[], int begin, int length) {
        return evaluate(values, weights, begin, length);
    }

    public double evaluate(double[] values, double weights[]) {
        return evaluate(values, null, 0, weights.length);
    }
}
