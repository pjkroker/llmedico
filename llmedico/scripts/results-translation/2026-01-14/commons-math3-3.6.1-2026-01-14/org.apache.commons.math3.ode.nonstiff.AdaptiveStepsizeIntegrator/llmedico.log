public class Graph {
    private Map<String, Set<Edge>> edges;

    public Graph() {
        edges = new HashMap<>();
    }

    public boolean addEdge(Object sourceVertex, Object targetVertex, Object e) {
        String key = sourceVertex + "," + targetVertex;
        if (!edges.containsKey(key)) {
            edges.put(key, new HashSet<>());
        }
        edges.get(key).add((Edge)e);
        return true;
