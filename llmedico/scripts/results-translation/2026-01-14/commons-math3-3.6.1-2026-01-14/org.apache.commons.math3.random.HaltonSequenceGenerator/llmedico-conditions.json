        },
        {
          "description": "b must not be zero",
          "assertion": "assert args[2] != 0;",
          "name": "b",
          "content": "the base for this dimension"
        }
      ],
      "RETURN": [
        {
          "description": "the scrambled digit",
          "assertion": "assert methodResultID == (((weight_i * digit) % b));",
          "name": null,
          "content": "<pre>( weight_i * digit ) mod base</pre>"
