        },
        {
          "description": "i must not be zero",
          "assertion": "assert args[0] != 0;",
          "name": "i",
          "content": "the dimension index"
        },
        {
          "description": "j must not be zero",
          "assertion": "assert args[1] != 0;",
          "name": "j",
