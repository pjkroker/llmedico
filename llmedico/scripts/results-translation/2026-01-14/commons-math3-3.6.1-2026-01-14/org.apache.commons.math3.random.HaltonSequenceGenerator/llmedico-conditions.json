[
  {
    "method": "HaltonSequenceGenerator",
    "type": "constructor",
    "parameters": [
      {
        "type": {
          "qualified_name": "int",
          "simple_name": "int",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "dimension"
      }
    ],
    "conditions": {
      "PARAM": [
        {
          "description": "dimension must be in [1, 40]",
          "assertion": "assert args[0] >= 1 && args[0] <= 40;",
          "name": "dimension",
          "content": "the space dimension"
        }
      ],
      "THROWS": [
        {
          "description": "if dimension is outside the allowed range of [1, 40]",
          "assertion": "assert args[0] < 1 || args[0] > 40;",
          "name": "OutOfRangeException",
          "content": "if space dimension is outside the allowed range of [1, 40]"
        }
      ]
    }
  },
  {
    "method": "HaltonSequenceGenerator",
    "type": "constructor",
    "parameters": [
      {
        "type": {
          "qualified_name": "int",
          "simple_name": "int",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "dimension"
      },
      {
        "type": {
          "qualified_name": "int",
          "simple_name": "int",
          "is_array": true,
          "array_dimensions": 1
        },
        "name": "bases"
      },
      {
        "type": {
          "qualified_name": "int",
          "simple_name": "int",
          "is_array": true,
          "array_dimensions": 1
        },
        "name": "weights"
      }
    ],
    "conditions": {
      "PARAM": [
        {
          "description": "the space dimension must be greater than 0",
          "assertion": "assert receiverObjectID.dimension > 0;",
          "name": "dimension",
          "content": "&lt;strong&gt;The length of the bases array defines the space dimension and is required to be &gt; 0.&lt;/strong&gt;"
        },
        {
          "description": "bases must not be null and entries should be (pairwise) prime",
          "assertion": "assert receiverObjectID.bases != null && !receiverObjectID.bases.some(x -> x == 0 || x % 2 == 0);",
          "name": "bases",
          "content": "&lt;strong&gt;entries should be (pairwise) prime, may not be null&lt;/strong&gt;"
        },
        {
          "description": "weights must not be null and if non-null the length of the input arrays must match",
          "assertion": "assert receiverObjectID.weights == null || receiverObjectID.bases.length == receiverObjectID.weights.length;",
          "name": "weights",
          "content": "&lt;strong&gt;if weights is non-null, the length of the input arrays must match&lt;/strong&gt;"
        }
      ],
      "THROWS": [
        {
          "description": "&lt;code&gt;base&lt;/code&gt; is <code>null&lt;/code&gt;.",
          "assertion": "assert args[0] == null;",
          "name": "NullArgumentException",
          "content": "<code>null</code>"
        },
        {
          "description": "the space dimension is outside the range [1, len], where len refers to the length of the bases array",
          "assertion": "assert receiverObjectID.dimension < 1 || receiverObjectID.dimension > args[0].length;",
          "name": "OutOfRangeException",
          "content": "&lt;code&gt;len&lt;/code&gt; refers to the length of the bases array"
        },
        {
          "description": "weights is non-null and the length of the input arrays differ",
          "assertion": "assert args[1] == null || receiverObjectID.weights.length == receiverObjectID.bases.length && receiverObjectID.weights.length != receiverObjectID.bases[0].length;",
          "name": "DimensionMismatchException",
          "content": "&lt;code&gt;weights&lt;/code&gt; is non-null"
        }
      ]
    }
  },
