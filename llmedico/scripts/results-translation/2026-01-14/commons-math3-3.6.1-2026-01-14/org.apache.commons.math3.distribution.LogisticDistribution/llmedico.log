from typing import List, Dict

class PreconditionAssertion:
    def __init__(self, name: str, content: str, assertion: str):
        self.name = name
        self.content = content
        self.assertion = assertion


def generate_assertions(parameters: List[Dict], return_type: Dict) -> List[PreconditionAssertion]:
    assertions = []
    for parameter in parameters:
        if "type" in parameter and "name" in parameter and "qualified_name" not in parameter:
            name = parameter["name"]
            content = parameter["content"]
            assertion = (
                f"assert {name} instanceof "
                + return_type["qualified_name"]
                + ";"
            )
            assertions.append(
                PreconditionAssertion(name, content, assertion)
            )
    return assertions


def generate_json(output: List[PreconditionAssertion]) -> str:
    return json.dumps(output)


# Input Parameters
parameters = [
    {"type": {"qualified_name": "RandomGenerator", "simple_name": "RandomGenerator", "is_array": False, "array_dimensions": 0}, "name": "rng"},
    {
        "type": {"qualified_name": "double", "simple_name": "double", "is_array": False, "array_dimensions": 0},
        "name": "mu",
    },
    {
        "type": {"qualified_name": "double", "simple_name": "double", "is_array": False, "array_dimensions": 0},
        "name": "s",
    },
]

# Return Type
return_type = {"qualified_name": "void", "simple_name": "void", "is_array": False}

# Generate assertions and output as JSON
output = generate_assertions(parameters, return_type)
corrected_output = json.dumps(output)

# Output the corrected JSON
print(corrected_output)
