import json
from typing import List, Dict

def extract_throws_tags(javadoc: str) -> List[Dict]:
    throws_tags = []
    lines = javadoc.split('\n')
    in_throws_tag = False
    current_method = None
    for line in lines:
        if 'throws' in line and ' @param' not in line and '@return' not in line:
            in_throws_tag = True
        elif not in_throws_tag:
            throws_tags.append(extract_throws_line(line, current_method))
            current_method = line.split(' ')[0]
    return throws_tags


def extract_throws_line(line: str, method_name: str) -> Dict:
    throws_tag = {'description': '', 'assertion': '', 'name': '', 'content': ''}
    param_start_index = line.find('{')
    if param_start_index != -1:
        params_str = line[param_start_index + 1:-2]
        throws_tag['description'] = ''
        throws_tag['content'] = ""
        throws_tag['assertion'] = f'assert {method_name}({", ".join([param.strip().split(', ')[0] for param in params_str.split('), (')])})'
    return throws_tag


def main():
    javadoc = """/**
 * Generates a random value from the {@link HypergeometricDistribution Hypergeometric Distribution}.
 *
 * @param populationSize the population size of the Hypergeometric distribution
 * @param numberOfSuccesses number of successes in the population of the Hypergeometric distribution
 * @param sampleSize the sample size of the Hypergeometric distribution
 * @return random value sampled from the Hypergeometric(numberOfSuccesses, sampleSize) distribution
 * @throws NumberIsTooLargeException  if {@code numberOfSuccesses > populationSize},
 * or {@code sampleSize > populationSize}.
 * @throws NotStrictlyPositiveException if {@code populationSize <= 0}.
 * @throws NotPositiveException  if {@code numberOfSuccesses < 0}.
 */
"""
    throws_tags = extract_throws_tags(javadoc)
    for tag in throws_tags:
        print(json.dumps(tag, indent=4))


if __name__ == "__main__":
    main()
