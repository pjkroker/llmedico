public class AssertionGenerator {

    public static List<Assertion> generateAssertions(String javadoc) {
        String[] lines = javadoc.split("\n");

        List<Assertion> assertions = new ArrayList<>();

        for (String line : lines) {
            if (line.contains("@throws")) {
                String description = line.trim();

                int startIndex = description.indexOf("@throws");
                String tagDescription = description.substring(startIndex + 8);

                String[] tags = tagDescription.split(",");
