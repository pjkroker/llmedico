    }

    private static Assertion createNullPointerExceptionAssertion() {
        String assertion = "assert receiverObjectID==null;";
        return new Assertion("NullPointerException", assertion);
    }
}

class Tag {
    String name;
    String description;

    public Tag(String name, String description) {
        this.name = name;
        this.description = description;
    }
}

class Assertion {
