    private static Tag parseTag(String tagDescription) {
        String[] parts = tagDescription.split(":");
        if (parts.length == 2) {
            String name = parts[0].trim();
            String description = parts[1].trim();

            return new Tag(name, description);
        } else {
            throw new RuntimeException("Invalid tag format: " + tagDescription);
        }
    }

    private static Assertion generateAssertion(String name, String description) {
        if (name.equals("IllegalArgumentException")) {
