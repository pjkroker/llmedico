import java.util.ArrayList;
import java.util.List;

public class AssertionGenerator {

    public static List<Map<String, Object>> generateAssertions(String javadoc, String methodName, List<Map<String, Object>> parameters, String returnType) {
        List<Map<String, Object>> assertions = new ArrayList<>();

        if (parameters != null && !parameters.isEmpty()) {
            for (Map<String, Object> parameter : parameters) {
                Map<String, Object> assertion = new HashMap<>();
                assertion.put("description", generateDescription(javadoc));
                assertion.put("assertion", generateAssertion(parameter));
                assertion.put("name", (String) parameter.get("name"));
                assertion.put("content", getParameterContent(javadoc, parameter));

                assertions.add(assertion);
            }
        }

        return assertions;
    }

    private static String generateDescription(String javadoc) {
        int startIndex = javadoc.indexOf("@param");
        if (startIndex == -1) {
            return "";
        }

        int endIndex = javadoc.indexOf("\n", startIndex);
        if (endIndex == -1) {
            endIndex = javadoc.length();
        }

        String description = javadoc.substring(startIndex + 6, endIndex).trim();

        return description;
    }

    private static String generateAssertion(Map<String, Object> parameter) {
        return "assert " + parameter.get("name") + " " + getParameterContent(javadoc, parameter) + ";";
    }

    private static String getParameterContent(String javadoc, Map<String, Object> parameter) {
        int startIndex = javadoc.indexOf("@param");
        if (startIndex == -1) {
            return "";
        }

        int endIndex = javadoc.indexOf("\n", startIndex);
        if (endIndex == -1) {
            endIndex = javadoc.length();
        }

        String content = javadoc.substring(startIndex + 6, endIndex).trim();

        if (parameter.get("type") instanceof Map) {
            content += ": " + ((Map<String, Object>) parameter.get("type")).get("qualified_name");
        }

        return content;
    }
}
