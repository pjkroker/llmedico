                        lengthAssertion = name + " must not be null and its dimension must be greater than 0";
                    } else {
                        lengthAssertion = name + " must not be null";
                    }

                    assertion = "assert !" + lengthAssertion;
                } else if (simpleName.equals("Dimension") && jsonParameter.has("dimension")) {
                    JSONObject dimension = jsonParameter.getJSONObject("dimension");
                    String lengthAssertion;
                    if (dimension.has("qualifier") && dimension.get("qualifier").equals("negative")) {
                        lengthAssertion = name + " must be null or its dimension must be less than 0";
                    } else {
                        lengthAssertion = name + " must not be null";
                    }

                    assertion = "assert !" + lengthAssertion;
                } else if (paramType.has("qualifier") && qualName.equals(paramType.get("qualifier"))) {
                    String content = jsonParameter.getString("content").replace("&lt;", "<");
                    assertion = "assert " + content;
                }
            } else {
                continue;
            }

            JSONObject outputJson = new JSONObject();
            outputJson.put("description", name + " must " + content);
            outputJson.put("assertion", assertion);
            outputJson.put("name", name);

            output.add(outputJson);
        }

        return output;
    }
}
