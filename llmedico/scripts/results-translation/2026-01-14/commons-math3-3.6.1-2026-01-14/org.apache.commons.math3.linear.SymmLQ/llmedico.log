import java.util.ArrayList;
import java.util.List;

public class AssertionGenerator {
    public static List<Assertion> generateAssertions(String javadoc) {
        // Parse the Javadoc to extract @throws tags
        String[] throwsTags = javadoc.split("@throws");

        List<Assertion> assertions = new ArrayList<>();

        for (String tag : throwsTags) {
            if (!tag.isEmpty()) { // Ignore empty lines
                String description = trimAndEscape(tag);
                String name = getTagName(description);
                String content = getContent(description);

                assertAssertions(assertions, description, name, content);
            }
        }

        return assertions;
    }

    private static String trimAndEscape(String text) {
        return text.trim().replace("&lt;", "<").replace("&gt;", ">");
    }

    private static String getTagName(String description) {
        if (description.contains("if ")) {
            // @throws Exception: <code>exception</code> if condition
            int index = description.indexOf("if ");
            return description.substring(index + 4).trim();
        } else if (description.startsWith("if ")) {
            // @throws Exception: <code>condition</code>
            return description.trim().substring(3);
        }
        return "";
    }

    private static String getContent(String description) {
        if (description.contains(":")) { // @throws Exception: condition
            return description.substring(description.indexOf(":") + 1).trim();
        } else if (description.startsWith(":")) { // @throws Exception: <code>condition</code>
            return description.trim().substring(2);
        }
        return "";
    }

    private static void assertAssertions(List<Assertion> assertions, String description, String name, String content) {
        if (!content.isEmpty()) {
            String assertion = createAssertion(name, content);

            // Check for multiple conditions
            String[] parts = content.split("||");
            List<String> conditionList = new ArrayList<>();
            for (String part : parts) {
                if (!part.isEmpty()) { // Ignore empty strings
                    String condition = trimAndEscape(part);
                    conditionList.add(condition);
                }
            }

            if (conditionList.size() == 1) {
                // Single condition, no need to add logical OR
                assertions.add(new Assertion(name, assertion));
            } else {
                StringBuilder logicalOrBuilder = new StringBuilder();
                for (String condition : conditionList) {
                    logicalOrBuilder.append(" || ").append(condition);
                }
                String logicalOr = logicalOrBuilder.toString();

                // Add assert statement with logical OR
                assertions.add(new Assertion(name, logicalOr));
            }
        } else {
            // No content, only @throws Exception: <code>condition</code>
            String assertion = name + " == null";

            if (description.contains("if ")) { // @throws Exception: <code>condition</code>
                int index = description.indexOf("if ");
                String condition = description.substring(index + 4).trim();
                assertions.add(new Assertion(name, condition));
            } else {
                // @throws Exception: condition
                String condition = name;
                assertions.add(new Assertion(condition, assertion));
            }
        }
    }

    private static String createAssertion(String name, String content) {
        return "assert (" + name + ") == null;"; // TODO: make this more informative
