            if (paramType != null && paramType.has("qualifier") && qualName.equals(paramType.get("qualifier"))) {
                String content = jsonParameter.getString("content").replace("&lt;", "<");
                assertion = "assert " + content;
            } else if (paramType != null && paramType.has("simple_name")) {
                String simpleName = paramType.getString("simple_name");
                String content = jsonParameter.getString("content").replace("&lt;", "<");

                if (simpleName.equals("Dimension") && jsonParameter.has("dimension")) {
