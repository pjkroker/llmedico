import re

def generate_assertions(javadoc):
    lines = javadoc.split('\n')

    # Extract parameter information from @param tags
    params = []
    param_name = ''
    param_content = ''
    for line in lines:
        if line.strip().startswith('@param'):
            match = re.match(r'@param\s+([^\s]+)\s+([^<]+)', line)
            if match:
                param_name = match.group(1).strip()
                param_content = match.group(2).strip()
                params.append({
                    'type': {
                        'qualified_name': param_content,
                        'simple_name': param_name,
                        'is_array': False
                    },
                    'name': param_name
                })

    # Extract return type information from @return tag
    return_type = None
    for line in lines:
        if line.strip().startswith('@return'):
            match = re.match(r'@return\s+([^<]+)', line)
            if match:
                return_type = {
                    'qualified_name': match.group(1).strip(),
                    'simple_name': match.group(1).strip(),
                    'is_array': False
                }

    # Extract available instance methods from javadoc
    methods = []
    method_name = ''
    method_content = ''
    for line in lines:
        if line.strip().startswith('None'):
            continue
        if line.strip().endswith('()'):
            match = re.match(r'None\s+([^\s]+)', line)
            if match:
                method_name = match.group(1).strip()
                methods.append({
                    'name': method_name,
                    'content': ''
                })
        elif line.strip().startswith('if (') and line.strip().endswith(')'):
            match = re.match(r'if\s*\(\s*receiverObjectID\s+!=\s*null\s+&&\s*receiverObjectID\s+instanceof\s+\w+\)\s*{', line)
            if match:
                methods[-1]['content'] += ', assert true; } else { assert false; }'
            continue
        elif line.strip().startswith('if (') and line.strip().endswith(')'):
            match = re.match(r'if\s*\(\s*args\s*\[1\]\s+!=\s*null\s+||\s*args\s*\[1\]\s+instanceof\s+\w+\)\s*{', line)
            if match:
                methods[-1]['content'] += ', assert true; } else { assert false; }'
            continue

    # Generate assertions
    assertions = []
    for param in params:
        assertion = {
            'description': f'{param_name} must be of type {param["type"]["qualified_name"]}',
            'assertion': f'if (receiverObjectID != null && receiverObjectID instanceof {param["type"]["qualified_name"]}) {{ assert true; }} else {{ assert false; }}',
            'name': param['name'],
            'content': param_content
        }
        if 'content' in methods[-1]:
            assertion['assertion'] = f'{assertion["assertion"]} {methods[-1]["content"]}'
        assertions.append(assertion)

    return json.dumps(assertions, indent=4)

