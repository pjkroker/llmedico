            match = re.match(r'@return\s+(.*?)<', line)
            if match:
                return_type = {
                    'qualified_name': match.group(1).strip(),
                    'simple_name': match.group(1).strip(),
                    'is_array': False
                }

    # Extract available instance methods from javadoc
    methods = []
    method_name = ''
    method_content = ''
    for line in lines:
        if line.strip().startswith('None') or line.strip() == '':
            continue
        if line.strip().endswith('()'):
            match = re.match(r'None\s+([^\s]+)', line)
            if match:
                method_name = match.group(1).strip()
                methods.append({
                    'name': method_name,
                    'content': ''
                })
        elif '<' in line and '>' in line:
            continue
        elif line.strip().startswith('if (') and line.strip().endswith(')'):
            match = re.match(r'if\s*\(\s*(.*?)\s+!=\s*null\s+||\s*(.*?)\s+instanceof\s+\w+\)\s*{', line)
            if match:
                condition1, condition2 = match.group(1), match.group(2)
                method_content += f', assert true; } else {{ assert false; }}'
                methods[-1]['content'] += f'if ({condition1} || {condition2}) {{ assert true; }} else {{ assert false; }}'

    # Generate assertions
