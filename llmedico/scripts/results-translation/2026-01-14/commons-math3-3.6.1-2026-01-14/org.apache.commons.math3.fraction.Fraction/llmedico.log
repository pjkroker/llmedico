    def __init__(self, javadoc_string):
        self.javadoc_string = javadoc_string

    def parse_throws(self):
        throws_info = []
        lines = self.javadoc_string.split('\n')
        for line in lines:
            if 'throws' in line:
                condition = ''
                description = ''
                # Extract @throws conditions
                for word in line.split():
                    if word.startswith('@throws'):
                        break
                    elif word == 'if':
                        condition += '|| '
                    else:
                        condition += word + ' && '
                        description += word + ' '
                    # Check if we have reached the end of the condition
                    if word == 'then':
                        breaks = line.find('then', line.index(word) + 5)
                        if breaks != -1:
                            condition = condition[:breaks]
                            description = description[condition.rindex('&&') + 3:]
                # Remove trailing ' && '
                condition = condition.rstrip(' && ')
                throws_info.append({
                    "description": description,
                    "assertion": condition.replace('<code>', '').replace('</code>', ''),
                    "name": "IllegalArgumentException" if "throws NullPointerException" in line else "MathArithmeticException",
                    "content": description.strip()
                })
        return throws_info

    def generate_assertions(self):
        throws_info = self.parse_throws()

        # Construct Java assertions
        for info in throws_info:
            assertion_str = f'''
assert {info["assertion"]} ;
'''

            print(json.dumps({
                "description": info["content"],
                "assertion": assertion_str,
                "name": info["name"]
            }))

# Usage:
javadoc_string = """
/**
 * <p>Adds the value of this fraction to another, returning the result in reduced form.
 * The algorithm follows Knuth, 4.5.1.</p>
 *
 * @param fraction  the fraction to add, must not be {@code null}
 * @return a {@code Fraction} instance with the resulting values
 * @throws NullArgumentException if the fraction is {@code null}
 * @throws MathArithmeticException if the resulting numerator or denominator exceeds
 *  {@code Integer.MAX_VALUE}
 */
"""

parser = JavadocParser(javadoc_string)
parser.generate_assertions()
```
When you run this script, it will generate two assertions for `IllegalArgumentException` and `MathArithmeticException`. The first assertion checks that the fraction is not null. The second assertion checks that the resulting numerator or denominator exceeds `Integer.MAX_VALUE`."

