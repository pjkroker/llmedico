import java.util.ArrayList;
import java.util.List;

public class AssertionGenerator {
    public static List<Assertion> generateAssertions(String javadoc) {
        // Parse the method signature and parameters
        String[] lines = javadoc.split("\n");
        String methodSignature = "";
        String[] parameters = new String[0];
        for (String line : lines) {
            if (line.startsWith("@param")) {
                parameters = parseParameters(line);
            } else if (line.equals("}")) {
                break;
            }
        }

        // Parse the return type
        String returnType = null;
        for (int i = 0; i < lines.length; i++) {
            if (lines[i].startsWith("@return") || lines[i].startsWith("@throws")) {
                continue;
            }
            if (lines[i].equals("}")) {
                break;
            }
            if (lines[i].contains(":")) {
                String[] parts = lines[i].split(":");
                returnType = parts[1].trim();
            }
        }

        // Parse the available instance methods
        List<String> availableMethods = new ArrayList<>();
        for (String line : lines) {
            if (line.startsWith("void") || line.startsWith("double")) {
                availableMethods.add(line.trim());
            }
        }

        // Generate assertions for each parameter
        List<Assertion> assertions = new ArrayList<>();
        for (String parameter : parameters[1].split(",")) {
            String[] parts = parameter.split("\\s+");
            if (!parts[0].equals("return")) {
                String description = parseDescription(parts);
                String assertion = generateAssertion(parts, availableMethods);
                AssertionsList.add(assertions, new Assertion(description, assertion, parts[1]));
            }
        }

        return assertions;
    }

    private static String[] parseParameters(String line) {
        int start = line.indexOf('(');
        int end = line.indexOf(')');
        String[] parts = line.substring(start + 1, end).split(",");
        for (int i = 0; i < parts.length; i++) {
            parts[i] = parts[i].trim();
        }
        return parts;
    }

    private static String parseDescription(String[] parts) {
        if (parts.length > 1) {
            return parts[1];
        } else {
            for (String method : availableMethods) {
                if (method.startsWith(parts[0])) {
                    return "Must call the " + method + " method";
