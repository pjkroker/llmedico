        String json = mapper.writeValueAsString(output);

        System.out.println(json);
    }

    public static List<Map<String, Object>> generateAssertions(String javadoc, String parameters, String returnType) {
        // Parse parameters
        Map<String, Object> otherTypeMap = parseParameters(parameters);

        // Generate assertions
        List<Map<String, Object>> output = new ArrayList<>();

        // Check for nullity
        Map<String, Object> assertion1 = generateAssertion("the other object must not be null", "assert this.other != null");
        output.add(assertion1);

        // Check if other is of correct type
        Map<String, Object> assertion2 = generateAssertion("other must be an instance of Vector3D", "assert this.other instanceof Vector3D");
        output.add(assertion2);

        // Check for equality
        Map<String, Object> assertion3 = generateEqualityAssertion(otherTypeMap, "the two 3D vectors are considered to be equal");
        output.add(assertion3);

        return output;
    }

    public static Map<String, Object> parseParameters(String parameters) {
        ObjectMapper mapper = new ObjectMapper();
        try {
            Map<String, Object> otherTypeMap = mapper.readValue(parameters, Map.class);
            // Convert Map of parameter type maps to a single map
            Map<String, Object> combinedMap = new HashMap<>();
            for (Map.Entry<String, Object> entry : otherTypeMap.entrySet()) {
                String paramName = entry.getKey();
                Object paramTypeMap = entry.getValue();

                if (paramTypeMap instanceof Map) {
                    // Add parameter type maps to the combined map
                    ((Map<String, Object>) combinedMap).put(paramName, ((Map<String, Object>) paramTypeMap));
                }
            }
            return combinedMap;
        } catch (Exception e) {
            throw new RuntimeException(e);
        }
    }

    public static Map<String, Object> generateAssertion(String description, String assertionCode) {
        Map<String, Object> assertion = new HashMap<>();
        assertion.put("description", description);
        assertion.put("assertionCode", assertionCode);

        return assertion;
    }

    public static Map<String, Object> generateEqualityAssertion(Map<String, Object> otherTypeMap, String description) {
        // Get the parameter types
        List<Map<String, Object>> paramTypes = new ArrayList<>();
        for (Map.Entry<String, Object> entry : otherTypeMap.entrySet()) {
            paramTypes.add((Map<String, Object>) entry.getValue());
        }

        // Generate assertion code
        StringBuilder assertionCodeBuilder = new StringBuilder();
        assertionCodeBuilder.append("assert this.other ");
        for (int i = 0; i < paramTypes.size(); i++) {
            String paramName = "param" + i;
            Map<String, Object> paramTypeMap = paramTypes.get(i);
            if (!paramTypeMap.containsKey("isArray")) {
                assertionCodeBuilder.append(paramName).append(" == ").append(paramName);
            } else {
                assertionCodeBuilder.append(paramName).append(" == ");
                if (paramTypeMap.get("isArray") != null && !(Boolean) paramTypeMap.get("isArray")) {
                    // Convert int value to string
                    int minValue = (Integer) paramTypeMap.get("minValue");
                    int maxValue = (Integer) paramTypeMap.get("maxValue");

                    assertionCodeBuilder.append("(").append(minValue).append(", ").append(maxValue).append(")");
                } else if (paramTypeMap.containsKey("type") && !((String) paramTypeMap.get("type")).equals("double")) {
                    // Convert int value to string
                    int minValue = (Integer) paramTypeMap.get("minValue");
                    int maxValue = (Integer) paramTypeMap.get("maxValue");

                    assertionCodeBuilder.append("(").append(minValue).append(", ").append(maxValue).append(")");
                }
            }

            if (i < paramTypes.size() - 1) {
                assertionCodeBuilder.append(" && ");
            }
        }

        String assertionCode = assertionCodeBuilder.toString();

        Map<String, Object> assertion = new HashMap<>();
        assertion.put("description", description);
        assertion.put("assertionCode", assertionCode);

        return assertion;
    }
}"

