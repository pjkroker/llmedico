import java.util.*;

public class AssertionGenerator {

    private static final String ASSERTION_TEMPLATE = "assert %s;";

    public static List<Map<String, Object>> generateAssertions(String javadoc) {
        // Parse the Javadoc string to extract parameters and return type
        List<Map<String, Object>> params = parseParameters(javadoc);
        Map<String, Object> returnType = parseReturnType(javadoc);

        // Generate assertions for each parameter
        List<Map<String, Object>> assertions = new ArrayList<>();
        for (Map<String, Object> param : params) {
            String content = (String) param.get("content");
            String name = (String) param.get("name");

            // Check if the content includes HTML elements or character entities
            if (content.contains("&lt;") || content.contains("<")) {
                content = content.replace("&lt;", "&amp;lt;");
                content = content.replace("<", "&lt;");
            }

            Map<String, Object> assertion = new HashMap<>();
            assertion.put("description", String.format("the code must be %s", name));
            assertion.put("assertion", String.format(ASSERTION_TEMPLATE, String.format("%s %s", name, content)));
            assertion.put("name", name);
            assertion.put("content", content);

            assertions.add(assertion);
        }

        return assertions;
    }

    private static List<Map<String, Object>> parseParameters(String javadoc) {
        // Find the opening @param tag
        int paramStart = javadoc.indexOf("@param");
        if (paramStart == -1) {
            return new ArrayList<>();
        }

        // Find the closing @param tag
        int paramEnd = javadoc.indexOf("\n", paramStart);
        if (paramEnd == -1) {
            paramEnd = javadoc.length();
        }

        // Extract the parameters between the tags
        String paramStr = javadoc.substring(paramStart, paramEnd).trim();

        List<Map<String, Object>> params = new ArrayList<>();
        for (String param : paramStr.split(",")) {
            Map<String, Object> paramMap = new HashMap<>();
            paramMap.put("name", param.trim().split("=")[0].trim());
            paramMap.put("content", param.trim().split("=")[1].trim());

            params.add(paramMap);
        }

        return params;
    }

    private static Map<String, Object> parseReturnType(String javadoc) {
        // Find the opening @return tag
        int returnTypeStart = javadoc.indexOf("@return");
        if (returnTypeStart == -1) {
            return new HashMap<>();
        }

        // Find the closing @return tag
        int returnTypeEnd = javadoc.indexOf("\n", returnTypeStart);
        if (returnTypeEnd == -1) {
            returnTypeEnd = javadoc.length();
