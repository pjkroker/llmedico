        String[] paramDescriptions = cleanedJavadoc.substring(startIndex, endIndex).split(",");

        List<Map<String, String>> assertions = new ArrayList<>();

        // Process each parameter description
        for (String paramDescription : paramDescriptions) {
            if (!paramDescription.isEmpty()) {  // ignore empty strings

                int startIndex = paramDescription.indexOf("must be");
                int endIndex = paramDescription.indexOf(";");

                if (startIndex != -1 && endIndex != -1) {
                    String description = paramDescription.substring(startIndex + 5, endIndex);
                    Map<String, Object> typeMap = parameters.get(paramDescription.split("=")[0].trim());
                    if (typeMap != null) {
