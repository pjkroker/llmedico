    private static void parseJavadoc(String javadoc, List<JsonElement> jsonElements) {
        // For simplicity, assume the Javadoc is well-formed
        String[] lines = javadoc.split("\n");
        StringBuilder currentTag = new StringBuilder();

        for (String line : lines) {
            if (line.startsWith("@param")) {
                currentTag.setLength(0);
                jsonElements.add(new JsonElement(currentTag.toString().trim()));
            } else if (!currentTag.length() == 0 && line.startsWith("/**") || line.endsWith("*/")) {
                currentTag.append(line.substring(line.indexOf('}') + 1).trim());
            }
        }

        // If there's a remaining @param tag, add it to the list
        if (currentTag.length() > 0) {
            jsonElements.add(new JsonElement(currentTag.toString().trim()));
        }
    }

    private static void generateAssertions(List<JsonElement> jsonElements) {
        for (JsonElement element : jsonElements) {
            String type = element.getType().getQualifiedname();
            String name = element.getName();

            if (!type.equals("double")) {
                System.out.println("Incorrect parameter type: " + type);
                continue;
            }

            if (element.getName().equals("x0") || element.getName().equals("x1")
                    || element.getName().equals("absoluteAccuracy")) {
                // Check for null
                String assertion = "assert " + name + " != null;";
                System.out.println(assertion);

                continue;
            }

            if (!name.equals(element.getName())) {
                System.out.println("Incorrect parameter name: " + name);
                continue;
            }

            String assertion = "assert (" + name + " instanceof double);";
            System.out.println(assertion);
        }
    }

    private static class JsonElement {
        private String type;
        private String name;

        public String getType() {
            return type;
        }

        public void setType(String type) {
            this.type = type;
        }

        public String getName() {
            return name;
        }

        public void setName(String name) {
            this.name = name;
        }
    }
}
