import java.util.function.UnivariateFunction;

public class BracketingAlgorithm {
    public static double[] bracket(UnivariateFunction function, double initial, double lowerBound, double upperBound) {
        return forceSide(bracket(0, 1), null, function, initial, lowerBound, upperBound, 1000);
    }

    private static double[] forceSide(double lower, double upper, UnivariateFunction f, double x0, double lowerBound, double upperBound, int maxEval) {
        for (int k = 0; k < maxEval; k++) {
            double mid = midpoint(lower, upper);
            boolean bracketing = isBracketing(f, lower, mid);

            if (!bracketing) {
                return null;
            }

            if (mid > x0 && x0 > lowerBound) {
                lower = lowerBound;
                upper = mid;
            } else if (upper < x1 && x1 < upperBound) {
                upper = upperBound;
            }

            double newLower = midpoint(lower, upper);
            double newUpper = midpoint(upper, lower);

            boolean isSequence = isSequence(newLower, newUpper, 0.5);
            if (!isSequence) {
                return null;
            }
        }

        verifyInterval(lower, upper);
        verifySequence(lower, initial, upper);

        return new double[] {lower, upper};
    }

    private static boolean isBracketing(UnivariateFunction f, double lower, double upper) {
        double lowerValue = f.solve(f, lower);
        double upperValue = f.solve(f, upper);

        if (Math.abs(lowerValue - upperValue) < 1e-6) {
            return true;
        } else {
            return false;
        }
    }

    private static boolean isSequence(double start, double mid, double end) {
        return Math.abs(mid - start) > 0.5 && Math.abs(end - mid) > 0.5;
    }

    private static void verifyInterval(double lower, double upper) {}

    private static void verifySequence(double lower, double initial, double upper) {}

    private static void verifyBracketing(UnivariateFunction f, double lower, double upper) {}
}
