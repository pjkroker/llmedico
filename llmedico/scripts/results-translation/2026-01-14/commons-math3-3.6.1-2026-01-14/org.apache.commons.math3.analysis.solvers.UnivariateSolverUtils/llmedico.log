    public static String assembliesToJSON(List<Map<String, String>> assemblies) {
        StringBuilder sb = new StringBuilder("[\n");
        for (Map<String, String> assembly : assemblies) {
            sb.append("\t{\n");
            sb.append("\t\t\"description\": \"").append(assembly.get("description")).append("\",\n");
