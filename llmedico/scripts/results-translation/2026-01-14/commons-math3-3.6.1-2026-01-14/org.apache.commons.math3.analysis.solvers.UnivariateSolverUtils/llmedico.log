                        Map<String, String> assertionMap = new HashMap<>();
                        assertionMap.put("description", " must be " + description);
                        assertionMap.put("assertion", assertion);
                        assertionMap.put("name", paramName);
                        assertionMap.put("content", description);
                        assertions.add(assertionMap);

                    }
                }

            }
        }

        return assertions;
    }

