public class Bracket {
    public static double[] bracket(UnivariateFunction function, double initial, double lowerBound, double upperBound) {
        return bracket(function, initial, lowerBound, upperBound, 1.0, 2.0, Integer.MAX_VALUE);
    }

    public static double[] bracket(UnivariateFunction function, double initial, double lowerBound, double upperBound, double q, double r, int maximumIterations) {
        if (initial >= upperBound || initial <= lowerBound) {
            throw new NoBracketingException("Initial value must be within the search interval");
        }
        
        double[] bracketing = bracketing(function, initial, lowerBound, upperBound, q, r, maximumIterations);
        verifyInterval(lowerBound, bracketing[0]);
        verifyInterval(bracketing[1], upperBound);
        
        return new double[]{bracketing[0], bracketing[1]};
    }

    public static double[] bracketing(UnivariateFunction function, double initial, double lower, double upper, double q, double r, int maximumIterations) {
        double[] bounds = new double[2];
        int k = 0;
        
        while (k < maximumIterations && isBracketing(function, bounds[0], bounds[1])) {
            if (!isSequence(bounds[0], bounds[0] - q / r, bounds[1] + q / r)) {
                break;
            }
            
            double a = midpoint(bounds[0], bounds[1]);
            double b = midpoint(bounds[0] - q / r, bounds[0] + q / r);
            double c = midpoint(bounds[1] - q / r, bounds[1] + q / r);
            
            if (a < lower) {
                lower = a;
            }
            if (c > upper) {
                upper = c;
            }
            
            bounds[0] = Math.min(lower, bounds[0]);
            bounds[1] = Math.max(upper, bounds[1]);
            
            k++;
        }
        
        return bounds;
    }

    public static boolean isBracketing(UnivariateFunction function, double lower, double upper) {
        return function.solve(function, lower - 1e-6, upper + 1e-6) > 0;
    }

    public static boolean isSequence(double start, double mid, double end) {
        if (start < end) {
            return mid >= start && mid <= end;
        } else {
            return mid >= end && mid <= start;
        }
    }

