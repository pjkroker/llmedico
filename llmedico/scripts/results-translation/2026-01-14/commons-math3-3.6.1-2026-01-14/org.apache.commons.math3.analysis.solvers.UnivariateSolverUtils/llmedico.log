import json

class Precondition:
    def __init__(self, name, content):
        self.name = name
        self.content = content

def fix_assertion(assertion):
    return f"assert {assertion}"

def generate_preconditions(javadoc):
    # Parse the Javadoc to extract parameters and their documentation
    params = []
    for tag in javadoc["tags"]:
        if tag["name"] == "param":
            param_type = {
                "qualified_name": tag["doc"]["type"]["qualified_name"],
                "simple_name": tag["doc"]["type"]["simple_name"],
                "is_array": tag["doc"]["type"]["array_dimensions"] == 0,
            }
            params.append({"type": param_type, "name": tag["name"], "content": tag["doc"].get("description", "")})

    # Generate the preconditions
    preconditions = []
    for i, param in enumerate(params):
        if javadoc.get("return_type"):
            continue
        content = param.get("content")
        if content.startswith("&lt;") and content.endswith("&gt;"):
            content = content[1:-2]
        precondition = Precondition(
            name=f"if ({param['name']}) {{ {fix_assertion(param['name'])} }}",
            content=content
        )
        preconditions.append({"description": content, **precondition.__dict__})

    return preconditions

def main():
    javadoc = {
        "tags": [
            {"name": "param", "doc": {"type": {"qualified_name": None, "simple_name": "UnivariateFunction", "array_dimensions": 0}, "description": ""}},
            {"name": "param", "doc": {"type": {"qualified_name": None, "simple_name": "double", "array_dimensions": 0}, "description": "&lt;double&gt;"}}},
            {"name": "param", "doc": {"type": {"qualified_name": None, "simple_name": "double", "array_dimensions": 0}, "description": "&lt;double&gt;"}}},
        ]
    }

    preconditions = generate_preconditions(javadoc)
    print(json.dumps(preconditions))

if __name__ == "__main__":
    main()
