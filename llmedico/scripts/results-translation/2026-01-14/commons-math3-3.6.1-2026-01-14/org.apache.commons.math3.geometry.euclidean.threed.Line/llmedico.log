```java
import java.util.List;
import java.util.Map;

public class AssertionGenerator {

    public static List<Map<String, String>> generateAssertions(String javadoc) {
        // Split the Javadoc into lines
        String[] lines = javadoc.split("\n");

        // Initialize an empty list to store the assertions
        List<Map<String, String>> assertions = new ArrayList<>();

        // Iterate over each line in the Javadoc
        for (String line : lines) {
            // Check if the line contains a @throws tag
            if (line.contains("@throws")) {
                // Extract the exception name and description from the @throws tag
                int index = line.indexOf("@throws");
                String exceptionName = line.substring(index + 8, line.indexOf(":")).trim();
                String condition = line.substring(line.indexOf(":") + 1).trim();

                // Check if the condition mentions multiple sub-conditions
                if (condition.contains("&&")) {
                    // Split the condition into individual statements
                    String[] statements = condition.split("&&");

                    // Generate an assertion for each statement
                    for (String statement : statements) {
                        Map<String, String> assertion = new HashMap<>();
                        assertion.put("description", statement.trim());
                        assertion.put("assertion", statement);
                        assertion.put("name", exceptionName);
                        assertion.put("content", condition);
                        assertions.add(assertion);
                    }
                } else if (condition.contains("||")) {
                    // Split the condition into individual statements
                    String[] statements = condition.split("||");

                    // Generate an assertion for each statement
                    for (String statement : statements) {
                        Map<String, String> assertion = new HashMap<>();
                        assertion.put("description", statement.trim());
                        assertion.put("assertion", statement);
                        assertion.put("name", exceptionName);
                        assertions.add(assertion);
                    }
                } else if (!condition.isEmpty()) {
                    // Generate an assertion for the single condition
                    Map<String, String> assertion = new HashMap<>();
                    assertion.put("description", condition.trim());
                    assertion.put("assertion", condition);
                    assertion.put("name", exceptionName);
                    assertions.add(assertion);
                }
            }
        }

        return assertions;
    }

    public static void main(String[] args) {
        // Javadoc
        String javadoc = "/**
 * Build a line from two points.
 *
 * @param p1 first point belonging to the line (this can be any point)
 * @param p2 second point belonging to the line (this can be any point, different from p1)
 * @param tolerance tolerance below which points are considered identical
 * @exception MathIllegalArgumentException if the points are equal
 * @since 3.3
 */";

        // Generate assertions
        List<Map<String, String>> assertions = generateAssertions(javadoc);

        // Print assertions
        for (Map<String, String> assertion : assertions) {
            System.out.println("{" +
                    "description: '" + assertion.get("description") + "'," +
                    "assertion: '" + assertion.get("assertion") + "'," +
                    "name: '" + assertion.get("name") + "'," +
                    "content: '" + assertion.get("content") + "'" +
                    "}");
        }
    }
}
```

