import re

def generate_preconditions(javadoc):
    lines = javadoc.split('\n')
    tags = []
    for line in lines:
        match = re.search(r'@param\s+([a-zA-Z0-9_]+)\s*must\s*(be|be\W*positive|not\W*[a-z])', line)
        if match:
            params = lines[lines.index(line) + 1].split('{')
            param_type = {'qualified_name': None, 'simple_name': None, 'is_array': False}
            param_type['name'] = match.group(1)
            tag = {
                "type": param_type,
                "name": match.group(1),
                "content": line.strip()
            }
            tags.append(tag)

    return tags

def process_tags(tags):
    processed_tags = []
    for tag in tags:
        if 'content' not in tag or 'assertion' not in tag:
            continue
        processed_tag = {
            "type": tag["type"],
            "name": tag['name'],
            "description": tag["content"],
            "assertion": tag["assertion"]
        }
        # Remove the 'must be positive' part of the assertion
        if 'be positive' in tag['assertion']:
            processed_tag['assertion'] = re.sub(r'must be positive', '', tag['assertion'])
        elif 'not' not in tag['assertion']:
            processed_tag['assertion'] = re.sub(r'must be', '', tag['assertion'])
            if 'be' in tag['assertion']:
                processed_tag['assertion'] = re.sub(r'be', '=', tag['assertion')
        else:
            # Remove the part of the assertion that is not needed for our purpose
            parts = re.split(r'\s*(not|not\s*)\W*', tag['assertion'])
            if len(parts) > 1 and parts[-1] == '=':
                processed_tag['assertion'] = 'assert ' + parts[0]
        processed_tags.append(processed_tag)

    return processed_tags

