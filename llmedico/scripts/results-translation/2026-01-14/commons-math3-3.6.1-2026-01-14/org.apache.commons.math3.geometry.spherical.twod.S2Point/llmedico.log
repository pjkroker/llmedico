import java.util.*;

public class Main {
    public static void main(String[] args) {
        String javadoc = "/**
 * Simple constructor.
 * Build a vector from its spherical coordinates
 * @param theta azimuthal angle \( \theta \) in the x-y plane
 * @param phi polar angle \( \varphi \)
 * @see #getTheta()
 * @see #getPhi()
 * @exception OutOfRangeException if \( \varphi \) is not in the [\( 0; \pi \)] range
 */";

        String[] parameters = "[{'type': {'qualified_name': 'double', 'simple_name': 'double', 'is_array': False, 'array_dimensions': 0}, 'name': 'theta'}, {'type': {'qualified_name': 'double', 'simple_name': 'double', 'is_array': False, 'array_dimensions': 0}, 'name': 'phi'}]";
        String returnType = "None";
        String[] availableMethods = {"double getTheta()", "double getPhi()", "None getVector()", "None getSpace()", "boolean isNaN()", "None negate()", "double distance(None point)", "double distance(None p1, None p2)", "boolean equals(None other)", "int hashCode()"};

        List<Map<String, Object>> assertions = new ArrayList<>();

        Map<String, Object> param1 = new HashMap<>();
        param1.put("description", "theta must be in the range [-pi; pi]");
        param1.put("assertion", "assert args[0] >= -3.14159265359 && args[0] <= 3.14159265359;");
        param1.put("name", "theta");
        param1.put("content", "&lt;div&gt;azimuthal angle &lt;/div&gt;&lt;span style=\"color: red;\"&gt;$lt;thetax&gt;&lt;/thetax&gt; in the x-y plane&lt;/span&gt;");
        assertions.add(param1);

        Map<String, Object> param2 = new HashMap<>();
        param2.put("description", "phi must be in the range [0; pi]");
        param2.put("assertion", "assert args[0] >= 0 && args[0] <= 3.14159265359;");
        param2.put("name", "phi");
        param2.put("content", "&lt;div&gt;polar angle &lt;/div&gt;&lt;span style=\"color: red;\"&gt;$lt;phix&gt;&lt;/phix&gt;";
        assertions.add(param2);

        for (Map<String, Object> assertion : assertions) {
            System.out.println(JSON.stringify(assertion));
        }
    }

    public static String JSON(String obj) {
        StringBuilder sb = new StringBuilder();
        sb.append("{");
        for (int i = 0; i < obj.length(); i++) {
            if (obj.charAt(i) == ',') {
                sb.append(",");
            } else {
                sb.append("\"").append(obj.charAt(i)).append("\": \"").append(obj.substring(i + 1, obj.length())).append("\",");
            }
        }
        sb.setLength(sb.length() - 2);
        return sb.toString();
    }

    public static void JSONMap(Map<String, Object> map) {
        StringBuilder sb = new StringBuilder("{");
        for (String key : map.keySet()) {
            if (!sb.toString().equals("{")) {
                sb.append(",");
            }
            sb.append("\"").append(key).append("\": \"").append(map.get(key)).append("\",");
        }
        sb.setLength(sb.length() - 2);
        System.out.println(sb.toString());
    }
}
```
