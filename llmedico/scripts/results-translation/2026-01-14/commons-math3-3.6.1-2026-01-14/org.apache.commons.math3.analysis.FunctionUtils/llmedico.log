             //output += "{\"description\":\"f must be a list of functions\",\"assertion\":\"if (args != null && args instanceof List)&#x3C;UnivariateFunction&#x3E;\",\"name\":\"multiply\",\"content\":\"f must be a list of functions.\"}\n";
         }
     }

        return output;
    }
    private static String parseParameters(String input){
        // extract parameters from javadoc
        String[] lines = input.split("\n");
        StringBuilder parameterString = new StringBuilder();
        for (String line : lines) {
            if(line.contains("@param")) {
                parameterString.append(line).append("\n");
            }
        }

        return parameterString.toString().trim();

    }

