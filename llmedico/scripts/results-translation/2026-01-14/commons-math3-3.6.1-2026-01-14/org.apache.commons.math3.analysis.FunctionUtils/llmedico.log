            "\n" +
            "@param f Binary function.\n" +
            "@param fixed value to which the second argument of {@code f} is set.", parameters, "UnivariateFunction");

    // Print the assertions
    for (String assertion : assertions) {
      System.out.println(assertion);
    }
  }
}
