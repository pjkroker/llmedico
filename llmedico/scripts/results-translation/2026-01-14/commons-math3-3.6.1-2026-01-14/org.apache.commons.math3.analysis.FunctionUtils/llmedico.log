public class Graph {
    // ... other methods and fields ...

    public boolean addEdge(Object sourceVertex, Object targetVertex, Object e) {
        if (sourceVertex == null || targetVertex == null) {
            throw new NullPointerException();
        }
        return edgesOf(sourceVertex).contains(e);
    }

    public double sample(UnivariateFunction f, double min, double max, int n) {
        if (n <= 0) {
            throw new NotStrictlyPositiveException();
        }
        if (min >= max) {
            throw new NumberIsTooLargeException();
        }
        double[] samples = new double[n];
        for (int i = 0; i < n; i++) {
            double x = min + (max - min) / n * i;
            samples[i] = f.apply(x);
        }
        return samples;
    }

    // ... other methods ...

    private Set edgesOf(Object vertex) { /* implementation details */ }
}
```
