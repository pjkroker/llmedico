  public static void generateAssertion(String javadoc, Parameter param, List<String> assertions) {
    // Extract the description and content of the @param tag
    String[] lines = javadoc.split("\n");
    int startIndex = -1;
    for (int i = 0; i < lines.length; i++) {
      if (lines[i].contains("@param " + param.getName())) {
        startIndex = i + 1;
        break;
      }
    }

    // If the @param tag is not found, skip this parameter
    if (startIndex == -1) return;

    String description = "";
    String content = "";
    for (int i = startIndex; i < lines.length; i++) {
      if (lines[i].contains("}")) break;
      String line = lines[i];
      // Check if the line contains a colon (:)
      if (line.contains(":")) {
        description += line + "\n";
      } else {
        content += line + "\n";
      }
    }

    // Generate the assertion
    String assertion = "description: \"" + description.trim() + "\",\n" +
            "content: \"" + content.trim() + "\"";

    assertions.add(assertion);
  }

  public static List<Parameter> parseParameters(String[] parameters) {
    List<Parameter> parsedParameters = new ArrayList<>();
    for (String param : parameters) {
      String[] parts = param.split(",");
      if (parts.length == 2) {
        parsedParameters.add(new Parameter(parts[0], parts[1]));
      }
    }
    return parsedParameters;
  }

  public static class Parameter {
    private String name;
    private String type;

    public Parameter(String name, String type) {
      this.name = name;
      this.type = type;
    }

    public String getName() {
      return name;
    }

    public String getType() {
      return type;
    }
  }

