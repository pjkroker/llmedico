          "simple_name": "double",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "max"
      },
      {
        "type": {
          "qualified_name": "int",
          "simple_name": "int",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "n"
      }
    ],
    "conditions": {
      "PARAM": [
        {
          "description": "the function must be differentiable univariate",
          "assertion": "assert receiverObjectID.toDifferentiableUnivariateFunction(args[0]) != null;",
          "name": "f",
          "content": "Function to be sampled"
        },
        {
          "description": "min must be strictly positive",
          "assertion": "assert args[1] > 0 && receiverObjectID.min >= args[1];",
          "name": "min",
          "content": "Lower bound of the interval (included)"
        },
        {
          "description": "max must be strictly greater than min and not equal to it",
          "assertion": "assert args[2] > args[1] && args[2] != args[1];",
          "name": "max",
          "content": "Upper bound of the interval (excluded)"
        },
        {
          "description": "n must be strictly positive",
          "assertion": "assert args[3] > 0;",
          "name": "n",
          "content": "Number of sample points"
        }
      ],
      "RETURN": [
        {
          "tag": "return",
          "name": "the",
          "content": "array of samples.",
          "assertion": "",
          "description": "array of samples."
        }
      ],
      "THROWS": [
        {
          "description": "if min is greater than max.",
          "assertion": "assert args[2] > args[1];",
          "name": "NumberIsTooLargeException",
          "content": "if lower bound is greater than upper bound."
        },
        {
          "description": "if n is negative.",
          "assertion": "assert args[3] < 0;",
          "name": "NotStrictlyPositiveException",
          "content": "If number of sample points is negative."
        }
      ]
    }
  },
