    "method": "sample",
    "type": "method",
    "parameters": [
      {
        "type": {
          "qualified_name": null,
          "simple_name": "UnivariateFunction",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "f"
      },
      {
        "type": {
          "qualified_name": "double",
          "simple_name": "double",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "min"
      },
      {
        "type": {
          "qualified_name": "double",
          "simple_name": "double",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "max"
      },
      {
        "type": {
          "qualified_name": "int",
          "simple_name": "int",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "n"
      }
    ],
    "conditions": {
      "PARAM": [
        {
          "description": "f is not sampled at the upper bound max",
          "assertion": "assert max > f;",
          "name": "f",
          "content": "Function to be sampled"
        },
        {
          "description": "the lower bound of the interval (included)",
          "assertion": "assert min < max;",
          "name": "min",
          "content": "Lower bound of the interval (included)."
        },
        {
          "description": "the upper bound of the interval (excluded)",
          "assertion": "assert true;",
          "name": "max",
          "content": "Upper bound of the interval (excluded)."
        },
        {
          "description": "the number of sample points",
          "assertion": "assert n > 0;",
          "name": "n",
          "content": "Number of sample points."
        }
      ],
      "RETURN": [
        {
          "description": "the array of samples.",
          "assertion": "assert result == args[3].sample(args[2], args[1], args[0]);",
          "name": null,
          "content": "the array of samples."
        }
      ],
      "THROWS": [
        {
          "description": "if the lower bound min is greater than, or equal to the upper bound max.",
          "assertion": "assert args[2] < args[1];",
          "name": "NumberIsTooLargeException",
          "content": "if the lower bound @code min is greater than, or equal to the upper bound @code max."
        },
        {
          "description": "if the number of sample points n is negative.",
          "assertion": "assert args[3] > 0;",
          "name": "NotStrictlyPositiveException",
          "content": "if the number of sample points @code n is negative."
        }
      ]
    }
