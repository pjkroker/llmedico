, 'conditions': {}}, {'method': 'getUnitList', 'type': 'method', 'parameters': [], 'conditions': {}}, {'method': 'getUnitIterator', 'type': 'method', 'parameters': [], 'conditions': {}}, {'method': 'getGoodsContainer', 'type': 'method', 'parameters': [], 'conditions': {}}, {'method': 'getSettlement', 'type': 'method', 'parameters': [], 'conditions': {}}, {'method': 'getColony', 'type': 'method', 'parameters': [], 'conditions': {}}, {'method': 'getIndianSettlement', 'type': 'method', 'parameters': [], 'conditions': {}}, {'method': 'getSpaceTaken', 'type': 'method', 'parameters': [], 'conditions': {'RETURN': [{'description': 'sum of the space taken by the units in this location.', 'assertion': 'assert methodResultID == receiverObjectID.getTotalUnitCount();', 'name': None, 'content': 'sum of the space taken by the units in this location.'}]}}, {'method': 'moveToFront', 'type': 'method', 'parameters': [{'type': {'qualified_name': None, 'simple_name': 'Unit', 'is_array': False, 'array_dimensions': 0}, 'name': 'u'}], 'conditions': {'PARAM': [{'description': 'The <code>Unit</code> to move to the front.', 'assertion': 'assert (args[0] == null) == false;', 'name': 'u', 'content': 'The <code>Unit</code> to move to the front.'}]}}, {'method': 'clearUnitList', 'type': 'method', 'parameters': [], 'conditions': {}}, {'method': 'getNoAddReason', 'type': 'method', 'parameters': [{'type': {'qualified_name': None, 'simple_name': 'Locatable', 'is_array': False, 'array_dimensions': 0}, 'name': 'locatable'}], 'conditions': {'PARAM': [{'description': 'The <code>Locatable</code> to test.', 'assertion': 'assert args[0] != null;', 'name': 'locatable', 'content': 'The <code>Locatable</code> to test.'}], 'RETURN': [{'description': 'reason why adding would fail.', 'assertion': 'assert methodResultID == receiverObjectID.getNoAddReason(args[0]);', 'name': None, 'content': 'reason why adding would fail.'}]}}, {'method': 'getUnitCapacity', 'type': 'method', 'parameters': [], 'conditions': {'RETURN