ssing == current_nonmissing + 1);\n        } else {\n            throw new Error(\"Can't happen: \" + current_missing + \" \" + current_nonmissing);\n        }\n    }\n\n    public Long next() {\n        if (!hasNext()) {\n            throw new NoSuchElementException();\n        }\n        Long result = new Long(current_missing);\n        current_missing++;\n        return result;\n    }\n\n    public void remove() {\n        throw new UnsupportedOperationException();\n    }\n}",
