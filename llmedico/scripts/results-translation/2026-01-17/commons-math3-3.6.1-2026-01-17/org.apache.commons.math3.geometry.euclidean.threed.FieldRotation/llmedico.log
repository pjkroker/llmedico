            "content": "array of three angles, in the order specified by the set",
            "assertion": "",
            "description": "array of three angles, in the order specified by the set"
          },
          {
            "tag": "throws",
            "name": "CardanEulerSingularityException",
            "content": "if the rotation is singular with respect to the angles set specified",
            "assertion": "",
            "description": "if the rotation is singular with respect to the angles set specified"
          },
          {
