        "name": "min"
      },
      {
        "type": {
          "qualified_name": "double",
          "simple_name": "double",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "max"
      },
      {
        "type": {
          "qualified_name": "int",
          "simple_name": "int",
          "is_array": false,
          "array_dimensions": 0
        },
        "name": "n"
      }
    ],
    "conditions": {
      "PARAM": [
        {
          "description": "not null",
          "assertion": "assert args[0] != null;",
          "name": "f",
          "content": "Function to be sampled"
        },
        {
          "description": "lower bound is less than upper bound",
          "assertion": "assert args[1] < args[2];",
          "name": "min",
          "content": "Lower bound of the interval (included)."
        },
        {
          "description": "upper bound is greater than lower bound",
          "assertion": "assert args[1] < args[2];",
          "name": "max",
          "content": "Upper bound of the interval (excluded)."
        },
        {
          "description": "number of sample points is positive",
          "assertion": "assert args[3] > 0;",
          "name": "n",
          "content": "Number of sample points."
        }
      ],
      "RETURN": [
        {
          "description": "the array of samples.",
          "assertion": "assert java.util.Arrays.equals(methodResultID, receiverObjectID.sample(args[0], args[1], args[2], args[3]));",
          "name": null,
          "content": "the array of samples."
        }
      ],
      "THROWS": [
        {
          "description": "if the lower bound min is greater than, or equal to the upper bound max.",
          "assertion": "assert args[1] >= args[2];",
          "name": "NumberIsTooLargeException",
          "content": "if the lower bound {@code min} is greater than, or equal to the upper bound {@code max}."
        },
        {
          "description": "if the number of sample points n is negative.",
          "assertion": "assert args[3] < 0;",
          "name": "NotStrictlyPositiveException",
          "content": "if the number of sample points {@code n} is negative."
        }
      ]
    }
