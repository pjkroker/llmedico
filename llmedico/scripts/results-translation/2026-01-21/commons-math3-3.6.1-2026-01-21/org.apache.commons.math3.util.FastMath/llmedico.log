        "javadoc": "/**\n * Computes log(1 + x).\n *\n * @param x Number.\n * @return {@code log(1 + x)}.\n */\n",
        "tags": [
          {
            "tag": "param",
            "name": "x",
            "content": "Number.",
            "assertion": "assert true;",
