          },
          {
            "tag": "throws",
            "name": "MathArithmeticException",
            "content": "if the result cannot be represented as a non-negative {@code int} value.",
            "assertion": "assert (args[0] == Integer.MIN_VALUE && args[1] == Integer.MIN_VALUE) || (args[0] == Integer.MIN_VALUE && args[1] == 0) || (args[0] == 0 && args[1] == Integer.MIN_VALUE);",
