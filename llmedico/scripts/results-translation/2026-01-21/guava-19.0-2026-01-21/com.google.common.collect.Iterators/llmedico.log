        "code": "/**\n * Returns the number of elements remaining in {@code iterator}. The iterator\n * will be left exhausted: its {@code hasNext()} method will return\n * {@code false}.\n */\npublic static int size(Iterator<?> iterator) {\n    int count = 0;\n    while (iterator.hasNext()) {\n        iterator.next();\n        count++;\n    }\n    return count;\n}"
