        "code": "///\n/// gcd\n///\n/**\n * Return the greatest common divisor of the two arguments.\n * @param a first operand\n * @param b second operand\n * @return greatest common divisor of a and b\n */\npublic static int gcd(int a, int b) {\n    // Euclid's method\n    if (b == 0) {\n        return (Math.abs(a));\n    }\n    a = Math.abs(a);\n    b = Math.abs(b);\n    while (b != 0) {\n        int tmp = b;\n        b = a % b;\n        a = tmp;\n    }\n    return a;\n}"
